---
import siteConfig from '../data/site-config';
import '../styles/global.css';
import type { Language } from '../i18n/ui';
import { getEquivalentPage } from '@/utils/localized-routes';

export type Props = {
    title?: string;
    description?: string;
    image?: { src: string; alt?: string };
    pageType?: 'website' | 'article';
    lang?: Language;
    noindex?: boolean;
    structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
};

const { description = '', image = siteConfig.image, pageType = 'website', lang = 'es', noindex = false, structuredData } = Astro.props;
const title = [Astro.props.title, siteConfig.title].filter(Boolean).join(' | ');
const effectiveDescription = description?.trim() || siteConfig.description?.trim() || siteConfig.subtitle || 'Portfolio';

const resolvedImage = image?.src
    ? {
          src: new URL(image.src, Astro.site).toString(),
          alt: image.alt
      }
    : undefined;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

/**
 * Standard canonical formatting:
 * - removes query/hash
 * - keeps trailing slash for page routes
 */
function formatCanonicalURL(url: string | URL) {
    const normalized = new URL(url.toString());
    normalized.search = '';
    normalized.hash = '';

    if (!normalized.pathname.endsWith('/') && !normalized.pathname.includes('.')) {
        normalized.pathname = `${normalized.pathname}/`;
    }

    return normalized.toString();
}

const currentPath = Astro.url.pathname;
const alternatePaths = {
    es: getEquivalentPage(currentPath, 'es'),
    en: getEquivalentPage(currentPath, 'en'),
    no: getEquivalentPage(currentPath, 'no')
};

const alternateURLs = {
    es: formatCanonicalURL(new URL(alternatePaths.es, Astro.site)),
    en: formatCanonicalURL(new URL(alternatePaths.en, Astro.site)),
    no: formatCanonicalURL(new URL(alternatePaths.no, Astro.site))
};

const ogLocale = lang === 'es' ? 'es_ES' : lang === 'en' ? 'en_US' : 'no_NO';
const ogLocaleAlternates = ['es_ES', 'en_US', 'no_NO'].filter((locale) => locale !== ogLocale);

const websiteJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteConfig.title,
    description: effectiveDescription,
    url: formatCanonicalURL(canonicalURL),
    inLanguage: ['es', 'en', 'no'],
    author: {
        '@type': 'Person',
        name: 'Allison Peña',
        jobTitle: 'Full-stack web developer',
        url: 'https://allison.sh',
        sameAs: ['https://github.com/skryensya', 'https://linkedin.com/in/skryensya']
    },
    publisher: {
        '@type': 'Organization',
        name: siteConfig.title,
        url: 'https://allison.sh/'
    }
};

const additionalStructuredData = Array.isArray(structuredData)
    ? structuredData
    : structuredData
      ? [structuredData]
      : [];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="generator" content={Astro.generator} />

<link rel="dns-prefetch" href="https://api.github.com" />

<link rel="icon" type="image/x-icon" href="/img/favicon/favicon-dos-dark.ico" />
<link rel="shortcut icon" type="image/x-icon" href="/img/favicon/favicon-dos-dark.ico" />
<link rel="sitemap" href="/sitemap.xml" />
<link rel="alternate" type="application/rss+xml" href="/rss.xml" title="RSS" />

<link rel="canonical" href={formatCanonicalURL(canonicalURL)} />
<meta name="description" content={effectiveDescription} />
<meta name="language" content={lang} />
{noindex && <meta name="robots" content="noindex,follow" />}

<link rel="alternate" hreflang="es" href={alternateURLs.es} />
<link rel="alternate" hreflang="en" href={alternateURLs.en} />
<link rel="alternate" hreflang="no" href={alternateURLs.no} />
<link rel="alternate" hreflang="x-default" href={alternateURLs.es} />

<meta property="og:type" content={pageType} />
<meta property="og:url" content={formatCanonicalURL(canonicalURL)} />
<meta property="og:title" content={title} />
<meta property="og:description" content={effectiveDescription} />
<meta property="og:locale" content={ogLocale} />
{ogLocaleAlternates.map((locale) => <meta property="og:locale:alternate" content={locale} />)}
{resolvedImage?.src && <meta property="og:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta property="og:image:alt" content={resolvedImage.alt} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={formatCanonicalURL(canonicalURL)} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={effectiveDescription} />
{resolvedImage?.src && <meta name="twitter:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta name="twitter:image:alt" content={resolvedImage.alt} />}

<script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>
{additionalStructuredData.map((entry) => (
    <script type="application/ld+json" set:html={JSON.stringify(entry)}></script>
))}
