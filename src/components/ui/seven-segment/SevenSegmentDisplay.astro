---
import SevenSegmentDigit from './SevenSegmentDigit.astro';

interface Props {
  id?: string;
  value?: string;
  className?: string;
  inverted?: boolean;
  ariaLabel?: string;
}

const {
  id = 'seven-segment-display',
  value = '00.0:0',
  className = '',
  inverted = true,
  ariaLabel
} = Astro.props as Props;

const paletteClasses = inverted
  ? 'bg-main text-secondary border-secondary'
  : 'bg-secondary text-main border-main';
const chars = value.split('');
---

<div
  id={id}
  class={`ss-display inline-flex min-h-[28px] min-w-[78px] items-center justify-center gap-[2px] border px-2 py-1 font-mono font-bold text-xs rounded-[2px] ${paletteClasses} ${className}`}
  role="status"
  aria-label={ariaLabel ?? value}
  data-value={value}
>
  {chars.map((char) => <SevenSegmentDigit char={char} />)}
</div>

<style is:global>
  .ss-display {
    line-height: 1;
    box-shadow:
      inset 0 0 0 1px currentColor,
      inset 0 -1px 0 rgba(0, 0, 0, 0.12);
    background-image: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.08),
      rgba(0, 0, 0, 0.04)
    );
  }

  .ss-display .ss-digit {
    position: relative;
    display: inline-block;
    width: 15px;
    height: 22px;
    transform: skewX(-5deg);
    transform-origin: center;
  }

  .ss-display .ss-fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-family: var(--font-mono);
    font-weight: 700;
  }

  .ss-display .ss-colon {
    width: 6px;
    margin-inline: 1px;
    transform: none;
  }

  .ss-display .ss-dot-only {
    width: 5px;
    transform: none;
  }

  .ss-display .ss-dot {
    position: absolute;
    left: calc(50% - 1px);
    width: 2px;
    height: 2px;
    border-radius: 0;
    background: currentColor;
    opacity: 1;
  }

  .ss-display .ss-dot-top {
    top: 6px;
  }

  .ss-display .ss-dot-bottom {
    bottom: 6px;
  }

  .ss-display .ss-colon.is-off .ss-dot {
    opacity: 0.14;
  }

  .ss-display .ss-dot-only .ss-dot-bottom {
    bottom: 2px;
    left: calc(50% - 1px);
  }

  .ss-display .ss-seg {
    position: absolute;
    display: block;
    border-radius: 0;
    background: currentColor;
    opacity: 0.18;
    transition: opacity 150ms ease;
  }

  .ss-display .ss-seg.is-on {
    opacity: 1;
  }

  .ss-display .ss-a,
  .ss-display .ss-d,
  .ss-display .ss-g {
    clip-path: polygon(0 50%, 22% 0, 78% 0, 100% 50%, 78% 100%, 22% 100%);
    -webkit-clip-path: polygon(0 50%, 22% 0, 78% 0, 100% 50%, 78% 100%, 22% 100%);
  }

  .ss-display .ss-b,
  .ss-display .ss-c,
  .ss-display .ss-e,
  .ss-display .ss-f {
    clip-path: polygon(0 22%, 50% 0, 100% 22%, 100% 78%, 50% 100%, 0 78%);
    -webkit-clip-path: polygon(0 22%, 50% 0, 100% 22%, 100% 78%, 50% 100%, 0 78%);
  }

  .ss-display .ss-a {
    left: 2.7px;
    right: 2.7px;
    top: 1px;
    height: 2.4px;
  }

  .ss-display .ss-b {
    right: 1px;
    top: 3.2px;
    width: 2.4px;
    height: 7.2px;
  }

  .ss-display .ss-c {
    right: 1px;
    bottom: 3.2px;
    width: 2.4px;
    height: 7.2px;
  }

  .ss-display .ss-d {
    left: 2.7px;
    right: 2.7px;
    bottom: 1px;
    height: 2.4px;
  }

  .ss-display .ss-e {
    left: 1px;
    bottom: 3.2px;
    width: 2.4px;
    height: 7.2px;
  }

  .ss-display .ss-f {
    left: 1px;
    top: 3.2px;
    width: 2.4px;
    height: 7.2px;
  }

  .ss-display .ss-g {
    left: 2.7px;
    right: 2.7px;
    top: 10.2px;
    height: 2.4px;
  }
</style>
