---
import Layout from '@/layouts/Layout.astro';
import { getTranslations } from '@/i18n/utils';
import { defaultLang, type Language } from '@/i18n/ui';
import { ProyectStack } from '@/components/ProyectStack.tsx';

interface Props {
    lang?: Language;
    projects?: unknown;
}

const { lang = defaultLang } = Astro.props as Props;

const t = getTranslations(lang);

const projectsDescription = {
    es: 'Listado de proyectos de Allison Peña: desarrollo web full-stack con foco en accesibilidad, performance y sistemas de diseño.',
    en: 'Project archive by Allison Peña: full-stack web development focused on accessibility, performance, and design systems.',
    no: 'Prosjektoversikt av Allison Peña: fullstack webutvikling med fokus på tilgjengelighet, ytelse og designsystemer.',
    ja: 'Allison Peña のプロジェクト一覧。アクセシビリティ、パフォーマンス、デザインシステムに焦点を当てた開発。'
} as const;
---

<Layout
    title={t('nav.projects')}
    description={projectsDescription[lang]}
    showHeader={true}
    headerTitle={t('nav.projects')}
    headerSubtitle={t('nav.projects')}
    lang={lang}
>
    <h1 class="mb-12 text-2xl leading-tight font-mono sm:mb-16 sm:text-4xl">{t('nav.projects')}</h1>

    <ProyectStack client:visible ></ProyectStack>
</Layout>
