---
import Layout from '@/layouts/Layout.astro';
import siteConfig from '@/data/site-config';
import Hero from '@/components/sections/Hero.astro';
import ProjectsSection from '@/components/sections/ProjectsSection.astro';
import { defaultLang, type Language } from '@/i18n/ui';
import { getTranslations } from '@/i18n/utils';

interface Props {
    lang?: Language;
}

const { lang = defaultLang } = Astro.props as Props;
const t = getTranslations(lang);

const homeTitleByLang: Record<Language, string> = {
    es: 'Desarrollador web full stack',
    en: 'Full-stack web developer',
    no: 'Fullstack webutvikler',
    ja: 'フルスタック・ウェブデベロッパー'
};

const personJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Allison Peña',
    jobTitle: 'Full-stack web developer',
    url: 'https://allison.sh/',
    sameAs: [
        'https://github.com/skryensya',
        'https://linkedin.com/in/skryensya',
        'https://lichess.org/@/Skryensya'
    ]
};
---

<Layout title={homeTitleByLang[lang]} description={t('site.description')} image={siteConfig.image} lang={lang} structuredData={personJsonLd}>
    <Hero lang={lang} />

    <ProjectsSection lang={lang} />
</Layout>
