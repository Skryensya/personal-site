---
/**
 * CardSwapAstro — animación de baraja sin GSAP.
 *
 * Antes: dependía de window.gsap que nunca se cargaba → las cards se apilaban
 * pero el swap no ocurría visualmente. Ahora usa CSS transitions nativas, lo que
 * hace el efecto funcionar realmente en producción.
 *
 * El stack y el swap son idénticos al diseño original:
 * - Cards posicionadas en diagonal (offset x/y/z con skewY)
 * - Container escalado para encajar en el padre (ResizeObserver)
 * - Swap automático cada `delay` ms rotando el orden del array
 * - Animación manejada por CSS transition (translate3d, ease)
 * - pauseOnHover soportado
 */
interface Props {
  width?: number | string;
  height?: number | string;
  cardDistance?: number;
  verticalDistance?: number;
  delay?: number;
  pauseOnHover?: boolean;
  enableSwap?: boolean;
  skewAmount?: number;
  class?: string;
}

const {
  width          = 500,
  height         = 400,
  cardDistance   = 60,
  verticalDistance = 70,
  delay          = 5000,
  pauseOnHover   = false,
  enableSwap     = true,
  skewAmount     = 6,
  class: className = ''
} = Astro.props;
---

<div
  class={`card-swap-container absolute inset-0 flex items-center justify-center overflow-visible ${className}`}
  style="--card-swap-scale:1"
  data-width={typeof width === 'number' ? String(width) : width}
  data-height={typeof height === 'number' ? String(height) : height}
  data-card-distance={cardDistance}
  data-vertical-distance={verticalDistance}
  data-delay={delay}
  data-pause-on-hover={pauseOnHover}
  data-enable-swap={enableSwap}
  data-skew-amount={skewAmount}
>
  <slot />
</div>

<style>
  .card-swap-container {
    transform: translateZ(0) scale(var(--card-swap-scale, 1));
    transform-origin: center center;
  }
</style>

<script>
  interface Slot { x: number; y: number; z: number; zIndex: number; }

  function makeSlot(i: number, distX: number, distY: number, total: number): Slot {
    const cx = (total - 1) / 2;
    return {
      x:      (i - cx) * distX * 0.7,
      y:      (cx - i) * distY * 0.7,
      z:      -i * 20,
      zIndex: total - i
    };
  }

  function applySlot(el: HTMLElement, slot: Slot, skew: number, animate: boolean) {
    if (animate) {
      el.style.transition = 'transform 0.65s cubic-bezier(0.4,0,0.2,1)';
    } else {
      el.style.transition = 'none';
    }
    el.style.transform  = `translate(-50%,-50%) translate3d(${slot.x}px,${slot.y}px,${slot.z}px) skewY(${skew}deg)`;
    el.style.zIndex     = String(slot.zIndex);
    el.style.transformOrigin = 'center center';
    el.style.willChange = 'transform';
  }

  function parseDim(v: string | undefined, fallback: number, parent: number): number {
    if (!v) return fallback;
    const s = v.trim();
    if (s.endsWith('%')) return (parent * parseFloat(s)) / 100;
    const n = parseFloat(s);
    return isNaN(n) ? fallback : n;
  }

  class CardSwap {
    private el:      HTMLElement;
    private cards:   HTMLElement[];
    private order:   number[];
    private cfg:     { distX: number; distY: number; delay: number; skew: number; pause: boolean; swap: boolean };
    private timer:   number | null  = null;
    private ro:      ResizeObserver | null = null;
    private animating = false;

    constructor(el: HTMLElement) {
      this.el    = el;
      this.cards = Array.from(el.querySelectorAll<HTMLElement>('.card-swap-card'));
      this.order = this.cards.map((_, i) => i);
      this.cfg   = {
        distX:  parseInt(el.dataset.cardDistance     || '60'),
        distY:  parseInt(el.dataset.verticalDistance || '70'),
        delay:  parseInt(el.dataset.delay            || '5000'),
        skew:   parseInt(el.dataset.skewAmount       || '6'),
        pause:  el.dataset.pauseOnHover === 'true',
        swap:   el.dataset.enableSwap   !== 'false'
      };
      this.init();
    }

    private scale() {
      const parent = this.el.parentElement;
      const c0     = this.cards[0];
      if (!parent || !c0) return;
      const pr = parent.getBoundingClientRect();
      const bw = parseDim(this.el.dataset.width,  c0.offsetWidth  || 1, pr.width);
      const bh = parseDim(this.el.dataset.height, c0.offsetHeight || 1, pr.height);
      const sx = pr.width  / Math.max(bw + (this.cards.length - 1) * this.cfg.distX * 0.7 + 40, 1);
      const sy = pr.height / Math.max(bh + (this.cards.length - 1) * this.cfg.distY * 0.7 + 48, 1);
      this.el.style.setProperty('--card-swap-scale', String(Math.max(0.45, Math.min(1, sx, sy))));
    }

    private place(animate: boolean) {
      this.order.forEach((ci, pos) =>
        applySlot(this.cards[ci], makeSlot(pos, this.cfg.distX, this.cfg.distY, this.cards.length), this.cfg.skew, animate)
      );
    }

    private swap() {
      if (this.animating || this.order.length < 2) return;
      this.animating = true;
      // Rotar: el de adelante pasa al fondo
      this.order = [...this.order.slice(1), this.order[0]];
      this.place(true);
      setTimeout(() => { this.animating = false; }, 700);
    }

    private startCycle() {
      if (!this.cfg.swap) return;
      // Primer swap tras un segundo (deja que el reveal termine)
      setTimeout(() => this.swap(), 1000);
      this.timer = window.setInterval(() => this.swap(), this.cfg.delay);
    }

    init() {
      // Posicionado inmediato sin animación (evita CLS)
      this.place(false);
      this.scale();

      this.ro = new ResizeObserver(() => this.scale());
      if (this.el.parentElement) this.ro.observe(this.el.parentElement);
      this.ro.observe(this.el);

      this.startCycle();

      if (this.cfg.pause) {
        this.el.addEventListener('mouseenter', () => {
          if (this.timer) { clearInterval(this.timer); this.timer = null; }
        });
        this.el.addEventListener('mouseleave', () => {
          if (!this.timer) this.timer = window.setInterval(() => this.swap(), this.cfg.delay);
        });
      }
    }

    destroy() {
      if (this.timer) { clearInterval(this.timer); this.timer = null; }
      if (this.ro)    { this.ro.disconnect(); this.ro = null; }
    }
  }

  const instances = new Set<CardSwap>();

  function init() {
    instances.forEach(i => i.destroy());
    instances.clear();
    document.querySelectorAll<HTMLElement>('.card-swap-container').forEach(el => {
      instances.add(new CardSwap(el));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }

  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-preparation', () => {
    instances.forEach(i => i.destroy());
    instances.clear();
  });
</script>
