---
import { getTranslations } from '@/i18n/utils';
import { defaultLang, type Language } from '@/i18n/ui';

interface Props {
    theme: {
        id: string;
        name: string;
        description: string;
        colors: {
            colorful: string;
            contrasty: string;
        };
    };
    lang?: Language;
    isActive?: boolean;
    enableAnchor?: boolean;
}

const { theme, lang = defaultLang, isActive = false, enableAnchor = true } = Astro.props;
const t = getTranslations(lang);

const nameKey = (`theme.${theme.id}`) as any;
const localizedName = t(nameKey);
const displayName = (typeof localizedName === 'string' && localizedName !== nameKey) ? localizedName : theme.name;
const colorfulHexLabel = theme.colors.colorful.toUpperCase();
const contrastyHexLabel = theme.colors.contrasty.toUpperCase();

// Create a stable slug from localized theme name for anchor linking
const slug = 'theme-' + displayName
  .toLowerCase()
  .normalize('NFD')
  .replace(/[\u0300-\u036f]/g, '') // strip accents
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/(^-|-$)/g, '');
---

<div data-anchor-id={slug}
    class="border-2 overflow-hidden flex flex-col theme-card cursor-pointer h-full min-h-[232px]"
    style={`border-color: ${theme.colors.colorful}; outline: 2px solid ${theme.colors.contrasty}`}
    data-theme-id={theme.id}
    data-prism-preview={theme.id === 'prism-flow' ? 'true' : 'false'}
    role="button"
    tabindex="0"
    aria-label={`${t('theme.apply')} ${displayName}`}
>
    <div
        class="px-4 pt-4 pb-3.5 flex-1 flex flex-col"
        style={`background-color: ${theme.colors.colorful}; color: ${theme.colors.contrasty}; border-color: ${theme.colors.colorful}`}
        data-prism-colorful
    >
        <div class="flex items-start justify-between gap-3 mb-2.5">
            <div class="flex-1 min-w-0 pr-1">
                <div class="font-bold uppercase leading-tight mb-1" data-theme-title>
                    {displayName}
                </div>
                {(() => {
                    const key = (`theme.desc.${theme.id}`) as any;
                    const localized = t(key);
                    const desc = (typeof localized === 'string' && localized.startsWith('theme.desc.')) ? theme.description : localized;
                    return <p class="text-sm leading-snug opacity-80" style="height: 3.85rem; overflow: hidden;">{desc}</p>;
                })()}
            </div>
            <button
                type="button"
                class="apply-theme-btn flex-shrink-0"
                data-theme-id={theme.id}
                aria-label={`${t('theme.apply')} ${displayName}`}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class:list={["lucide lucide-circle w-6 h-6 theme-unchecked opacity-40 hover:opacity-100", { hidden: isActive }]}
                >
                    <circle cx="12" cy="12" r="10"/>
                </svg>
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    class:list={["w-6 h-6 theme-checked opacity-100", { hidden: !isActive }]}
                    aria-hidden="true"
                >
                    <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" />
                    <circle cx="12" cy="12" r="4.5" fill="currentColor" />
                </svg>
            </button>
        </div>
        <p class="text-xs font-mono mt-auto pt-1">
            <span class="capitalize">{t('designSystem.colors.themes.colorful')}</span>: <span data-prism-colorful-value>{colorfulHexLabel}</span>
        </p>
    </div>

    <div
        class="px-4 py-3.5 shrink-0"
        style={`background-color: ${theme.colors.contrasty}; color: ${theme.colors.colorful}`}
        data-prism-contrasty
    >
        <p class="font-mono text-xs font-bold">
            <span class="capitalize">{t('designSystem.colors.themes.contrasty')}</span>: <span data-prism-contrasty-value>{contrastyHexLabel}</span>
        </p>
    </div>
</div>

<style is:global>
    @keyframes themeDotPop {
        0% { transform: scale(0.55); opacity: 0.35; }
        60% { transform: scale(1.12); opacity: 1; }
        100% { transform: scale(1); opacity: 1; }
    }

    .theme-dot-pop {
        animation: themeDotPop 180ms cubic-bezier(0.2, 0.9, 0.3, 1);
        transform-origin: center;
    }

    @media (prefers-reduced-motion: reduce) {
        .theme-dot-pop {
            animation: none;
        }
    }
</style>

<script is:inline define:vars={{ slug, themeId: theme.id, enableAnchor }}>
    const initThemeCard = () => {
        const card = document.querySelector(`[data-anchor-id="${slug}"]`);
        if (!card) return;

        const applyThemeFromCard = async () => {
            const tc = window.themeControl;

            if (tc && Array.isArray(tc.availableThemes) && typeof tc.selectTheme === 'function') {
                const selected = tc.availableThemes.find((t) => t.id === themeId);
                if (selected) {
                    tc.selectTheme(selected);
                    window.dispatchEvent(new CustomEvent('theme-changed', { detail: { themeId } }));
                    return;
                }
            }

            // Fallback: ask ThemeControl to handle selection when it finishes initializing
            window.dispatchEvent(new CustomEvent('theme-card-select', { detail: { themeId } }));
            window.dispatchEvent(new CustomEvent('theme-changed', { detail: { themeId } }));
        };

        if (!card.hasAttribute('data-anchor-bound')) {
            card.setAttribute('data-anchor-bound', 'true');

            card.addEventListener('click', async (e) => {
                const target = e.target;
                if (target instanceof HTMLElement && target.closest('.apply-theme-btn')) return;
                await applyThemeFromCard();
            });

            card.addEventListener('keydown', async (e) => {
                if (e.key !== 'Enter' && e.key !== ' ') return;
                e.preventDefault();
                await applyThemeFromCard();
            });

            const applyBtn = card.querySelector('.apply-theme-btn');
            if (applyBtn) {
                applyBtn.addEventListener('click', async (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    await applyThemeFromCard();
                });
            }
        }

        if (themeId !== 'prism-flow') return;

        const prismCard = document.querySelector('[data-prism-preview="true"]');
        if (!prismCard) return;

        const colorfulPane = prismCard.querySelector('[data-prism-colorful]');
        const contrastyPane = prismCard.querySelector('[data-prism-contrasty]');
        const colorfulValue = prismCard.querySelector('[data-prism-colorful-value]');
        const contrastyValue = prismCard.querySelector('[data-prism-contrasty-value]');
        if (!colorfulPane || !contrastyPane) return;

        const w = window;

        if (w.__prismPreviewInterval) return;

        const sessionHue = Number(sessionStorage.getItem('prism-flow-hue'));
        w.__prismPreviewHue = Number.isFinite(sessionHue) ? sessionHue : (w.__prismPreviewHue ?? 275);
        w.__prismPreviewStart = performance.now();

        const clamp = (v, min, max) => Math.min(max, Math.max(min, v));

        const colorProbe = document.createElement('span');
        colorProbe.style.display = 'none';
        document.body.appendChild(colorProbe);

        const cssColorToHex = (cssColor) => {
            colorProbe.style.color = cssColor;
            const rgb = getComputedStyle(colorProbe).color;

            const match = rgb.match(/\d+/g);
            if (!match || match.length < 3) return cssColor;
            const [r, g, b] = match.slice(0, 3).map(Number);
            return (
                '#' +
                [r, g, b]
                    .map((n) => n.toString(16).padStart(2, '0'))
                    .join('')
                    .toUpperCase()
            );
        };

        const applyPreview = (colorful, contrasty) => {
            colorfulPane.style.backgroundColor = colorful;
            colorfulPane.style.color = contrasty;
            contrastyPane.style.backgroundColor = contrasty;
            contrastyPane.style.color = colorful;
            prismCard.style.borderColor = colorful;
            prismCard.style.outline = `2px solid ${contrasty}`;

            if (colorfulValue) colorfulValue.textContent = cssColorToHex(colorful);
            if (contrastyValue) contrastyValue.textContent = cssColorToHex(contrasty);
        };

        const tick = () => {
            const activeTheme = localStorage.getItem('theme-id');

            // If Prisma is active, mirror real runtime colors exactly
            if (activeTheme === 'prism-flow') {
                const rootStyles = getComputedStyle(document.documentElement);
                const colorful = rootStyles.getPropertyValue('--theme-colorful').trim();
                const contrasty = rootStyles.getPropertyValue('--theme-contrasty').trim();
                if (colorful && contrasty) {
                    applyPreview(colorful, contrasty);
                    return;
                }
            }

            // Otherwise, run same curve as runtime theme engine
            const elapsed = (performance.now() - (w.__prismPreviewStart || 0)) / 1000;
            const anchors = [196, 228, 272, 318, 18, 52];
            const cycleDurationSec = 36;
            const cycle = ((elapsed / cycleDurationSec) % 1 + 1) % 1;
            const scaled = cycle * anchors.length;
            const fromIndex = Math.floor(scaled) % anchors.length;
            const toIndex = (fromIndex + 1) % anchors.length;
            const localT = scaled - Math.floor(scaled);
            const easedT = localT * localT * (3 - 2 * localT);

            const fromHue = anchors[fromIndex];
            const toHue = anchors[toIndex];
            const shortestDelta = ((toHue - fromHue + 540) % 360) - 180;
            const baseHue = (fromHue + shortestDelta * easedT + 360) % 360;

            w.__prismPreviewHue = (baseHue + Math.sin(elapsed * 0.19) * 2.6 + Math.sin(elapsed * 0.07 + 1.1) * 1.4 + 360) % 360;

            const h1 = w.__prismPreviewHue;
            const h2 = (h1 + 158 + Math.sin(elapsed * 0.11 + 0.6) * 6.5 + 360) % 360;

            const colorfulSat = clamp(66 + Math.sin(elapsed * 0.23) * 7 + Math.sin(elapsed * 0.09 + 1.7) * 4, 56, 78);
            const colorfulLight = clamp(83 + Math.sin(elapsed * 0.17 + 0.4) * 3.6 + Math.sin(elapsed * 0.05) * 1.8, 76, 88);
            const contrastySat = clamp(48 + Math.sin(elapsed * 0.21 + 2.2) * 8, 36, 62);
            const contrastyLight = clamp(20 + Math.sin(elapsed * 0.16 + 0.9) * 3.2, 14, 26);

            const colorful = `hsl(${h1.toFixed(1)} ${colorfulSat.toFixed(1)}% ${colorfulLight.toFixed(1)}%)`;
            const contrasty = `hsl(${h2.toFixed(1)} ${contrastySat.toFixed(1)}% ${contrastyLight.toFixed(1)}%)`;
            applyPreview(colorful, contrasty);
        };

        tick();
        w.__prismPreviewInterval = window.setInterval(tick, 180);
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initThemeCard, { once: true });
    } else {
        initThemeCard();
    }

    document.addEventListener('astro:page-load', initThemeCard);
</script>
