---
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST || 'https://us.i.posthog.com';
const posthogUiHost = import.meta.env.PUBLIC_POSTHOG_UI_HOST || 'https://us.posthog.com';
---

{posthogKey && (
  <script is:inline define:vars={{ posthogKey, posthogHost, posthogUiHost }} type="text/javascript" id="posthog-js">
    // @ts-nocheck
    (() => {
      const w = window;
      const LOAD_TIMEOUT_MS = 15000;
      const STATE_KEY = '__POSTHOG_DEFERRED_STATE__';

      const state = (w[STATE_KEY] = w[STATE_KEY] || {
        initialized: false,
        initPromise: null,
        pageviewQueued: false,
        listenersBound: false,
        timeoutId: null,
      });

      function createStub() {
        let o, n, p, r;
        const e = w.posthog || [];

        if (e.__SV) {
          return e;
        }

        w.posthog = e;
        e._i = e._i || [];
        e.init = function (i, s, a) {
          function g(t, key) {
            const parts = key.split('.');
            if (parts.length === 2) {
              t = t[parts[0]];
              key = parts[1];
            }
            t[key] = function () {
              t.push([key].concat(Array.prototype.slice.call(arguments, 0)));
            };
          }

          p = document.createElement('script');
          p.type = 'text/javascript';
          p.crossOrigin = 'anonymous';
          p.async = true;
          p.src = s.api_host + '/static/array.js';
          r = document.getElementsByTagName('script')[0];
          r.parentNode.insertBefore(p, r);

          let u = e;
          if (a !== void 0) {
            u = e[a] = [];
          } else {
            a = 'posthog';
          }

          u.people = u.people || [];
          u.toString = function (t) {
            let label = 'posthog';
            if (a !== 'posthog') label += '.' + a;
            if (!t) label += ' (stub)';
            return label;
          };
          u.people.toString = function () {
            return u.toString(1) + '.people (stub)';
          };

          o = 'capture identify alias people.set people.set_once set_config register register_once unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled onFeatureFlags getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures getActiveMatchingSurveys getSurveys getNextSurveyStep onSessionId'.split(' ');
          for (n = 0; n < o.length; n++) g(u, o[n]);
          e._i.push([i, s, a]);
        };
        e.__SV = 1;
        return e;
      }

      function initPostHog() {
        if (state.initPromise) return state.initPromise;

        state.initPromise = new Promise((resolve, reject) => {
          try {
            const posthog = createStub();
            posthog.init(posthogKey, {
              api_host: posthogHost,
              ui_host: posthogUiHost,
              capture_pageview: false,
              capture_pageleave: true,
              autocapture: true,
              disable_session_recording: true,
              disable_surveys: true,
              loaded: (instance) => {
                state.initialized = true;
                resolve(instance);
              }
            });
          } catch (error) {
            reject(error);
          }
        }).catch(() => {
          state.initPromise = null;
          state.initialized = false;
          throw new Error('posthog-init-failed');
        });

        return state.initPromise;
      }

      function capturePageview() {
        state.pageviewQueued = true;
        initPostHog()
          .then((posthog) => {
            if (!state.pageviewQueued) return;
            state.pageviewQueued = false;
            posthog.capture('$pageview');
          })
          .catch(() => {});
      }

      function cleanupTriggers() {
        if (state.timeoutId) {
          clearTimeout(state.timeoutId);
          state.timeoutId = null;
        }

        window.removeEventListener('pointerdown', onTrigger, true);
        window.removeEventListener('keydown', onTrigger, true);
        window.removeEventListener('scroll', onTrigger, true);
      }

      function onTrigger() {
        cleanupTriggers();
        capturePageview();
      }

      function bindTriggers() {
        if (state.listenersBound || state.initialized) return;
        state.listenersBound = true;

        window.addEventListener('pointerdown', onTrigger, { once: true, capture: true, passive: true });
        window.addEventListener('keydown', onTrigger, { once: true, capture: true });
        window.addEventListener('scroll', onTrigger, { once: true, capture: true, passive: true });
        state.timeoutId = window.setTimeout(onTrigger, LOAD_TIMEOUT_MS);
      }

      bindTriggers();

      document.addEventListener('astro:page-load', () => {
        if (state.initialized && w.posthog) {
          w.posthog.capture('$pageview');
          return;
        }

        bindTriggers();
      });
    })();
  </script>
)}
