---
/**
 * ProjectCarousel — reemplaza Embla (8.4 KB gz) con CSS scroll-snap nativo.
 *
 * Comportamiento igual al anterior:
 * - ≤ 3 proyectos → grid estático (sin carrusel)
 * - > 3 proyectos → scroll horizontal con snap
 *   · móvil: 1 columna, avanza 1 card
 *   · tablet: 2 columnas, avanza 2 cards
 *   · desktop: 3 columnas, avanza 3 cards
 * - Botones prev/next con estado disabled
 * - Controles ocultos cuando no hay scroll posible
 */
import Button from './Button.astro';

interface Props {
  projectCount: number;
  class?: string;
}

const { projectCount, class: className = '' } = Astro.props;
const isCarousel = projectCount > 3;
---

{!isCarousel ? (
  <div class:list={['grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4', className]}>
    <slot />
  </div>
) : (
  <div class:list={['relative', className]} data-snap-carousel>
    <!-- Viewport: scroll-snap container -->
    <div class="snap-vp overflow-x-auto" data-snap-vp>
      <div class="snap-track flex" data-snap-track>
        <slot />
      </div>
    </div>

    <!-- Controls -->
    <div class="flex justify-end items-center mt-8 gap-2" data-snap-controls>
      <div data-snap-prev-wrap class="opacity-30 cursor-not-allowed">
        <Button
          type="button" filled={true} size="sm"
          class="!w-12 !h-12 !p-0 flex items-center justify-center pointer-events-none"
          disabled={true}
          data-snap-prev
          aria-label="Anterior"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6"/>
          </svg>
        </Button>
      </div>

      <div data-snap-next-wrap>
        <Button
          type="button" filled={true} size="sm"
          class="!w-12 !h-12 !p-0 flex items-center justify-center"
          data-snap-next
          aria-label="Siguiente"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </Button>
      </div>
    </div>
  </div>
)}

<script>
  function initCarousels() {
    document.querySelectorAll<HTMLElement>('[data-snap-carousel]').forEach(el => {
      if (el.dataset.scInit === '1') return;
      el.dataset.scInit = '1';

      const vp       = el.querySelector<HTMLElement>('[data-snap-vp]')!;
      const prevWrap = el.querySelector<HTMLElement>('[data-snap-prev-wrap]')!;
      const nextWrap = el.querySelector<HTMLElement>('[data-snap-next-wrap]')!;
      const prevBtn  = el.querySelector<HTMLButtonElement>('[data-snap-prev]')!;
      const nextBtn  = el.querySelector<HTMLButtonElement>('[data-snap-next]')!;
      const controls = el.querySelector<HTMLElement>('[data-snap-controls]')!;
      if (!vp || !prevBtn || !nextBtn) return;

      const setDisabled = (btn: HTMLButtonElement, wrap: HTMLElement, off: boolean) => {
        btn.disabled = off;
        wrap.classList.toggle('opacity-30', off);
        wrap.classList.toggle('cursor-not-allowed', off);
        btn.classList.toggle('pointer-events-none', off);
      };

      const update = () => {
        const atStart = vp.scrollLeft <= 2;
        const atEnd   = vp.scrollLeft + vp.clientWidth >= vp.scrollWidth - 2;
        setDisabled(prevBtn, prevWrap, atStart);
        setDisabled(nextBtn, nextWrap, atEnd);
        // Ocultar controles si no hay scroll en ninguna dirección
        controls.classList.toggle('hidden', atStart && atEnd);
      };

      prevBtn.addEventListener('click', () =>
        vp.scrollBy({ left: -vp.clientWidth, behavior: 'smooth' }));
      nextBtn.addEventListener('click', () =>
        vp.scrollBy({ left:  vp.clientWidth, behavior: 'smooth' }));

      vp.addEventListener('scroll', update, { passive: true });
      new ResizeObserver(update).observe(vp);
      update();
    });
  }

  initCarousels();
  document.addEventListener('astro:page-load', initCarousels);
</script>

<style>
  /* Ocultar scrollbar visual pero mantener scroll funcional */
  .snap-vp {
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
  }
  .snap-vp::-webkit-scrollbar { display: none; }

  /* Cada slide ocupa el ancho correcto según breakpoint */
  .snap-track { display: flex; }
  .snap-track > :global(*) {
    flex: 0 0 100%;
    scroll-snap-align: start;
    padding-left: 0.25rem;
    padding-right: 0.25rem;
  }
  .snap-track > :global(*:first-child) { padding-left: 0; }
  .snap-track > :global(*:last-child)  { padding-right: 0; }

  @media (min-width: 768px) {
    .snap-track > :global(*) { flex: 0 0 50%; }
  }
  @media (min-width: 1024px) {
    .snap-track > :global(*) { flex: 0 0 33.333333%; }
  }
</style>
