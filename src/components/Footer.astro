---
import siteConfig, { type Link } from '@/data/site-config';
import WaveDivider from './WaveDivider.astro';
import { Heart } from 'lucide-react';
import { getTranslations } from '@/i18n/utils';
import { defaultLang, type Language } from '@/i18n/ui';
import CircularTextAstro from '@/components/CircularTextAstro.astro';
import FooterContrastDisplay from '@/components/ui/seven-segment/FooterContrastDisplay.astro';
import FooterNavigationList from '@/components/FooterNavigationList.astro';

interface Props { 
  lang?: Language; 
}

const { lang = defaultLang } = Astro.props;
const t = getTranslations(lang);

const connectLinks = (siteConfig.socialLinks || []).map((link: Link) => ({
  href: link.href,
  text: link.text,
  isExternal: true,
}));

---

<footer id="site-footer" class="bg-main border-t-double border-t-2 border-secondary selection-opposite">
  <WaveDivider inverted />
  <div class="mx-auto max-w-[var(--max-w-size)] px-4 pb-4">
    <!-- Main content flex - Mobile: stacked, Desktop: 83.33% content + 16.67% circle -->
    <div class="flex flex-col md:flex-row gap-4 mb-8">
      <!-- Content sections container - full width when circle is hidden, flexes with circle on lg -->
      <div class="flex flex-col md:flex-row gap-4 md:gap-6 lg:gap-14 w-full lg:flex-1">
        <!-- Navigation - 33.33% of content area -->
        <div class="md:w-[33.33%] w-full">
          <h3 class="font-mono uppercase tracking-wider text-sm font-bold !mb-2 !mt-1 text-secondary scramble-text" data-text={t('footer.navigation')}>
            {t('footer.navigation')}
          </h3>
          <FooterNavigationList lang={lang} />
        </div>

        <!-- Social - 33.33% of content area -->
        <div class="md:w-[33.33%] w-full">
          <h3 class="font-mono uppercase tracking-wider text-sm font-bold !mb-2 !mt-1 text-secondary scramble-text" data-text={t('footer.connect')}>
            {t('footer.connect')}
          </h3>
          <FooterNavigationList lang={lang} links={connectLinks} />
        </div>

        <!-- Information - 33.33% of content area -->
        <div class="md:w-[33.33%] w-full">
          <h3 class="font-mono uppercase tracking-wider text-sm font-bold !mb-2 !mt-1 text-secondary scramble-text" data-text={t('footer.info')}>
            {t('footer.info')}
          </h3>
          <nav class="space-y-1">
            <div class="block font-mono text-sm text-secondary px-2 py-0.5 scramble-text" data-text="Santiago, Chile">
              Santiago, Chile
            </div>
            <div class="block font-mono text-sm text-secondary px-2 py-0.5 scramble-text" data-text={t('footer.availableForProjects')}>
              {t('footer.availableForProjects')}
            </div>
            <div class="block font-mono text-sm pt-2 pb-1">
              <div class="relative text-secondary font-mono text-sm pr-20 md:pr-0">
                <div class="md:hidden absolute right-0 -top-[42px] scale-[1.1] origin-top-right" style="view-transition-name: none;">
                  <CircularTextAstro text="ALLISON PEÑA * SKRYENSYA * " onHover="speedUp" spinDuration={20}/>
                </div>
                <h3 class="font-mono uppercase tracking-wider text-sm font-bold !mb-2 !mt-1 text-secondary scramble-text" data-text={t('footer.aspectRatio.title')}>
                  {t('footer.aspectRatio.title')}
                </h3>
                <div class="flex gap-1.5 items-center ">
                  <FooterContrastDisplay
                    id="footer-contrast-display"
                    initialValue="00.0:0"
                    className="text-main !gap-[1px] ss-display-proportion-standard"
                    inverted={false}
                  />
                  <div id="footer-wcag-levels" class="flex gap-1.5"></div>
                </div>
              </div>
            </div>
            <div class="block font-mono text-sm py-2">
              <div class="text-secondary font-mono text-sm">
                <h3 class="font-mono uppercase tracking-wider text-sm font-bold !mb-2 !mt-1 text-secondary scramble-text" data-text={t('footer.motion.label')}>
                  {t('footer.motion.label')}
                </h3>
                <div class=""><span id="motion-status" class="scramble-text inline-flex items-center px-2 py-1 text-xs font-mono font-bold border border-secondary bg-main text-secondary ml-2">{t('footer.motion.detecting')}</span></div>
              </div>
            </div>
          </nav>
        </div>
      </div>

      <!-- CircularText - hidden on mobile/md, visible on lg+ -->
      <div class="hidden lg:flex lg:w-36 justify-center items-start overflow-visible" style="view-transition-name: none;">
        <CircularTextAstro text="ALLISON PEÑA * SKRYENSYA * " onHover="speedUp" spinDuration={20}/>
      </div>
    </div>

  </div>

  <div class="mx-auto w-full max-w-[var(--max-w-size)] px-4 pt-4 pb-8">
    <div class="w-full border-t border-secondary/50 pt-4 flex justify-center">
      <p class="font-mono text-sm text-secondary scramble-text flex items-center justify-center gap-2 text-center" data-text="Hecho con por Allison Peña" data-has-heart="true">
        <span class="scramble-part">Hecho con</span>
        <Heart size={14} className="text-secondary" fill="currentColor" />
        <span class="scramble-part">por Allison Peña</span>
      </p>
    </div>
  </div>
</footer>

<script>
  const debugLogger = (window as any).debugLogger ?? {
    log: () => {},
    warn: () => {},
    group: () => {},
    groupEnd: () => {}
  };

  let footerCleanup: (() => void) | null = null;

  // Function to initialize footer functionality
  function initFooter() {
    // Clean previous listeners/observers to avoid stacking on Astro transitions
    if (footerCleanup) {
      footerCleanup();
      footerCleanup = null;
    }

    debugLogger.log('🦶 Footer script initialized');

    let footerAnimated = false;
    const cleanupFns: Array<() => void> = [];

    // Contrast ratio calculation functions
    function hexToRgb(hex: string): { r: number; g: number; b: number } | null {
      const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
      return result ? {
        r: parseInt(result[1], 16),
        g: parseInt(result[2], 16),
        b: parseInt(result[3], 16)
      } : null;
    }

    function getRelativeLuminance(r: number, g: number, b: number): number {
      const [rNorm, gNorm, bNorm] = [r, g, b].map(c => {
        c = c / 255;
        return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
      });
      return 0.2126 * rNorm + 0.7152 * gNorm + 0.0722 * bNorm;
    }

    function getContrastRatio(color1: string, color2: string): number {
      const rgb1 = hexToRgb(color1);
      const rgb2 = hexToRgb(color2);

      if (!rgb1 || !rgb2) return 1;

      const lum1 = getRelativeLuminance(rgb1.r, rgb1.g, rgb1.b);
      const lum2 = getRelativeLuminance(rgb2.r, rgb2.g, rgb2.b);

      const brightest = Math.max(lum1, lum2);
      const darkest = Math.min(lum1, lum2);

      return (brightest + 0.05) / (darkest + 0.05);
    }

    function updateWcagLevelsUI(ratio: number): void {
      const wcagLevelsElement = document.getElementById('footer-wcag-levels');
      if (!wcagLevelsElement) return;

      const thresholds: Record<string, number> = {
        A: 3,
        AA: 4.5,
        AAA: 7
      };

      const boxes = wcagLevelsElement.querySelectorAll('[data-wcag-level]');
      boxes.forEach((box) => {
        const level = (box as HTMLElement).dataset.wcagLevel || '';
        const required = thresholds[level] ?? 99;
        const passed = ratio >= required;
        (box as HTMLElement).classList.toggle('opacity-100', passed);
        (box as HTMLElement).classList.toggle('opacity-30', !passed);
      });
    }

    function rgbToHex(rgb: string): string {
      const result = rgb.match(/\d+/g);
      if (!result || result.length < 3) return '#000000';

      const r = parseInt(result[0]);
      const g = parseInt(result[1]);
      const b = parseInt(result[2]);

      return '#' + [r, g, b].map(x => {
        const hex = x.toString(16);
        return hex.length === 1 ? '0' + hex : hex;
      }).join('');
    }

    function formatContrastDisplayValue(ratio: number): string {
      const left = ratio.toFixed(1).padStart(4, '0'); // e.g. 04.5
      const right = '1';
      return `${left}:${right}`;
    }

    function setContrastDisplayValue(value: string): void {
      (window as any).__footerContrastValue = value;
      window.dispatchEvent(new CustomEvent('footer-contrast-change', {
        detail: { value, targetId: 'footer-contrast-display' }
      }));
    }

    function calculateAndDisplayFooterContrast(): void {

      try {
        const rootStyles = getComputedStyle(document.documentElement);
        const colorMain = rootStyles.getPropertyValue('--color-main').trim();
        const colorSecondary = rootStyles.getPropertyValue('--color-secondary').trim();

        debugLogger.log('Footer contrast calculation:', { colorMain, colorSecondary });

        let mainColor = colorMain;
        let secondaryColor = colorSecondary;

        if (!mainColor || !secondaryColor) {
          const isDarkMode = document.documentElement.getAttribute('data-theme') === 'dark';
          mainColor = isDarkMode ? '#ffffff' : '#000000';
          secondaryColor = isDarkMode ? '#000000' : '#ffffff';
        }

        if (!mainColor.startsWith('#')) {
          mainColor = mainColor.startsWith('rgb') ? rgbToHex(mainColor) : '#000000';
        }
        if (!secondaryColor.startsWith('#')) {
          secondaryColor = secondaryColor.startsWith('rgb') ? rgbToHex(secondaryColor) : '#ffffff';
        }

        const contrastRatio = getContrastRatio(mainColor, secondaryColor);

        const wcagLevelsElement = document.getElementById('footer-wcag-levels');
        setContrastDisplayValue(formatContrastDisplayValue(contrastRatio));
        
        if (wcagLevelsElement) {
          // Get language from document
          const lang = document.documentElement.getAttribute('lang') || 'es';

          const shouldBuild =
            wcagLevelsElement.children.length === 0 ||
            wcagLevelsElement.getAttribute('data-lang') !== lang;

          // Define levels and their requirements
          const levels = [
            { name: 'A', requirement: 3, passed: contrastRatio >= 3 },
            { name: 'AA', requirement: 4.5, passed: contrastRatio >= 4.5 },
            { name: 'AAA', requirement: 7, passed: contrastRatio >= 7 }
          ];

          if (shouldBuild) {
            wcagLevelsElement.innerHTML = '';
            wcagLevelsElement.setAttribute('data-lang', lang);

            levels.forEach(level => {
            const levelBox = document.createElement('div');
            levelBox.dataset.wcagLevel = level.name;
            levelBox.className = `bg-secondary text-main px-2 py-1 text-xs font-mono font-bold min-h-[28px] flex items-center gap-1.5 border border-main ${level.passed ? 'opacity-100' : 'opacity-30'} cursor-help relative`;
            
            const titleKey = `footer.wcag.${level.name.toLowerCase()}.title`;
            const descKey = `footer.wcag.${level.name.toLowerCase()}.desc`;
            
            // Get tooltip text from translations
            let tooltipTitle = '';
            let tooltipDesc = '';
            if (lang === 'en') {
              const enTranslations: Record<string, string> = {
                'footer.wcag.a.title': 'WCAG A - Minimum',
                'footer.wcag.a.desc': '3:1 contrast for graphics, icons and UI components',
                'footer.wcag.aa.title': 'WCAG AA - Standard',
                'footer.wcag.aa.desc': '4.5:1 contrast for normal text and legal compliance',
                'footer.wcag.aaa.title': 'WCAG AAA - Enhanced',
                'footer.wcag.aaa.desc': '7:1 contrast for maximum accessibility and readability'
              };
              tooltipTitle = enTranslations[titleKey] || '';
              tooltipDesc = enTranslations[descKey] || '';
            } else if (lang === 'no') {
              const noTranslations: Record<string, string> = {
                'footer.wcag.a.title': 'WCAG A - Minimum',
                'footer.wcag.a.desc': '3:1 kontrast for grafikk, ikoner og UI-komponenter',
                'footer.wcag.aa.title': 'WCAG AA - Standard',
                'footer.wcag.aa.desc': '4.5:1 kontrast for normal tekst og lovmessig overholdelse',
                'footer.wcag.aaa.title': 'WCAG AAA - Forbedret',
                'footer.wcag.aaa.desc': '7:1 kontrast for maksimal tilgjengelighet og lesbarhet'
              };
              tooltipTitle = noTranslations[titleKey] || '';
              tooltipDesc = noTranslations[descKey] || '';
            } else {
              const esTranslations: Record<string, string> = {
                'footer.wcag.a.title': 'WCAG A - Mínimo',
                'footer.wcag.a.desc': 'Contraste 3:1 para elementos gráficos, iconos y componentes de interfaz',
                'footer.wcag.aa.title': 'WCAG AA - Estándar',
                'footer.wcag.aa.desc': 'Contraste 4.5:1 para texto normal y cumplimiento legal',
                'footer.wcag.aaa.title': 'WCAG AAA - Superior',
                'footer.wcag.aaa.desc': 'Contraste 7:1 para máxima accesibilidad y legibilidad'
              };
              tooltipTitle = esTranslations[titleKey] || '';
              tooltipDesc = esTranslations[descKey] || '';
            }
            
            // Create icon element
            const iconContainer = document.createElement('span');
            iconContainer.className = 'inline-flex w-3 h-3 items-center justify-center';
            
            if (level.passed) {
              // Use circle-check-big icon for passed levels
              iconContainer.innerHTML = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>';
            } else {
              // Use ban icon for failed levels
              iconContainer.innerHTML = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.929 4.929 19.07 19.071"/><circle cx="12" cy="12" r="10"/></svg>';
            }
            
            const label = document.createElement('span');
            label.textContent = level.name;
            
            // Create tooltip element
            const tooltip = document.createElement('div');
            tooltip.className = 'fixed bg-secondary text-main border-2 border-main shadow-[4px_4px_0px_var(--color-main)] z-[9999] pointer-events-none';
            tooltip.style.width = '280px';
            tooltip.style.maxWidth = 'min(92vw, 320px)';
            tooltip.style.opacity = '0';
            tooltip.style.visibility = 'hidden';
            
            // Create tooltip content
            const tooltipContent = document.createElement('div');
            tooltipContent.className = 'p-4 flex flex-col gap-3';
            
            // Header with title and icon
            const header = document.createElement('div');
            header.className = 'flex items-start justify-between gap-3';
            
            const title = document.createElement('div');
            title.className = 'text-sm font-mono font-bold leading-tight';
            title.textContent = tooltipTitle;
            
            // Status icon
            const statusIcon = document.createElement('div');
            statusIcon.className = 'w-5 h-5 flex items-center justify-center';
            if (level.passed) {
              statusIcon.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>';
            } else {
              statusIcon.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.929 4.929 19.07 19.071"/><circle cx="12" cy="12" r="10"/></svg>';
            }
            
            header.appendChild(title);
            header.appendChild(statusIcon);

            const requirement = document.createElement('div');
            requirement.className = 'inline-flex w-fit items-center border border-main px-2 py-1 text-[11px] font-mono font-bold leading-none';
            requirement.textContent = `${level.requirement}:1 minimum`;
            
            // Description
            const desc = document.createElement('div');
            desc.className = 'text-xs font-mono leading-relaxed text-left';
            desc.textContent = tooltipDesc;
            
            tooltipContent.appendChild(header);
            tooltipContent.appendChild(requirement);
            tooltipContent.appendChild(desc);
            tooltip.appendChild(tooltipContent);
            
            levelBox.appendChild(iconContainer);
            levelBox.appendChild(label);
            
            // Add hover events
            levelBox.addEventListener('mouseenter', () => {
              // Position tooltip relative to the levelBox
              const rect = levelBox.getBoundingClientRect();
              tooltip.style.left = `${rect.left + rect.width / 2}px`;
              tooltip.style.top = `${rect.top - 8}px`;
              tooltip.style.transform = 'translate(-50%, -100%)';
              tooltip.style.opacity = '1';
              tooltip.style.visibility = 'visible';
              
              // Append to body to avoid opacity inheritance
              document.body.appendChild(tooltip);
            });
            
            levelBox.addEventListener('mouseleave', () => {
              tooltip.style.opacity = '0';
              tooltip.style.visibility = 'hidden';
              // Remove from body
              if (tooltip.parentNode) {
                tooltip.parentNode.removeChild(tooltip);
              }
            });
            
            wcagLevelsElement.appendChild(levelBox);
          });
        }

          updateWcagLevelsUI(contrastRatio);
        }

      } catch (error) {
        debugLogger.warn('Failed to calculate contrast ratio:', error);
        setContrastDisplayValue('00.0:0');
      }
    }

    // Motion preference management
    function updateMotionPreference(): void {
      const motionStatus = document.getElementById('motion-status');
      if (!motionStatus) {
        debugLogger.warn('Motion status element not found');
        return;
      }

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const lang = document.documentElement.getAttribute('lang') || 'es';

      // Get translations from the global translations object
      const translations = (window as any).__ASTRO_I18N__;
      let statusText = '';

      debugLogger.log('Motion preference check:', {
        prefersReducedMotion,
        lang,
        translations,
        hasTranslations: !!translations?.[lang]
      });

      if (translations && translations[lang]) {
        statusText = prefersReducedMotion ?
          translations[lang]['footer.motion.activated'] || 'Motion: reduced' :
          translations[lang]['footer.motion.deactivated'] || 'Motion: enabled';
      } else {
        // Fallback
        const statusTexts = {
          'es': prefersReducedMotion ? 'Activado' : 'Desactivado',
          'en': prefersReducedMotion ? 'Activated' : 'Deactivated',
          'no': prefersReducedMotion ? 'Aktivert' : 'Deaktivert'
        };
        statusText = statusTexts[lang as keyof typeof statusTexts] || statusTexts.es;
      }

      motionStatus.textContent = statusText;

      const baseClasses = 'scramble-text inline-flex items-center px-2 py-1 text-xs font-mono font-bold ml-2 border';
      motionStatus.className = prefersReducedMotion
        ? `${baseClasses} border-main bg-secondary text-main`
        : `${baseClasses} border-secondary bg-main text-secondary`;

      const tooltipTexts = {
        es: prefersReducedMotion ? 'Las animaciones están reducidas' : 'Las animaciones están habilitadas',
        en: prefersReducedMotion ? 'Animations are reduced' : 'Animations are enabled',
        no: prefersReducedMotion ? 'Animasjoner er redusert' : 'Animasjoner er aktivert'
      };
      const tooltip = tooltipTexts[lang as keyof typeof tooltipTexts] || tooltipTexts.es;
      motionStatus.setAttribute('title', tooltip);
      motionStatus.setAttribute('aria-label', `${statusText}. ${tooltip}`);

      debugLogger.log('Motion status updated:', {
        statusText,
        state: prefersReducedMotion ? 'activated-filled' : 'deactivated-outlined'
      });
    }

    // Scramble a single text node (span.scramble-part)
    const scrambleTimers = new WeakMap<HTMLElement, number>();

    function scrambleText(element: HTMLElement, originalText: string, duration: number = 450): void {
      const chars = 'abcdefghijkstuvwxyzABCDEFGHWXYZ01234!@#$%&*:.?';
      let i = 0;
      const stepMs = 50;
      const maxSteps = Math.ceil(duration / stepMs);

      // Avoid overlapping timers that can leave text corrupted
      const existing = scrambleTimers.get(element);
      if (existing) {
        clearInterval(existing);
        scrambleTimers.delete(element);
      }

      const timer = window.setInterval(() => {
        const progress = Math.min(i / maxSteps, 1);
        const reveal = Math.floor(progress * originalText.length);

        element.textContent = originalText
          .split('')
          .map((_ch: string, idx: number) => (idx < reveal ? originalText[idx] : chars[Math.floor(Math.random() * chars.length)]))
          .join('');

        i++;
        if (progress >= 1) {
          clearInterval(timer);
          scrambleTimers.delete(element);
          element.textContent = originalText; // ensure final stable text
        }
      }, stepMs);

      scrambleTimers.set(element, timer);
    }

    // Scramble only the .scramble-part children; never touch icons/components
    function scrambleContainer(container: HTMLElement): void {
      const parts = container.querySelectorAll('.scramble-part');
      if (parts.length) {
        parts.forEach((part: Element, idx: number) => {
          const el = part as HTMLElement;

          // Persist real source text once; never read from transient scrambled text
          if (!el.dataset.originalText) {
            el.dataset.originalText = (el.textContent || '').trim();
          }

          const txt = el.dataset.originalText || '';
          const delay = idx * 120;
          if (!txt.trim()) return;
          setTimeout(() => scrambleText(el, txt), delay);
        });
      } else {
        // fallback: if no .scramble-part, scramble the element text safely
        if (!container.dataset.originalText) {
          container.dataset.originalText = (container.dataset.text || container.textContent || '').trim();
        }

        const txt = container.dataset.originalText || '';
        if (!txt.trim()) return;
        // Only scramble if the element has no child elements (avoid nuking icons)
        if (container.children.length === 0) {
          scrambleText(container, txt);
        }
      }
    }

    // Lazy-init footer utilities to avoid competing with above-the-fold rendering
    let contrastRaf: number | null = null;
    let footerUtilitiesReady = false;

    const scheduleContrastUpdate = () => {
      if (!footerUtilitiesReady) return;
      if (contrastRaf !== null) {
        cancelAnimationFrame(contrastRaf);
      }
      contrastRaf = requestAnimationFrame(() => {
        contrastRaf = null;
        calculateAndDisplayFooterContrast();
      });
    };

    const initFooterUtilities = () => {
      if (footerUtilitiesReady) return;
      footerUtilitiesReady = true;

      calculateAndDisplayFooterContrast();
      updateMotionPreference();

      const observer = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          if (
            mutation.type === 'attributes' &&
            (mutation.attributeName === 'data-theme' || mutation.attributeName === 'class')
          ) {
            scheduleContrastUpdate();
            break;
          }
        }
      });

      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme', 'class']
      });
      cleanupFns.push(() => observer.disconnect());

      const motionMediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      motionMediaQuery.addEventListener('change', updateMotionPreference);
      cleanupFns.push(() => motionMediaQuery.removeEventListener('change', updateMotionPreference));

      // Live contrast updates for dynamic theme (throttled)
      let lastDynamicContrastUpdate = 0;
      const onDynamicThemeContrast = (event: Event) => {
        const now = performance.now();
        if (now - lastDynamicContrastUpdate < 220) return;
        lastDynamicContrastUpdate = now;

        const ratio = (event as CustomEvent).detail?.ratio;
        if (typeof ratio !== 'number' || Number.isNaN(ratio)) return;

        setContrastDisplayValue(formatContrastDisplayValue(ratio));

        updateWcagLevelsUI(ratio);
      };

      window.addEventListener('dynamic-theme-contrast', onDynamicThemeContrast);
      cleanupFns.push(() => window.removeEventListener('dynamic-theme-contrast', onDynamicThemeContrast));
    };

    // Intersection Observer: run once when footer enters viewport
    const runFooterScramble = (footerEl: Element) => {
      if (footerAnimated) return;
      footerAnimated = true;

      initFooterUtilities();
      window.dispatchEvent(new CustomEvent('footer-scramble-start'));

      const elements = footerEl.querySelectorAll('.scramble-text');
      elements.forEach((el: Element, idx: number) => {
        setTimeout(() => scrambleContainer(el as HTMLElement), idx * 28);
      });
    };

    const scrambleObserver = new IntersectionObserver((entries: IntersectionObserverEntry[]) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          // Small delay so user can actually see start of effect when footer enters view
          setTimeout(() => runFooterScramble(entry.target), 80);
          scrambleObserver.disconnect();
          break;
        }
      }
    }, { threshold: 0.05, rootMargin: '100px 0px' });

    const footer = document.getElementById('site-footer');
    if (footer) {
      // Run scramble only once, when footer enters viewport
      scrambleObserver.observe(footer);

      // Idle fallback: initialize metrics lazily even if footer is never reached
      const idleId = 'requestIdleCallback' in window
        ? (window as any).requestIdleCallback(() => initFooterUtilities(), { timeout: 2500 })
        : window.setTimeout(() => initFooterUtilities(), 1800);

      cleanupFns.push(() => {
        if ('cancelIdleCallback' in window) {
          (window as any).cancelIdleCallback?.(idleId);
        } else {
          clearTimeout(idleId as number);
        }
      });
    }
    cleanupFns.push(() => {
      scrambleObserver.disconnect();
      if (contrastRaf !== null) cancelAnimationFrame(contrastRaf);
    });

    footerCleanup = () => {
      cleanupFns.forEach((fn) => fn());
    };
  }

  // Initialize on first load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFooter, { once: true });
  } else {
    initFooter();
  }

  // Re-initialize on page transitions (bind once)
  const footerWindow = window as Window & { __footerPageLoadBound?: boolean };
  if (!footerWindow.__footerPageLoadBound) {
    document.addEventListener('astro:page-load', initFooter);
    footerWindow.__footerPageLoadBound = true;
  }
</script>

