---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/Button.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import ContentPage from '@/components/ContentPage.astro';
import ThemeCard from '@/components/ThemeCard.astro';
import DropdownButton from '@/components/ui/DropdownButton.astro';
import DropdownContent from '@/components/ui/DropdownContent.astro';
import Kbd from '@/components/ui/Kbd.astro';
import themesData from '@/data/themes.json';
import { getTranslations } from '@/i18n/utils';
import { defaultLang, type Language } from '@/i18n/ui';
import WaveDivider from '@/components/WaveDivider.astro';
import SevenSegmentDisplay from '@/components/ui/seven-segment/SevenSegmentDisplay.astro';
import LiveClockDisplay from '@/components/ui/seven-segment/LiveClockDisplay.astro';
import FooterNavigationList from '@/components/FooterNavigationList.astro';
import { Command, Option, ArrowUpToLine, CornerDownLeft, ArrowRight } from 'lucide-react';

interface Props {
    lang?: Language;
}

const { lang = defaultLang } = Astro.props;
const t = getTranslations(lang);

// Localized heading pangram preview aligned to each language
const headingPangram =
    lang === 'es'
        ? '“El pequeño zorro bajó feliz y juguetón al río mientras cantaba.”'
        : lang === 'no'
          ? '“Den lille reven gikk glad og lekende ned til elva mens han sang.”'
          : lang === 'ja'
            ? '「小さな狐は歌いながら、楽しそうに川へ降りていった。」'
            : '“The quick little fox joyfully went down to the river singing a warm tune.”';

const ssDisplayLabel =
    lang === 'es'
        ? 'SS DISPLAY · Space Grotesk'
        : lang === 'no'
          ? 'SS DISPLAY · Space Grotesk'
          : 'SS DISPLAY · Space Grotesk';

const sevenSegmentCopy =
    lang === 'es'
        ? {
              heading: 'Pantalla de siete segmentos',
              intro: 'Sistema de dígitos segmentados para lecturas numéricas. Se usa en estados y métricas para mantener legibilidad y ritmo visual.',
              samples: 'Muestras'
          }
        : lang === 'no'
          ? {
                heading: 'Seven Segment-display',
                intro: 'Segmentert tallsystem for numeriske avlesninger. Brukes i status og målinger for tydelig lesbarhet og visuell rytme.',
                samples: 'Eksempler'
            }
          : lang === 'ja'
            ? {
                  heading: '7セグメント表示',
                  intro: '数値表示のためのセグメント式ディスプレイ。状態表示やメトリクスで可読性と視覚リズムを保ちます。',
                  samples: 'サンプル'
              }
            : {
                heading: 'Seven Segment Display',
                intro: 'Segment-based digit system for numeric readouts. Used in status and metrics to keep readability and visual rhythm.',
                samples: 'Samples'
            };

const keyboardSectionHeading =
    lang === 'es' ? 'Teclas de teclado' : lang === 'no' ? 'Tastaturtaster' : lang === 'ja' ? 'キーボードキー' : 'Keyboard Keys';

const footerNavigationHeading =
    lang === 'es' ? 'Navegación de footer' : lang === 'no' ? 'Footer-navigasjon' : lang === 'ja' ? 'フッターナビゲーション' : 'Footer Navigation';

const sectionIntro = {
    structure:
        lang === 'es'
            ? 'Ordenado por importancia: color, temas, tipografía y luego componentes de interacción.'
            : lang === 'no'
              ? 'Sortert etter viktighet: farger, temaer, typografi og deretter interaktive komponenter.'
              : lang === 'ja'
                ? '重要度順に整理しています。色、テーマ、タイポグラフィ、そしてインタラクション要素。'
                : 'Ordered by importance: color, themes, typography, and then interactive components.',
    buttons:
        lang === 'es'
            ? 'Base de interacción primaria. Aquí se concentran estados, jerarquía visual y variantes de acción.'
            : lang === 'no'
              ? 'Grunnlaget for primær interaksjon. Her vises tilstander, visuelt hierarki og handlingsvarianter.'
              : lang === 'ja'
                ? '主要なインタラクション要素。状態、視覚的階層、アクションのバリエーションをまとめています。'
                : 'Core interaction building block. This section shows states, visual hierarchy, and action variants.',
    cards:
        lang === 'es'
            ? 'Contenedor de contenido resumido. Prioriza lectura rápida, enlace claro y estructura consistente.'
            : lang === 'no'
              ? 'Kort for komprimert innhold. Prioriterer rask lesing, tydelig lenke og konsistent struktur.'
              : lang === 'ja'
                ? '要約情報のためのカード。素早い読取、明確なリンク、一貫した構造を重視します。'
                : 'Compact content container focused on quick scanning, clear linking, and consistent structure.',
    footerNav:
        lang === 'es'
            ? 'Patrón de navegación secundaria para cierre de página y acceso a secciones clave.'
            : lang === 'no'
              ? 'Sekundært navigasjonsmønster for sidens avslutning og tilgang til viktige seksjoner.'
              : lang === 'ja'
                ? 'ページ末尾で主要セクションへ素早く移動するための補助ナビゲーションです。'
                : 'Secondary navigation pattern used at page end for quick access to key sections.',
    keyboard:
        lang === 'es'
            ? 'Representación visual de atajos y teclas del sistema para documentación y ayuda contextual.'
            : lang === 'no'
              ? 'Visuell representasjon av hurtigtaster for dokumentasjon og konteksthjelp.'
              : lang === 'ja'
                ? 'ショートカットやシステムキーを視覚的に示し、ドキュメントや文脈ヘルプに活用します。'
                : 'Visual representation of shortcuts and system keys for documentation and contextual help.',
    visual:
        lang === 'es'
            ? 'Recursos decorativos de menor prioridad que refuerzan identidad sin competir con el contenido.'
            : lang === 'no'
              ? 'Dekorative elementer med lavere prioritet som styrker identitet uten å forstyrre innholdet.'
              : lang === 'ja'
                ? '装飾要素は優先度を低く保ち、内容を邪魔せずにサイトの個性を補強します。'
                : 'Lower-priority decorative resources that reinforce identity without competing with content.'
};

const opacities = [100, 80, 60, 40, 20, 10] as const;
const mainBgClasses: Record<(typeof opacities)[number], string> = {
    100: 'bg-main',
    80: 'bg-main/80',
    60: 'bg-main/60',
    40: 'bg-main/40',
    20: 'bg-main/20',
    10: 'bg-main/10'
};
const secondaryBgClasses: Record<(typeof opacities)[number], string> = {
    100: 'bg-secondary',
    80: 'bg-secondary/80',
    60: 'bg-secondary/60',
    40: 'bg-secondary/40',
    20: 'bg-secondary/20',
    10: 'bg-secondary/10'
};
---

<Layout title={`${t('designSystem.title')} - Showcase`} description={t('designSystem.intro.description')} lang={lang}>
    <ContentPage contentId="main-content" lang={lang} useClerkTOC={true} contentClassName="space-y-12 md:space-y-20">
        <!-- Hero Header -->
        <section id="introduccion" class="relative space-y-6 md:space-y-8">
            <div class="mt-6 md:mt-8">
                <h1 id="inicio" class="h1">{t('designSystem.intro.heading')}</h1>
            </div>
            <div class="space-y-6 md:space-y-8 max-w-3xl leading-relaxed text-balance">
                {lang === 'es' && (
                    <>
                        <p class="text-base md:text-lg">Este sistema nace desde una restricción clara: dos colores, bordes definidos y tipografía con jerarquía estable. Al reducir decisiones visuales, el contenido toma protagonismo y cada página mantiene el mismo lenguaje.</p>
                        <p class="text-base md:text-lg">La accesibilidad está integrada desde el diseño: contraste legible, foco visible, estructura semántica y navegación simple. Si quieres revisar criterios y alcance en detalle, puedes leer la <a href="/declaracion-de-accesibilidad" class="underline underline-offset-2 decoration-[1.5px] hover:opacity-80">Declaración de Accesibilidad</a>.</p>
                    </>
                )}
                {lang === 'en' && (
                    <>
                        <p class="text-base md:text-lg">This system is built from a clear constraint: two colors, sharp borders, and typography with a stable hierarchy. By reducing visual choices, content takes priority and every page keeps the same language.</p>
                        <p class="text-base md:text-lg">Accessibility is built into the design: readable contrast, visible focus, semantic structure, and straightforward navigation. If you want to review criteria and scope in detail, read the <a href="/en/accessibility-statement" class="underline underline-offset-2 decoration-[1.5px] hover:opacity-80">Accessibility Statement</a>.</p>
                    </>
                )}
                {lang === 'no' && (
                    <>
                        <p class="text-base md:text-lg">Dette systemet bygger på en tydelig begrensning: to farger, skarpe kanter og typografi med stabilt hierarki. Når de visuelle valgene reduseres, får innholdet mer plass, og alle sider følger samme språk.</p>
                        <p class="text-base md:text-lg">Tilgjengelighet er bygget inn i designet: lesbar kontrast, synlig fokus, semantisk struktur og enkel navigasjon. Hvis du vil se kriterier og omfang i detalj, kan du lese <a href="/no/tilgjengelighetserklaering" class="underline underline-offset-2 decoration-[1.5px] hover:opacity-80">Tilgjengelighetserklæringen</a>.</p>
                    </>
                )}
                {lang === 'ja' && (
                    <>
                        <p class="text-base md:text-lg">このシステムは明確な制約から生まれました。2色のみ、鋭い境界線、安定したタイポグラフィ階層です。視覚的な選択肢を絞ることで、コンテンツが主役になります。</p>
                        <p class="text-base md:text-lg">アクセシビリティは設計段階から組み込まれています。十分なコントラスト、見えるフォーカス、意味論的な構造、シンプルなナビゲーション。詳細は <a href="/ja/accessibility-statement" class="underline underline-offset-2 decoration-[1.5px] hover:opacity-80">アクセシビリティ方針</a>をご覧ください。</p>
                    </>
                )}
            </div>
        </section>

        <!-- Color System -->
        <section id="colores" class="space-y-6 md:space-y-8">
            <h2 id="colores-heading" class="h2">
                {t('designSystem.colors.heading')}
            </h2>

            <p class="md:text-lg leading-relaxed text-main max-w-3xl">
                {t('designSystem.colors.intro')}
            </p>

            <div class="space-y-4 md:space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 border">
                    <div class="bg-secondary p-4 md:p-6 space-y-2 md:space-y-3 border-r">
                        <div class="w-full bg-main flex flex-col justify-end items-end aspect-5/3">
                            <p class="font-mono p-2 w-fit leading-tight text-secondary">--color-main</p>
                        </div>

                        <p class="text-main">
                            {t('designSystem.colors.main.description')}
                        </p>
                    </div>
                    <div class="bg-main p-4 md:p-6 space-y-2 md:space-y-3 ring ring-inset ring-secondary">
                        <div class="w-full bg-secondary flex flex-col justify-end items-end aspect-5/3">
                            <p class="font-mono p-2 w-fit leading-tight text-main">--color-secondary</p>
                        </div>

                        <p class="text-secondary">
                            {t('designSystem.colors.secondary.description')}
                        </p>
                    </div>
                </div>
            </div>

            <!-- Opacity showcase -->
            <div>
                <h3 class="h3">{t('designSystem.colors.opacity.title')}</h3>
                <p class="text-body max-w-3xl text-main/80">{t('designSystem.colors.opacity.intro')}</p>
                <p class="text-body-sm text-main/70">{t('designSystem.colors.opacity.helper')}</p>

                <!-- Main over Secondary (title above, single container with contrast background) -->
                <div class="space-y-3 md:space-y-4 mt-4">
                    <h4 class="h4">{t('designSystem.colors.opacity.mainOverSecondary')}</h4>
                    <div class="w-full border border-main bg-secondary">
                        <div class="p-2">
                            <div class="flex w-full">
                                {
                                    opacities.map((o) => (
                                        <div class="relative w-full h-28 md:h-52 overflow-hidden">
                                            <div class={`absolute inset-0 ${mainBgClasses[o]}`} />
                                            <span class="absolute top-1 left-1 font-mono text-[10px] md:text-xs px-1.5 py-0.5 bg-secondary text-main border border-main">
                                                main/{o}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Secondary over Main (title above, single container with contrast background) -->
                <div class="space-y-3 md:space-y-4 mt-6">
                    <h4 class="h4">{t('designSystem.colors.opacity.secondaryOverMain')}</h4>
                    <div class="w-full border border-main bg-main">
                        <div class="p-2">
                            <div class="flex w-full">
                                {
                                    opacities.map((o) => (
                                        <div class="relative w-full h-28 md:h-52 overflow-hidden">
                                            <div class={`absolute inset-0 ${secondaryBgClasses[o]}`} />
                                            <span class="absolute top-1 left-1 font-mono text-[10px] md:text-xs px-1.5 py-0.5 bg-main text-secondary border border-secondary">
                                                secondary/{o}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </section>

        <!-- Available Themes -->
        <section id="temas" class="space-y-6 md:space-y-8">
            <h2 id="temas-heading" class="h2">
                {t('designSystem.colors.themes.title')}
            </h2>

            <p class="md:text-lg leading-relaxed text-main max-w-4xl">
                <span set:html={t('designSystem.colors.themes.intro')} />
            </p>

            <!-- Themes container styled like buttons box -->
            <div class="bg-main/10 p-0 space-y-0">
                <!-- Tile header (full width, filled in main) -->
                <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
                    {t('designSystem.colors.themes.available')}
                </div>
                <!-- Tile content -->
                <div class="flex items-center justify-center p-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="default-themes">
                        {
                            themesData.company.map((theme) => (
                                <div class="company-theme hidden" data-theme-id={theme.id}>
                                    <ThemeCard theme={theme} lang={lang} isActive={false} />
                                </div>
                            ))
                        }
                        {themesData.default.map((theme) => <ThemeCard theme={theme} lang={lang} isActive={false} />)}

                        {
                            themesData.special.map((theme) => (
                                <div class="special-theme hidden" data-theme-id={theme.id}>
                                    <ThemeCard theme={theme} lang={lang} isActive={false} />
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <script>
                const initDesignSystemThemeCards = () => {

                    function getMode() {
                        const savedMode = localStorage.getItem('theme-mode') || 'system';
                        if (savedMode === 'system') {
                            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                        }
                        return savedMode;
                    }

                    function updateActiveChecks() {
                        const activeId = localStorage.getItem('theme-id') || window.__THEME_ID__;
                        const cards = document.querySelectorAll('.theme-card');
                        cards.forEach((card) => {
                            const id = card.getAttribute('data-theme-id');
                            const checked = card.querySelector('.theme-checked');
                            const unchecked = card.querySelector('.theme-unchecked');
                            if (!checked || !unchecked) return;
                            if (id === activeId) {
                                checked.classList.remove('hidden');
                                unchecked.classList.add('hidden');
                                checked.classList.remove('theme-dot-pop');
                                void checked.offsetWidth;
                                checked.classList.add('theme-dot-pop');
                            } else {
                                checked.classList.add('hidden');
                                unchecked.classList.remove('hidden');
                                checked.classList.remove('theme-dot-pop');
                            }
                        });
                    }

                    function applyVisibilityState() {
                        const activeCompany = sessionStorage.getItem('active-company-theme');
                        const companyWrappers = document.querySelectorAll('.company-theme');
                        companyWrappers.forEach((el) => {
                            const id = el.getAttribute('data-theme-id');
                            if (activeCompany && id === activeCompany) el.classList.remove('hidden');
                            else el.classList.add('hidden');
                        });

                        const specialUnlocked = localStorage.getItem('special-themes-visible') === 'true';
                        const specialWrappers = document.querySelectorAll('.special-theme');
                        specialWrappers.forEach((el) => {
                            if (specialUnlocked) el.classList.remove('hidden');
                            else el.classList.add('hidden');
                        });
                    }

                    function wireApplyButtons() {
                        const buttons = document.querySelectorAll('.apply-theme-btn');
                        buttons.forEach((btn) => {
                            if (btn.hasAttribute('data-check-bound')) return;
                            btn.setAttribute('data-check-bound', 'true');
                            btn.addEventListener('click', async (e) => {
                                e.preventDefault();
                                const themeId = btn.getAttribute('data-theme-id');
                                if (!themeId) return;
                                const mode = getMode();
                                const isDark = mode === 'dark';
                                const mod = await import('../data/themes.js');
                                mod.applyTheme(themeId, isDark);
                                updateActiveChecks();
                            });
                        });
                    }

                    const handleVisibilityEvent = () => {
                        applyVisibilityState();
                        wireApplyButtons();
                        updateActiveChecks();
                    };

                    handleVisibilityEvent();

                    window.addEventListener('themes-unlocked', handleVisibilityEvent);
                    window.addEventListener('themes-locked', handleVisibilityEvent);
                    window.addEventListener('theme-unlocked', handleVisibilityEvent);
                    window.addEventListener('theme-changed', handleVisibilityEvent);
                    window.addEventListener('theme-control-ready', handleVisibilityEvent);
                    window.addEventListener('company-theme-activated', handleVisibilityEvent);
                    window.addEventListener('company-theme-deactivated', handleVisibilityEvent);

                    window.addEventListener('storage', (e) => {
                        if (e.key === 'special-themes-visible' || e.key === 'theme-id') {
                            handleVisibilityEvent();
                        }
                    });
                };

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initDesignSystemThemeCards, { once: true });
                } else {
                    initDesignSystemThemeCards();
                }

                document.addEventListener('astro:page-load', initDesignSystemThemeCards);
            </script>
        </section>


        <!-- Typography Section -->
        <section id="tipografia" class="space-y-2 md:space-y-4">
            <h2 id="tipografia-heading" class="h2">
                {t('designSystem.typography.heading')}
            </h2>

            <p class="md:text-lg leading-relaxed text-main max-w-3xl">
                {t('designSystem.typography.intro')}
            </p>

            <div class="space-y-2 md:space-y-4">
                <!-- Headings -->
                <div class="bg-main/10">
                    <div class="">
                              <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
           
                         {t('designSystem.typography.labels.headings')}
                    </div>
              
                        <div class="flex-1 p-6 md:p-8 space-y-3 md:space-y-4">
                            <div>
                                <span class="font-mono text-secondary bg-main/80 px-2">{ssDisplayLabel}</span>
                                <p class="text-4xl md:text-5xl font-bold leading-tight !mt-0 !mb-10" style="font-family: var(--font-display);">{headingPangram}</p>
                            </div>
                            <div>
                                <span class="font-mono text-secondary bg-main/80 px-2">{t('designSystem.typography.labels.h1')}</span>
                                <p class="h1 !mt-0 !mb-10">{headingPangram}</p>
                            </div>
                            <div>
                                <span class="font-mono text-secondary bg-main/80 px-2">{t('designSystem.typography.labels.h2')}</span>
                                <p class="h2 !mt-0 !mb-10">{headingPangram}</p>
                            </div>
                            <div>
                                <span class="font-mono text-secondary bg-main/80 px-2">{t('designSystem.typography.labels.h3')}</span>
                                <p class="h3 !mt-0 !mb-10">{headingPangram}</p>
                            </div>
                            <div>
                                <span class="font-mono text-secondary bg-main/80 px-2">{t('designSystem.typography.labels.h4toh6')}</span>
                                <p class="h4 !mt-0 !mb-10">{headingPangram}</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Body Sans -->
                <div class="bg-main/10">
                    <div class=" ">
                         <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
           
                            
                                {t('designSystem.typography.labels.body')}
                             
                        </div>
                        <div class="flex-1 p-6 md:p-8 space-y-3 md:space-y-4">
                            <div>
                                <span class="font-mono text-secondary bg-main/80 px-2">{t('designSystem.typography.labels.bodyBase')}</span>
                                <p class="text-body !mt-0 !mb-10">{t('designSystem.typography.samples.sans')}</p>
                            </div>
                            <div>
                                <span class="font-mono text-secondary bg-main/80 px-2">{t('designSystem.typography.labels.bodySm')}</span>
                                <p class="text-body-sm !mt-0 !mb-10">{t('designSystem.typography.samples.sans')}</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Body Mono -->
                <div class="bg-main/10">
                    <div class=" ">
                         <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
           
                           
                                {t('designSystem.typography.labels.mono')}
                       
                        </div>
                        <div class="flex-1 p-6 md:p-8 space-y-3 md:space-y-4">
                            <div>
                                <span class="font-mono text-secondary bg-main/80 px-2">{t('designSystem.typography.labels.monoBase')}</span>
                                <p class="text-body-mono mt-1">{t('designSystem.typography.samples.monoPrimary')}</p>
                            </div>
                            <div>
                                <span class="font-mono text-secondary bg-main/80 px-2">{t('designSystem.typography.labels.monoSm')}</span>
                                <p class="text-body-mono-sm mt-1">{t('designSystem.typography.samples.monoSecondary')}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Buttons Section -->
        <section id="botones" class="space-y-6 md:space-y-8">
            <h2 id="botones-heading" class="h2">
                {t('designSystem.buttons.heading')}
            </h2>
            <p class="text-body text-main/80 max-w-3xl">{sectionIntro.buttons}</p>

            <!-- Mesh of components: each in its own box -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                <!-- Default -->
                <div class="bg-main/10 p-0 space-y-0">
                    <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
                        {t('designSystem.buttons.labels.default')}
                    </div>
                    <div class="flex items-center justify-center p-4 aspect-5/2">
                        <Button variant="normal" size="normal">{t('designSystem.buttons.labels.default')}</Button>
                    </div>
                </div>

                <!-- Filled -->
                <div class="bg-main/10 p-0 space-y-0">
                    <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
                        {t('designSystem.buttons.labels.filled')}
                    </div>
                    <div class="flex items-center justify-center p-4 aspect-5/2">
                        <Button variant="normal" size="normal" filled>{t('designSystem.buttons.labels.filled')}</Button>
                    </div>
                </div>

                <!-- Small -->
                <div class="bg-main/10 p-0 space-y-0">
                    <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
                        {t('designSystem.buttons.labels.small')}
                    </div>
                    <div class="flex items-center justify-center p-4 aspect-5/2">
                        <Button variant="normal" size="sm">{t('designSystem.buttons.labels.small')}</Button>
                    </div>
                </div>

