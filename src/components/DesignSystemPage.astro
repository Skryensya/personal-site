        <script>
            // @ts-nocheck
            const initDesignSystemDropdownDemo = () => {
                const label = document.getElementById('ds-dropdown-default-label');
                const optionButtons = Array.from(document.querySelectorAll('#dropdown-menu-ds-dropdown-default [data-ds-option="true"]'));

                if (!label || optionButtons.length === 0) return;

                const syncSelection = (index) => {
                    optionButtons.forEach((btn, i) => {
                        if (i === index) btn.setAttribute('data-selected', 'true');
                        else btn.setAttribute('data-selected', 'false');
                    });

                    const selectedText = optionButtons[index]?.textContent?.trim();
                    if (selectedText) label.textContent = selectedText;
                };

                optionButtons.forEach((btn, index) => {
                    if (btn.hasAttribute('data-ds-option-bound')) return;
                    btn.setAttribute('data-ds-option-bound', 'true');
                    btn.addEventListener('click', () => syncSelection(index));
                });

                window.nextDesignSystemOption = () => {
                    const currentIndex = optionButtons.findIndex((btn) => btn.getAttribute('data-selected') === 'true');
                    const safeIndex = currentIndex >= 0 ? currentIndex : 0;
                    const nextIndex = (safeIndex + 1) % optionButtons.length;
                    syncSelection(nextIndex);
                };
            };

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initDesignSystemDropdownDemo, { once: true });
            } else {
                initDesignSystemDropdownDemo();
            }

            document.addEventListener('astro:page-load', initDesignSystemDropdownDemo);
        </script>

