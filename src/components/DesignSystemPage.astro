                                    <Kbd class="!w-[2.3rem] !min-w-[2.3rem]" data-kbd-live="true" data-kbd-key="shift" data-kbd-code="shiftleft"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="kbd-mod-icon" aria-hidden="true"><path d="M9 13a1 1 0 0 0-1-1H5.061a1 1 0 0 1-.75-1.811l6.836-6.835a1.207 1.207 0 0 1 1.707 0l6.835 6.835a1 1 0 0 1-.75 1.811H16a1 1 0 0 0-1 1v6a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1z"/></svg></Kbd>
                                </div>

                                <div class="flex flex-wrap items-center gap-2 text-main/80">
                                    <Kbd data-konami-key="arrowup" class="!w-[2.2rem] !h-[2.2rem]"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="kbd-arrow-icon" style="transform:rotate(-90deg)" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></Kbd>
                                    <Kbd data-konami-key="arrowdown" class="!w-[2.2rem] !h-[2.2rem]"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="kbd-arrow-icon" style="transform:rotate(90deg)" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></Kbd>
                                    <Kbd data-konami-key="arrowleft" class="!w-[2.2rem] !h-[2.2rem]"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="kbd-arrow-icon" style="transform:rotate(180deg)" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></Kbd>
                                    <Kbd data-konami-key="arrowright" class="!w-[2.2rem] !h-[2.2rem]"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="kbd-arrow-icon" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></Kbd>
                                </div>

                                <div class="flex flex-wrap items-center gap-2 text-main/80">
                                    <Kbd data-konami-key="b" data-kbd-live="true" data-kbd-key="b" data-kbd-code="keyb">B</Kbd>
                                    <Kbd data-konami-key="a" data-kbd-live="true" data-kbd-key="a" data-kbd-code="keya">A</Kbd>
                                    <Kbd class="!w-auto !min-w-[2.25rem] !px-2" data-kbd-live="true" data-kbd-key="enter" data-kbd-code="enter">{kbdText.enter}</Kbd>
                                    <Kbd class="!w-auto !min-w-[2.25rem] !px-2" data-kbd-live="true" data-kbd-key="tab" data-kbd-code="tab">{kbdText.tab}</Kbd>
                                    <Kbd class="!w-auto !min-w-[2.25rem] !px-2" data-kbd-live="true" data-kbd-key="escape" data-kbd-code="escape">{kbdText.esc}</Kbd>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-2.5 border border-transparent lg:pl-2" id="kbd-action-examples">
                            <div class="grid gap-3 sm:grid-cols-2 text-main/80">
                                <div class="space-y-2.5">
                                    <div class="font-mono uppercase tracking-wider text-xs font-bold text-main/70">{t('designSystem.kbd.prevTheme')}</div>
                                    <div class="flex items-center gap-2">
                                        <Kbd class="!w-[2.3rem] !min-w-[2.3rem]" data-kbd-live="true" data-kbd-key="meta|control" data-kbd-code="metaleft|metaright|controlleft|controlright"><span data-kbd-platform-apple class="hidden block w-full text-center leading-none" aria-hidden="true">⌘</span><span data-kbd-platform-win class="hidden block w-full text-center font-mono text-[10px] leading-none uppercase tracking-tight" aria-hidden="true">{kbdText.ctrl}</span></Kbd>
                                        <span class="font-mono text-base leading-none font-bold">+</span>
                                        <Kbd data-kbd-live="true" data-kbd-key="arrowleft" data-kbd-code="arrowleft"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="kbd-arrow-icon" style="transform:rotate(180deg)" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></Kbd>
                                    </div>
                                </div>
                                <div class="space-y-2.5">
                                    <div class="font-mono uppercase tracking-wider text-xs font-bold text-main/70">{t('designSystem.kbd.nextTheme')}</div>
                                    <div class="flex items-center gap-2">
                                        <Kbd class="!w-[2.3rem] !min-w-[2.3rem]" data-kbd-live="true" data-kbd-key="meta|control" data-kbd-code="metaleft|metaright|controlleft|controlright"><span data-kbd-platform-apple class="hidden block w-full text-center leading-none" aria-hidden="true">⌘</span><span data-kbd-platform-win class="hidden block w-full text-center font-mono text-[10px] leading-none uppercase tracking-tight" aria-hidden="true">{kbdText.ctrl}</span></Kbd>
                                        <span class="font-mono text-base leading-none font-bold">+</span>
                                        <Kbd data-kbd-live="true" data-kbd-key="arrowright" data-kbd-code="arrowright"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="kbd-arrow-icon" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></Kbd>
                                    </div>
                                </div>
                            </div>

                            <div class="grid gap-3 sm:grid-cols-2 text-main/80">
                                <div class="space-y-2.5">
                                    <div class="font-mono uppercase tracking-wider text-xs font-bold text-main/70">{t('designSystem.kbd.copy')}</div>
                                    <div class="flex items-center gap-2">
                                        <Kbd class="!w-[2.3rem] !min-w-[2.3rem]" data-kbd-live="true" data-kbd-key="meta|control" data-kbd-code="metaleft|metaright|controlleft|controlright"><span data-kbd-platform-apple class="hidden block w-full text-center leading-none" aria-hidden="true">⌘</span><span data-kbd-platform-win class="hidden block w-full text-center font-mono text-[10px] leading-none uppercase tracking-tight" aria-hidden="true">{kbdText.ctrl}</span></Kbd>
                                        <span class="font-mono text-base leading-none font-bold">+</span>
                                        <Kbd data-kbd-live="true" data-kbd-key="c" data-kbd-code="keyc">C</Kbd>
                                    </div>
                                </div>
                                <div class="space-y-2.5">
                                    <div class="font-mono uppercase tracking-wider text-xs font-bold text-main/70">{t('designSystem.kbd.paste')}</div>
                                    <div class="flex items-center gap-2">
                                        <Kbd class="!w-[2.3rem] !min-w-[2.3rem]" data-kbd-live="true" data-kbd-key="meta|control" data-kbd-code="metaleft|metaright|controlleft|controlright"><span data-kbd-platform-apple class="hidden block w-full text-center leading-none" aria-hidden="true">⌘</span><span data-kbd-platform-win class="hidden block w-full text-center font-mono text-[10px] leading-none uppercase tracking-tight" aria-hidden="true">{kbdText.ctrl}</span></Kbd>
                                        <span class="font-mono text-base leading-none font-bold">+</span>
                                        <Kbd data-kbd-live="true" data-kbd-key="v" data-kbd-code="keyv">V</Kbd>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <script>
            // @ts-nocheck
            const initKonamiKbdDemo = () => {
                const section = document.getElementById('kbd');
                if (!section) return;

                const pieces = Array.from(section.querySelectorAll('[data-konami-key]'));
                if (!pieces.length) return;

                const sequence = ['arrowup', 'arrowup', 'arrowdown', 'arrowdown', 'arrowleft', 'arrowright', 'arrowleft', 'arrowright', 'b', 'a'];
                const liveKeys = Array.from(document.querySelectorAll('#kbd [data-kbd-live]'));
                const allExampleKbd = Array.from(document.querySelectorAll('#kbd .kbd'));

                window.__kbdKonamiSteps = pieces;
                window.__kbdLiveKeys = liveKeys;

                const ua = navigator.userAgent || '';
                const platform = navigator.platform || '';
                const isAppleDevice = /mac|iphone|ipad|ipod/i.test(`${platform} ${ua}`);

                section.querySelectorAll('[data-kbd-platform-apple]').forEach((el) => {
                    el.classList.toggle('hidden', !isAppleDevice);
                });
                section.querySelectorAll('[data-kbd-platform-win]').forEach((el) => {
                    el.classList.toggle('hidden', isAppleDevice);
                });
                section.querySelectorAll('[data-kbd-only-apple]').forEach((el) => {
                    el.classList.toggle('hidden', !isAppleDevice);
                });

                // Platform-specific modifier behavior for examples:
                // macOS/iOS => Command only, others => Control only
                section.querySelectorAll('[data-kbd-key="meta|control"]').forEach((el) => {
                    el.setAttribute('data-kbd-key', isAppleDevice ? 'meta' : 'control');
                    el.setAttribute('data-kbd-code', isAppleDevice ? 'metaleft|metaright' : 'controlleft|controlright');
                });

                let kbdClickAudio = null;
                const getKbdClickAudio = () => {
                    if (kbdClickAudio) return kbdClickAudio;
                    kbdClickAudio = new Audio('/buttonPress.mp3');
                    kbdClickAudio.volume = 0.25;
                    kbdClickAudio.preload = 'none';
                    return kbdClickAudio;
                };

                let lastKbdSoundAt = 0;
                const KBD_SOUND_COOLDOWN_MS = 90;

                const playKbdClickSound = () => {
                    const now = performance.now();
                    if (now - lastKbdSoundAt < KBD_SOUND_COOLDOWN_MS) return;
                    lastKbdSoundAt = now;

                    try {
                        const audio = getKbdClickAudio();
                        audio.currentTime = 0;
                        audio.play().catch(() => {});
                    } catch (_) {}
                };

                const transientPressTimers = new WeakMap();

                const docLangRaw = String(section.getAttribute('data-locale') || document.documentElement.lang || 'es').toLowerCase();
                const docLang = docLangRaw.split('-')[0].split('_')[0];
                const labelsByLang = {
                    es: {
                        arrowup: 'Flecha arriba',
                        arrowdown: 'Flecha abajo',
                        arrowleft: 'Flecha izquierda',
                        arrowright: 'Flecha derecha',
                        escape: 'Escape',
                        enter: 'Intro',
                        tab: 'Tab',
                        shift: 'Mayús',
                        alt: 'Alt',
                        control: 'Control',
                        meta: 'Comando',
                        key: 'Tecla',
                    },
                    en: {
                        arrowup: 'Arrow Up',
                        arrowdown: 'Arrow Down',
                        arrowleft: 'Arrow Left',
                        arrowright: 'Arrow Right',
                        escape: 'Escape',
                        enter: 'Enter',
                        tab: 'Tab',
                        shift: 'Shift',
                        alt: 'Alt',
                        control: 'Control',
                        meta: 'Command',
                        key: 'Key',
                    },
                    no: {
                        arrowup: 'Pil opp',
                        arrowdown: 'Pil ned',
                        arrowleft: 'Pil venstre',
                        arrowright: 'Pil høyre',
                        escape: 'Escape',
                        enter: 'Enter',
                        tab: 'Tab',
                        shift: 'Skift',
                        alt: 'Alt',
                        control: 'Kontroll',
                        meta: 'Kommando',
                        key: 'Tast',
                    },
                    ja: {
                        arrowup: '上矢印',
                        arrowdown: '下矢印',
                        arrowleft: '左矢印',
                        arrowright: '右矢印',
                        escape: 'エスケープ',
                        enter: 'エンター',
                        tab: 'タブ',
                        shift: 'シフト',
                        alt: 'オプション',
                        control: 'コントロール',
                        meta: 'コマンド',
                        key: 'キー',
                    },
                };
                const keyLabelMap = labelsByLang[docLang] || labelsByLang.es;

                const inferKbdTitle = (el) => {
                    const konamiKey = String(el.getAttribute('data-konami-key') || '').toLowerCase();
                    if (konamiKey) return keyLabelMap[konamiKey] || konamiKey.toUpperCase();

                    const dataKey = String(el.getAttribute('data-kbd-key') || '').toLowerCase();
                    if (dataKey) {
                        const first = dataKey.split('|')[0]?.trim() || dataKey;
                        if (first === 'meta') return keyLabelMap.meta;
                        return keyLabelMap[first] || first.toUpperCase();
                    }

                    const text = (el.textContent || '').trim();
                    if (text) return text;

                    const dataCode = String(el.getAttribute('data-kbd-code') || '').toLowerCase();
                    if (dataCode) return dataCode.toUpperCase();

                    return keyLabelMap.key || 'Key';
                };

                allExampleKbd.forEach((kbdEl) => {
                    const el = kbdEl;
                    el.style.cursor = 'pointer';

                    const title = inferKbdTitle(el);
                    el.setAttribute('title', title);
                    el.setAttribute('aria-label', title);

                    if (el.dataset.kbdClickBound === 'true') return;
                    el.dataset.kbdClickBound = 'true';

                    const press = () => {
                        el.classList.add('kbd-clicking');

                        const prev = transientPressTimers.get(el);
                        if (prev) clearTimeout(prev);
                        const timeoutId = setTimeout(() => {
                            el.classList.remove('kbd-clicking');
                            el.classList.remove('kbd-pressed');
                        }, 180);
                        transientPressTimers.set(el, timeoutId);
                    };

                    const release = () => {
                        el.classList.remove('kbd-clicking');
                    };

                    el.addEventListener('pointerdown', press);
                    el.addEventListener('click', () => {
                        playKbdClickSound();
                    });
                    el.addEventListener('pointerup', release);
                    el.addEventListener('pointerleave', release);
                    el.addEventListener('pointercancel', release);
                });

                const markProgress = (count) => {
                    section.setAttribute('data-konami-progress', String(count));
                };

                const setKonamiPressed = (eventKey, pressed) => {
                    const key = String(eventKey || '').toLowerCase();
                    const currentSteps = window.__kbdKonamiSteps || [];

                    currentSteps.forEach((el) => {
                        const matchKey = String(el.getAttribute('data-konami-key') || '').toLowerCase();
                        if (!matchKey || matchKey !== key) return;
                        if (pressed) el.classList.add('kbd-pressed');
                        else el.classList.remove('kbd-pressed');
                    });
                };

                const normalizeKey = (rawKey) => {
                    const key = String(rawKey || '').toLowerCase();
                    if (key === 'os' || key === 'super' || key === 'command') return 'meta';
                    if (key === 'ctrl') return 'control';
                    return key;
                };

                const liveReleaseTimers = new WeakMap();

                const setLivePressed = (eventKey, eventCode, pressed) => {
                    const key = normalizeKey(eventKey);
                    const code = String(eventCode || '').toLowerCase();
                    const currentLiveKeys = window.__kbdLiveKeys || [];
                    const isModifier = key === 'meta' || key === 'control' || key === 'alt' || key === 'shift';

                    currentLiveKeys.forEach((el) => {
                        const matchKey = String(el.getAttribute('data-kbd-key') || '').toLowerCase();
                        const matchCode = String(el.getAttribute('data-kbd-code') || '').toLowerCase();
                        const keyCandidates = matchKey ? matchKey.split('|').map((k) => normalizeKey(k.trim())) : [];
                        const codeCandidates = matchCode ? matchCode.split('|').map((c) => c.trim()) : [];
                        const matches = keyCandidates.includes(key) || codeCandidates.includes(code);

                        if (!matches) return;
                        if (pressed) {
                            el.classList.add('kbd-pressed');

                            // Keep modifier keys pressed while held (Command/Ctrl/Alt/Shift)
                            if (isModifier) {
                                const prev = liveReleaseTimers.get(el);
                                if (prev) clearTimeout(prev);
                                return;
                            }

                            const prev = liveReleaseTimers.get(el);
                            if (prev) clearTimeout(prev);
                            const timeoutId = setTimeout(() => {
                                el.classList.remove('kbd-pressed');
                            }, 260);
                            liveReleaseTimers.set(el, timeoutId);
                        } else {
                            const prev = liveReleaseTimers.get(el);
                            if (prev) clearTimeout(prev);
                            el.classList.remove('kbd-pressed');
                        }
                    });
                };

                const completeKonamiSequence = (source = 'keyboard') => {
                    if (window.__kbdKonamiCelebrating) return;
                    window.__kbdKonamiCelebrating = true;

                    const trigger = window.__TRIGGER_KONAMI__;
                    if (typeof trigger === 'function') {
                        trigger({ triggerHaptic: source === 'pointer' });
                    }

                    if (window.__kbdKonamiResetTimer) {
                        clearTimeout(window.__kbdKonamiResetTimer);
                    }

                    window.__kbdKonamiResetTimer = setTimeout(() => {
                        window.__kbdKonamiProgress = 0;
                        window.__kbdKonamiCelebrating = false;
                        markProgress(0);
                    }, 1000);
                };

                const advanceKonamiProgress = (key, source = 'keyboard') => {
                    if (window.__kbdKonamiCelebrating) return;

                    let progress = Number(window.__kbdKonamiProgress || 0);
                    if (progress >= sequence.length) return;

                    if (key === sequence[progress]) {
                        progress += 1;
                        window.__kbdKonamiProgress = progress;
                        markProgress(progress);

                        if (progress === sequence.length) {
                            completeKonamiSequence(source);
                        }
                        return;
                    }

                    if (key === sequence[0]) {
                        window.__kbdKonamiProgress = 1;
                        markProgress(1);
                    } else {
                        window.__kbdKonamiProgress = 0;
                        markProgress(0);
                    }
                };

                if (window.__kbdKonamiBound) {
                    const progress = Number(window.__kbdKonamiProgress || 0);
                    markProgress(progress);
                }

                window.__kbdKonamiProgress = window.__kbdKonamiProgress || 0;
                markProgress(Number(window.__kbdKonamiProgress || 0));

                // Tap/click support for mobile and desktop demos
                pieces.forEach((pieceEl) => {
                    const el = pieceEl;
                    if (el.dataset.konamiTapBound === 'true') return;
                    el.dataset.konamiTapBound = 'true';

                    const activatePiece = (event) => {
                        event.preventDefault();
                        event.stopPropagation();

                        const key = String(el.getAttribute('data-konami-key') || '').toLowerCase();
                        if (!key) return;
                        advanceKonamiProgress(key, 'pointer');
                    };

                    el.addEventListener('click', activatePiece);
                });

                if (!window.__kbdKonamiBound) {
                    window.__kbdKonamiBound = true;

                    const setModifierPressedStateFromEvent = (e, pressed) => {
                        setLivePressed('meta', 'metaleft', pressed && !!e.metaKey);
                        setLivePressed('control', 'controlleft', pressed && !!e.ctrlKey);
                        setLivePressed('alt', 'altleft', pressed && !!e.altKey);
                        setLivePressed('shift', 'shiftleft', pressed && !!e.shiftKey);
                    };

                    const setMetaButtonsPressed = (pressed) => {
                        const metaButtons = section.querySelectorAll('[data-kbd-live][data-kbd-key*="meta"]');
                        metaButtons.forEach((el) => {
                            el.classList.toggle('kbd-pressed', !!pressed);
                        });
                    };

                    const onKeyDown = (e) => {
                        const key = String(e.key || '').toLowerCase();
                        const code = String(e.code || '').toLowerCase();

                        // Always register modifier presses (especially Meta/Command)
                        if (key === 'meta' || code === 'metaleft' || code === 'metaright' || e.metaKey) {
                            setLivePressed('meta', code || 'metaleft', true);
                            setModifierPressedStateFromEvent(e, true);
                            setMetaButtonsPressed(true);
                        }

                        if (e.repeat) return;

                        setLivePressed(key, code, true);
                        setModifierPressedStateFromEvent(e, true);
                        setKonamiPressed(key, true);
                        advanceKonamiProgress(key, 'keyboard');
                    };

                    const onKeyPress = (e) => {
                        // Fallback listener requested for Command key presses
                        const key = String(e.key || '').toLowerCase();
                        const code = String(e.code || '').toLowerCase();
                        if (key === 'meta' || code === 'metaleft' || code === 'metaright' || e.metaKey) {
                            setLivePressed('meta', code || 'metaleft', true);
                            setModifierPressedStateFromEvent(e, true);
                            setMetaButtonsPressed(true);
                        }
                    };

                    const onKeyUp = (e) => {
                        setLivePressed(e.key, e.code, false);
                        setModifierPressedStateFromEvent(e, true);
                        setMetaButtonsPressed(!!e.metaKey);
                        setKonamiPressed(e.key, false);
                        markProgress(Number(window.__kbdKonamiProgress || 0));
                    };

                    const onWindowBlur = () => {
                        const currentLiveKeys = window.__kbdLiveKeys || [];
                        const currentSteps = window.__kbdKonamiSteps || [];
                        currentLiveKeys.forEach((el) => el.classList.remove('kbd-pressed'));
                        currentSteps.forEach((el) => el.classList.remove('kbd-pressed'));
                        setMetaButtonsPressed(false);
                        markProgress(Number(window.__kbdKonamiProgress || 0));
                    };

                    const onVisibilityChange = () => {
                        if (document.visibilityState !== 'visible') {
                            onWindowBlur();
                        }
                    };

                    window.addEventListener('keydown', onKeyDown);
                    window.addEventListener('keypress', onKeyPress);
                    window.addEventListener('keyup', onKeyUp);
                    window.addEventListener('blur', onWindowBlur);
                    document.addEventListener('visibilitychange', onVisibilityChange);
                }
            };

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initKonamiKbdDemo, { once: true });
            } else {
                initKonamiKbdDemo();
            }

            document.addEventListener('astro:page-load', initKonamiKbdDemo);
        </script>

        <!-- Seven Segment Digits -->
        <section id="seven-segment" class="space-y-6 md:space-y-8">
            <h2 id="seven-segment-heading" class="h2">{sevenSegmentCopy.heading}</h2>
            <p class="md:text-lg leading-relaxed text-main max-w-3xl">
                {sevenSegmentCopy.intro}
            </p>
            <div class="bg-main/10 mb-4">
                <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
                    {sevenSegmentCopy.samples}
                </div>
                <div class="p-4">
                    <div class="p-3 md:p-4 bg-secondary/20 space-y-3">
                        <div class="flex flex-wrap items-center gap-3 md:gap-5">
                            <SevenSegmentDisplay id="ss-demo-na-inverted" value="--:--" />
                            <SevenSegmentDisplay id="ss-demo-ratio-inverted" value="21.0:1" />
                            <SevenSegmentDisplay id="ss-demo-all-inverted" value="0123456789" />
                            <LiveClockDisplay id="ss-local-clock-inverted" />
                            <SevenSegmentDisplay id="ss-demo-konami-inverted" value="5318008" className="!hidden" data-ss-konami-display="true" />
                        </div>
                        <div class="flex flex-wrap items-center gap-3 md:gap-5">
                            <SevenSegmentDisplay id="ss-demo-na-standard" value="--:--" inverted={false} />
                            <SevenSegmentDisplay id="ss-demo-ratio-standard" value="21.0:1" inverted={false} />
                            <SevenSegmentDisplay id="ss-demo-all-standard" value="0123456789" inverted={false} />
                            <LiveClockDisplay id="ss-local-clock-standard" inverted={false} />
                            <SevenSegmentDisplay id="ss-demo-konami-standard" value="5318008" inverted={false} className="!hidden" data-ss-konami-display="true" />
                        </div>
                    </div>
                </div>
            </div>

            <script>
                // @ts-nocheck
                const initSevenSegmentKonamiEasterEgg = () => {
                    const updateKonamiDisplays = () => {
                        const isKonamiActive = localStorage.getItem('special-themes-visible') === 'true';
                        const konamiDisplays = [
                            document.getElementById('ss-demo-konami-inverted'),
                            document.getElementById('ss-demo-konami-standard')
                        ].filter(Boolean);

                        konamiDisplays.forEach((display) => {
                            if (isKonamiActive) display.classList.remove('!hidden');
                            else display.classList.add('!hidden');
                        });
                    };

                    updateKonamiDisplays();

                    if (window.__ssKonamiBound) return;
                    window.__ssKonamiBound = true;

                    window.addEventListener('themes-unlocked', updateKonamiDisplays);
                    window.addEventListener('themes-locked', updateKonamiDisplays);
                    window.addEventListener('storage', (e) => {
                        if (e.key === 'special-themes-visible') updateKonamiDisplays();
                    });
                };

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initSevenSegmentKonamiEasterEgg, { once: true });
                } else {
                    initSevenSegmentKonamiEasterEgg();
                }

                document.addEventListener('astro:page-load', initSevenSegmentKonamiEasterEgg);
            </script>
        </section>

        <!-- Visual Elements -->
        <section id="elementos-visuales" class="space-y-6 md:space-y-8">
            <h2 id="elementos-visuales-heading" class="h2">
                {t('designSystem.visual.heading')}
            </h2>
            <p class="text-body text-main/80 max-w-3xl">{sectionIntro.visual}</p>

            <!-- Diagonal Stripe -->
            <div class="bg-main/10 mb-4">
                <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
                    {t('designSystem.visual.diagonalStripe.title')}
                </div>
                <div class="p-4 space-y-4"> 
                    <div> 
                        <p class="text-body-sm text-main/80 max-w-3xl">
                            {t('designSystem.visual.diagonalStripe.desc')}
                        </p>
                    </div>

                    <div class="border-2 border-main ">
                        <div class="h-32 diagonal-stripe"></div>
                        <span class="sr-only">Ejemplo de patrón de franja diagonal</span>
                    </div>
                </div>
            </div>

            <!-- Wavy Divider --> 
            <div class="bg-main/10 mb-4">
                <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
                   {t('designSystem.visual.wavy.title')}
                </div>
                <div class="p-4 space-y-4"> 
                    <div> 
                        <p class="text-body-sm text-main/80 max-w-3xl">
                            {t('designSystem.visual.wavy.desc')}
                        </p>
                    </div>

                    <div class="border-2 border-main ">
                        <WaveDivider inverted />
                    </div>
                </div>
            </div>
        </section> 

    </ContentPage>
</Layout>
