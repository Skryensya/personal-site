---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/Button.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import ContentPage from '@/components/ContentPage.astro';
import ThemeCard from '@/components/ThemeCard.astro';
import DropdownButton from '@/components/ui/DropdownButton.astro';
import DropdownContent from '@/components/ui/DropdownContent.astro';
import Kbd from '@/components/ui/Kbd.astro';
import themesData from '@/data/themes.json';
import { getTranslations } from '@/i18n/utils';
import { defaultLang, type Language } from '@/i18n/ui';
import WaveDivider from '@/components/WaveDivider.astro';
import SevenSegmentDisplay from '@/components/ui/seven-segment/SevenSegmentDisplay.astro';
import LiveClockDisplay from '@/components/ui/seven-segment/LiveClockDisplay.astro';
import FooterContrastDisplay from '@/components/ui/seven-segment/FooterContrastDisplay.astro';
import FooterNavigationList from '@/components/FooterNavigationList.astro';


interface Props {
    lang?: Language;
}

const { lang = defaultLang } = Astro.props;
const t = getTranslations(lang);

// Localized heading pangram preview aligned to each language
const headingPangram =
    lang === 'es'
        ? '“El pequeño zorro bajó feliz y juguetón al río mientras cantaba.”'
        : lang === 'no'
          ? '“Den lille reven gikk glad og lekende ned til elva mens han sang.”'
          : lang === 'ja'
            ? '「小さな狐は歌いながら、楽しそうに川へ降りていった。」'
            : '“The quick little fox joyfully went down to the river singing a warm tune.”';

const ssDisplayLabel =
    lang === 'es'
        ? 'SS DISPLAY · Space Grotesk'
        : lang === 'no'
          ? 'SS DISPLAY · Space Grotesk'
          : 'SS DISPLAY · Space Grotesk';

const sevenSegmentCopy =
    lang === 'es'
        ? {
              heading: 'Pantalla de siete segmentos',
              intro: 'Sistema de dígitos segmentados para lecturas numéricas. Se usa en estados y métricas para mantener legibilidad y ritmo visual.',
              samples: 'Muestras'
          }
        : lang === 'no'
          ? {
                heading: 'Seven Segment-display',
                intro: 'Segmentert tallsystem for numeriske avlesninger. Brukes i status og målinger for tydelig lesbarhet og visuell rytme.',
                samples: 'Eksempler'
            }
          : lang === 'ja'
            ? {
                  heading: '7セグメント表示',
                  intro: '数値表示のためのセグメント式ディスプレイ。状態表示やメトリクスで可読性と視覚リズムを保ちます。',
                  samples: 'サンプル'
              }
            : {
                heading: 'Seven Segment Display',
                intro: 'Segment-based digit system for numeric readouts. Used in status and metrics to keep readability and visual rhythm.',
                samples: 'Samples'
            };

const keyboardSectionHeading =
    lang === 'es' ? 'Teclas de teclado' : lang === 'no' ? 'Tastaturtaster' : lang === 'ja' ? 'キーボードキー' : 'Keyboard Keys';

const footerNavigationHeading =
    lang === 'es' ? 'Navegación de footer' : lang === 'no' ? 'Footer-navigasjon' : lang === 'ja' ? 'フッターナビゲーション' : 'Footer Navigation';

const kbdText =
    lang === 'es'
        ? {
              ctrl: 'Ctrl',
              enter: 'Intro',
              tab: 'Tab',
              esc: 'Esc',
              key: 'Tecla',
              arrowUp: 'Flecha arriba',
              arrowDown: 'Flecha abajo',
              arrowLeft: 'Flecha izquierda',
              arrowRight: 'Flecha derecha',
              escape: 'Escape',
              shift: 'Mayús',
              alt: 'Alt',
              control: 'Control',
              command: 'Comando'
          }
        : lang === 'no'
          ? {
                ctrl: 'Ctrl',
                enter: 'Enter',
                tab: 'Tab',
                esc: 'Esc',
                key: 'Tast',
                arrowUp: 'Pil opp',
                arrowDown: 'Pil ned',
                arrowLeft: 'Pil venstre',
                arrowRight: 'Pil høyre',
                escape: 'Escape',
                shift: 'Shift',
                alt: 'Alt',
                control: 'Control',
                command: 'Command'
            }
          : lang === 'ja'
            ? {
                  ctrl: 'Ctrl',
                  enter: 'Enter',
                  tab: 'Tab',
                  esc: 'Esc',
                  key: 'キー',
                  arrowUp: '上矢印',
                  arrowDown: '下矢印',
                  arrowLeft: '左矢印',
                  arrowRight: '右矢印',
                  escape: 'Esc',
                  shift: 'Shift',
                  alt: 'Alt',
                  control: 'Control',
                  command: 'Command'
              }
            : {
                  ctrl: 'Ctrl',
                  enter: 'Enter',
                  tab: 'Tab',
                  esc: 'Esc',
                  key: 'Key',
                  arrowUp: 'Arrow Up',
                  arrowDown: 'Arrow Down',
                  arrowLeft: 'Arrow Left',
                  arrowRight: 'Arrow Right',
                  escape: 'Escape',
                  shift: 'Shift',
                  alt: 'Alt',
                  control: 'Control',
                  command: 'Command'
              };

const sectionIntro = {
    structure:
        lang === 'es'
            ? 'Ordenado por importancia: color, temas, tipografía y luego componentes de interacción.'
            : lang === 'no'
              ? 'Sortert etter viktighet: farger, temaer, typografi og deretter interaktive komponenter.'
              : lang === 'ja'
                ? '重要度順に整理しています。色、テーマ、タイポグラフィ、そしてインタラクション要素。'
                : 'Ordered by importance: color, themes, typography, and then interactive components.',
    buttons:
        lang === 'es'
            ? 'Base de interacción primaria. Aquí se concentran estados, jerarquía visual y variantes de acción.'
            : lang === 'no'
              ? 'Grunnlaget for primær interaksjon. Her vises tilstander, visuelt hierarki og handlingsvarianter.'
              : lang === 'ja'
                ? '主要なインタラクション要素。状態、視覚的階層、アクションのバリエーションをまとめています。'
                : 'Core interaction building block. This section shows states, visual hierarchy, and action variants.',
    cards:
        lang === 'es'
            ? 'Contenedor de contenido resumido. Prioriza lectura rápida, enlace claro y estructura consistente.'
            : lang === 'no'
              ? 'Kort for komprimert innhold. Prioriterer rask lesing, tydelig lenke og konsistent struktur.'
              : lang === 'ja'
                ? '要約情報のためのカード。素早い読取、明確なリンク、一貫した構造を重視します。'
                : 'Compact content container focused on quick scanning, clear linking, and consistent structure.',
    footerNav:
        lang === 'es'
            ? 'Patrón de navegación secundaria para cierre de página y acceso a secciones clave.'
            : lang === 'no'
              ? 'Sekundært navigasjonsmønster for sidens avslutning og tilgang til viktige seksjoner.'
              : lang === 'ja'
                ? 'ページ末尾で主要セクションへ素早く移動するための補助ナビゲーションです。'
                : 'Secondary navigation pattern used at page end for quick access to key sections.',
    keyboard:
        lang === 'es'
            ? 'Representación visual de atajos y teclas del sistema para documentación y ayuda contextual.'
            : lang === 'no'
              ? 'Visuell representasjon av hurtigtaster for dokumentasjon og konteksthjelp.'
              : lang === 'ja'
                ? 'ショートカットやシステムキーを視覚的に示し、ドキュメントや文脈ヘルプに活用します。'
                : 'Visual representation of shortcuts and system keys for documentation and contextual help.',
    visual:
        lang === 'es'
            ? 'Recursos decorativos de menor prioridad que refuerzan identidad sin competir con el contenido.'
            : lang === 'no'
              ? 'Dekorative elementer med lavere prioritet som styrker identitet uten å forstyrre innholdet.'
              : lang === 'ja'
                ? '装飾要素は優先度を低く保ち、内容を邪魔せずにサイトの個性を補強します。'
                : 'Lower-priority decorative resources that reinforce identity without competing with content.'
};

const opacities = [100, 80, 60, 40, 20, 10] as const;
const mainBgClasses: Record<(typeof opacities)[number], string> = {
    100: 'bg-main',
    80: 'bg-main/80',
    60: 'bg-main/60',
    40: 'bg-main/40',
    20: 'bg-main/20',
    10: 'bg-main/10'
};
const secondaryBgClasses: Record<(typeof opacities)[number], string> = {
    100: 'bg-secondary',
    80: 'bg-secondary/80',
    60: 'bg-secondary/60',
    40: 'bg-secondary/40',
    20: 'bg-secondary/20',
    10: 'bg-secondary/10'
};
---

<Layout title={`${t('designSystem.title')} - Showcase`} description={t('designSystem.intro.description')} lang={lang}>
    <ContentPage contentId="main-content" lang={lang} useClerkTOC={true} contentClassName="space-y-12 md:space-y-20">
        <!-- Hero Header -->
        <section id="introduccion" class="relative space-y-6 md:space-y-8">
            <div class="mt-6 md:mt-8">
                <h1 id="inicio" class="h1">{t('designSystem.intro.heading')}</h1>
            </div>
            <div class="space-y-6 md:space-y-8 max-w-3xl leading-relaxed text-balance">
                {lang === 'es' && (
                    <>
                        <p class="text-base md:text-lg">Este sistema nace desde una restricción clara: dos colores, bordes definidos y tipografía con jerarquía estable. Al reducir decisiones visuales, el contenido toma protagonismo y cada página mantiene el mismo lenguaje.</p>
                        <p class="text-base md:text-lg">La accesibilidad está integrada desde el diseño: contraste legible, foco visible, estructura semántica y navegación simple. Si quieres revisar criterios y alcance en detalle, puedes leer la <a href="/declaracion-de-accesibilidad" class="underline underline-offset-2 decoration-[1.5px] hover:opacity-80">Declaración de Accesibilidad</a>.</p>
                    </>
                )}
                {lang === 'en' && (
                    <>
                        <p class="text-base md:text-lg">This system is built from a clear constraint: two colors, sharp borders, and typography with a stable hierarchy. By reducing visual choices, content takes priority and every page keeps the same language.</p>
                        <p class="text-base md:text-lg">Accessibility is built into the design: readable contrast, visible focus, semantic structure, and straightforward navigation. If you want to review criteria and scope in detail, read the <a href="/en/accessibility-statement" class="underline underline-offset-2 decoration-[1.5px] hover:opacity-80">Accessibility Statement</a>.</p>
                    </>
                )}
                {lang === 'no' && (
                    <>
                        <p class="text-base md:text-lg">Dette systemet bygger på en tydelig begrensning: to farger, skarpe kanter og typografi med stabilt hierarki. Når de visuelle valgene reduseres, får innholdet mer plass, og alle sider følger samme språk.</p>
                        <p class="text-base md:text-lg">Tilgjengelighet er bygget inn i designet: lesbar kontrast, synlig fokus, semantisk struktur og enkel navigasjon. Hvis du vil se kriterier og omfang i detalj, kan du lese <a href="/no/tilgjengelighetserklaering" class="underline underline-offset-2 decoration-[1.5px] hover:opacity-80">Tilgjengelighetserklæringen</a>.</p>
                    </>
                )}
                {lang === 'ja' && (
                    <>
                        <p class="text-base md:text-lg">このシステムは明確な制約から生まれました。2色のみ、鋭い境界線、安定したタイポグラフィ階層です。視覚的な選択肢を絞ることで、コンテンツが主役になります。</p>
                        <p class="text-base md:text-lg">アクセシビリティは設計段階から組み込まれています。十分なコントラスト、見えるフォーカス、意味論的な構造、シンプルなナビゲーション。詳細は <a href="/ja/accessibility-statement" class="underline underline-offset-2 decoration-[1.5px] hover:opacity-80">アクセシビリティ方針</a>をご覧ください。</p>
                    </>
                )}
            </div>
        </section>

        <!-- Color System -->
        <section id="colores" class="space-y-6 md:space-y-8">
            <h2 id="colores-heading" class="h2">
                {t('designSystem.colors.heading')}
            </h2>

            <p class="md:text-lg leading-relaxed text-main max-w-3xl">
                {t('designSystem.colors.intro')}
            </p>

            <div class="space-y-4 md:space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 border">
                    <div class="bg-secondary p-4 md:p-6 space-y-2 md:space-y-3 border-r">
                        <div class="w-full bg-main flex flex-col justify-end items-end aspect-5/3">
                            <p class="font-mono p-2 w-fit leading-tight text-secondary">--color-main</p>
                        </div>

                        <p class="text-main">
                            {t('designSystem.colors.main.description')}
                        </p>
                    </div>
                    <div class="bg-main p-4 md:p-6 space-y-2 md:space-y-3 ring ring-inset ring-secondary">
                        <div class="w-full bg-secondary flex flex-col justify-end items-end aspect-5/3">
                            <p class="font-mono p-2 w-fit leading-tight text-main">--color-secondary</p>
                        </div>

                        <p class="text-secondary">
                            {t('designSystem.colors.secondary.description')}
                        </p>
                    </div>
                </div>
            </div>

            <!-- Opacity showcase -->
            <div>
                <h3 class="h3">{t('designSystem.colors.opacity.title')}</h3>
                <p class="text-body max-w-3xl text-main/80">{t('designSystem.colors.opacity.intro')}</p>
                <p class="text-body-sm text-main/70">{t('designSystem.colors.opacity.helper')}</p>

                <!-- Main over Secondary (title above, single container with contrast background) -->
                <div class="space-y-3 md:space-y-4 mt-4">
                    <h4 class="h4">{t('designSystem.colors.opacity.mainOverSecondary')}</h4>
                    <div class="w-full border border-main bg-secondary">
                        <div class="p-2">
                            <div class="flex w-full">
                                {
                                    opacities.map((o) => (
                                        <div class="relative w-full h-28 md:h-52 overflow-hidden">
                                            <div class={`absolute inset-0 ${mainBgClasses[o]}`} />
                                            <span class="absolute top-1 left-1 font-mono text-[10px] md:text-xs px-1.5 py-0.5 bg-secondary text-main border border-main">
                                                main/{o}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Secondary over Main (title above, single container with contrast background) -->
                <div class="space-y-3 md:space-y-4 mt-6">
                    <h4 class="h4">{t('designSystem.colors.opacity.secondaryOverMain')}</h4>
                    <div class="w-full border border-main bg-main">
                        <div class="p-2">
                            <div class="flex w-full">
                                {
                                    opacities.map((o) => (
                                        <div class="relative w-full h-28 md:h-52 overflow-hidden">
                                            <div class={`absolute inset-0 ${secondaryBgClasses[o]}`} />
                                            <span class="absolute top-1 left-1 font-mono text-[10px] md:text-xs px-1.5 py-0.5 bg-main text-secondary border border-secondary">
                                                secondary/{o}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="space-y-3 md:space-y-4 mt-8">
                <h3 class="h3">{t('footer.aspectRatio.title')}</h3>
                <div class="inline-block bg-main pr-1.5 pl-0 py-1.5 rounded-sm">
                    <div class="flex items-center gap-2 bg-secondary px-2 py-1.5 rounded-sm">
                        <FooterContrastDisplay
                            id="design-system-contrast-display"
                            initialValue="00.0:0"
                            className="text-main !min-h-[1.75rem] !min-w-[2.55rem] !px-1 !py-0.5 !gap-[1px] !border-0 !border-transparent !shadow-none [transform:scaleX(0.82)_scaleY(0.9)] ss-display-proportion-standard"
                            inverted={false}
                        />
                        <div id="design-system-wcag-levels" class="flex gap-1.5"></div>
                    </div>
                </div>
            </div>

            <script>
                // @ts-nocheck
                const initDesignSystemContrastRatio = () => {
                    const displayTargetId = 'design-system-contrast-display';
                    const wcagLevelsEl = document.getElementById('design-system-wcag-levels');
                    if (!wcagLevelsEl) return;

                    const hexToRgb = (hex: string) => {
                        const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
                        return result
                            ? {
                                  r: parseInt(result[1], 16),
                                  g: parseInt(result[2], 16),
                                  b: parseInt(result[3], 16)
                              }
                            : null;
                    };

                    const getRelativeLuminance = (r: number, g: number, b: number) => {
                        const [rNorm, gNorm, bNorm] = [r, g, b].map((c) => {
                            const normalized = c / 255;
                            return normalized <= 0.03928 ? normalized / 12.92 : Math.pow((normalized + 0.055) / 1.055, 2.4);
                        });
                        return 0.2126 * rNorm + 0.7152 * gNorm + 0.0722 * bNorm;
                    };

                    const getContrastRatio = (color1: string, color2: string) => {
                        const rgb1 = hexToRgb(color1);
                        const rgb2 = hexToRgb(color2);
                        if (!rgb1 || !rgb2) return 1;
                        const lum1 = getRelativeLuminance(rgb1.r, rgb1.g, rgb1.b);
                        const lum2 = getRelativeLuminance(rgb2.r, rgb2.g, rgb2.b);
                        const brightest = Math.max(lum1, lum2);
                        const darkest = Math.min(lum1, lum2);
                        return (brightest + 0.05) / (darkest + 0.05);
                    };

                    const rgbToHex = (rgb: string) => {
                        const values = rgb.match(/\d+/g);
                        if (!values || values.length < 3) return '#000000';
                        const [r, g, b] = values.slice(0, 3).map((v) => parseInt(v, 10));
                        return `#${[r, g, b]
                            .map((x) => {
                                const hex = x.toString(16);
                                return hex.length === 1 ? `0${hex}` : hex;
                            })
                            .join('')}`;
                    };

                    const formatRatio = (ratio: number) => `${ratio.toFixed(1).padStart(4, '0')}:1`;

                    const renderWcagLevels = (ratio: number) => {
                        const levels = [
                            { name: 'A', threshold: 3 },
                            { name: 'AA', threshold: 4.5 },
                            { name: 'AAA', threshold: 7 }
                        ];

                        wcagLevelsEl.innerHTML = '';
                        for (const level of levels) {
                            const passed = ratio >= level.threshold;
                            const levelBox = document.createElement('div');
                            levelBox.className = `px-2 py-1 text-xs font-mono font-bold min-h-[28px] flex items-center border border-main ${
                                passed ? 'bg-secondary text-main opacity-100' : 'bg-secondary text-main/65 opacity-40'
                            }`;
                            levelBox.textContent = level.name;
                            wcagLevelsEl.appendChild(levelBox);
                        }
                    };

                    const updateContrast = () => {
                        const rootStyles = getComputedStyle(document.documentElement);
                        let mainColor = rootStyles.getPropertyValue('--color-main').trim();
                        let secondaryColor = rootStyles.getPropertyValue('--color-secondary').trim();

                        if (!mainColor || !secondaryColor) {
                            const isDarkMode = document.documentElement.getAttribute('data-theme') === 'dark';
                            mainColor = isDarkMode ? '#ffffff' : '#000000';
                            secondaryColor = isDarkMode ? '#000000' : '#ffffff';
                        }

                        if (!mainColor.startsWith('#')) {
                            mainColor = mainColor.startsWith('rgb') ? rgbToHex(mainColor) : '#000000';
                        }
                        if (!secondaryColor.startsWith('#')) {
                            secondaryColor = secondaryColor.startsWith('rgb') ? rgbToHex(secondaryColor) : '#ffffff';
                        }

                        const ratio = getContrastRatio(mainColor, secondaryColor);
                        window.dispatchEvent(
                            new CustomEvent('footer-contrast-change', {
                                detail: { value: formatRatio(ratio), targetId: displayTargetId }
                            })
                        );
                        renderWcagLevels(ratio);
                    };

                    let rafId: number | null = null;
                    const scheduleUpdate = () => {
                        if (rafId !== null) cancelAnimationFrame(rafId);
                        rafId = requestAnimationFrame(() => {
                            rafId = null;
                            updateContrast();
                        });
                    };

                    updateContrast();

                    const observer = new MutationObserver((mutations) => {
                        for (const mutation of mutations) {
                            if (mutation.type === 'attributes' && (mutation.attributeName === 'data-theme' || mutation.attributeName === 'class')) {
                                scheduleUpdate();
                                break;
                            }
                        }
                    });

                    observer.observe(document.documentElement, {
                        attributes: true,
                        attributeFilter: ['data-theme', 'class']
                    });

                    const onDynamicThemeContrast = (event: Event) => {
                        const ratio = (event as CustomEvent).detail?.ratio;
                        if (typeof ratio !== 'number' || Number.isNaN(ratio)) return;
                        window.dispatchEvent(
                            new CustomEvent('footer-contrast-change', {
                                detail: { value: formatRatio(ratio), targetId: displayTargetId }
                            })
                        );
                        renderWcagLevels(ratio);
                    };

                    window.addEventListener('dynamic-theme-contrast', onDynamicThemeContrast);

                    const cleanup = () => {
                        observer.disconnect();
                        window.removeEventListener('dynamic-theme-contrast', onDynamicThemeContrast);
                        if (rafId !== null) cancelAnimationFrame(rafId);
                    };

                    window.addEventListener('astro:before-preparation', cleanup, { once: true });
                    return cleanup;
                };

                const designSystemWindow = window as Window & {
                    __designSystemContrastCleanup?: (() => void) | null;
                    __designSystemContrastPageLoadBound?: boolean;
                };

                const runDesignSystemContrastInit = () => {
                    designSystemWindow.__designSystemContrastCleanup?.();
                    designSystemWindow.__designSystemContrastCleanup = initDesignSystemContrastRatio();
                };

                runDesignSystemContrastInit();
                if (!designSystemWindow.__designSystemContrastPageLoadBound) {
                    document.addEventListener('astro:page-load', runDesignSystemContrastInit);
                    designSystemWindow.__designSystemContrastPageLoadBound = true;
                }
            </script>

        </section>

        <!-- Available Themes -->
        <section id="temas" class="space-y-6 md:space-y-8">
            <h2 id="temas-heading" class="h2">
                {t('designSystem.colors.themes.title')}
            </h2>

            <p class="md:text-lg leading-relaxed text-main max-w-4xl">
                <span set:html={t('designSystem.colors.themes.intro')} />
            </p>

            <!-- Themes container styled like buttons box -->
            <div class="bg-main/10 p-0 space-y-0">
                <!-- Tile header (full width, filled in main) -->
                <div class="w-full bg-main text-secondary border border-main px-3 py-2 font-mono text-sm uppercase font-bold">
                    {t('designSystem.colors.themes.available')}
                </div>
                <!-- Tile content -->
                <div class="flex items-center justify-center p-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="default-themes">
                        {
                            themesData.company.map((theme) => (
                                <div class="company-theme hidden" data-theme-id={theme.id}>
                                    <ThemeCard theme={theme} lang={lang} isActive={false} />
                                </div>
                            ))
                        }
                        {themesData.default.map((theme) => <ThemeCard theme={theme} lang={lang} isActive={false} />)}

                        {
                            themesData.special.map((theme) => (
                                <div class="special-theme hidden" data-theme-id={theme.id}>
                                    <ThemeCard theme={theme} lang={lang} isActive={false} />
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <script>
                // @ts-nocheck
                //
                // Controlador unificado de ThemeCards — reemplaza el script-por-tarjeta.
                // Antes: 1 script × tarjeta (9 scripts × ~7 KB = ~63 KB inline).
                // Ahora: 1 controlador con event delegation sobre el contenedor.
                //
                const initDesignSystemThemeCards = () => {
                    const container = document.getElementById('default-themes');
                    if (!container) return;

                    // ── helpers ──────────────────────────────────────────────────────────

                    function getMode() {
                        const savedMode = localStorage.getItem('theme-mode') || 'system';
                        if (savedMode === 'system') {
                            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                        }
                        return savedMode;
                    }

                    function updateActiveChecks() {
                        const activeId = localStorage.getItem('theme-id') || window.__THEME_ID__;
                        container.querySelectorAll('.theme-card').forEach((card) => {
                            const id = card.getAttribute('data-theme-id');
                            const checked = card.querySelector('.theme-checked');
                            const unchecked = card.querySelector('.theme-unchecked');
                            if (!checked || !unchecked) return;
                            if (id === activeId) {
                                checked.classList.remove('hidden');
                                unchecked.classList.add('hidden');
                                checked.classList.remove('theme-dot-pop');
                                void checked.offsetWidth; // force reflow para reiniciar animación
                                checked.classList.add('theme-dot-pop');
                            } else {
                                checked.classList.add('hidden');
                                unchecked.classList.remove('hidden');
                                checked.classList.remove('theme-dot-pop');
                            }
                        });
                    }

                    function applyVisibilityState() {
                        const activeCompany = sessionStorage.getItem('active-company-theme');
                        document.querySelectorAll('.company-theme').forEach((el) => {
                            const id = el.getAttribute('data-theme-id');
                            el.classList.toggle('hidden', !(activeCompany && id === activeCompany));
                        });
                        const specialUnlocked = localStorage.getItem('special-themes-visible') === 'true';
                        document.querySelectorAll('.special-theme').forEach((el) => {
                            el.classList.toggle('hidden', !specialUnlocked);
                        });
                    }

                    // ── aplicar tema por id ───────────────────────────────────────────────

                    async function applyThemeById(themeId) {
                        if (!themeId) return;
                        const tc = window.themeControl;
                        if (tc && Array.isArray(tc.availableThemes) && typeof tc.selectTheme === 'function') {
                            const found = tc.availableThemes.find((t) => t.id === themeId);
                            if (found) {
                                tc.selectTheme(found);
                                window.dispatchEvent(new CustomEvent('theme-changed', { detail: { themeId } }));
                                return;
                            }
                        }
                        // Fallback si ThemeControl todavía no terminó de inicializar
                        window.dispatchEvent(new CustomEvent('theme-card-select', { detail: { themeId } }));
                        window.dispatchEvent(new CustomEvent('theme-changed', { detail: { themeId } }));
                    }

                    // ── event delegation (UN listener para todas las tarjetas) ────────────

                    if (!container.hasAttribute('data-delegation-bound')) {
                        container.setAttribute('data-delegation-bound', 'true');

                        container.addEventListener('click', async (e) => {
                            // Click en el botón de aplicar (círculo check)
                            const btn = e.target.closest('.apply-theme-btn');
                            if (btn) {
                                e.preventDefault();
                                e.stopPropagation();
                                const themeId = btn.getAttribute('data-theme-id');
                                if (!themeId) return;
                                const isDark = getMode() === 'dark';
                                const mod = await import('../data/themes.js');
                                mod.applyTheme(themeId, isDark);
                                updateActiveChecks();
                                return;
                            }
                            // Click en el cuerpo de la tarjeta
                            const card = e.target.closest('.theme-card');
                            if (card) await applyThemeById(card.getAttribute('data-theme-id'));
                        });

                        container.addEventListener('keydown', async (e) => {
                            if (e.key !== 'Enter' && e.key !== ' ') return;
                            const card = e.target.closest('.theme-card');
                            if (card) {
                                e.preventDefault();
                                await applyThemeById(card.getAttribute('data-theme-id'));
                            }
                        });
                    }

                    // ── prism-flow preview (una sola instancia global) ────────────────────

                    function startPrismPreview() {
                        if (window.__prismPreviewInterval) return;
                        const prismCard = container.querySelector('[data-prism-preview="true"]');
                        if (!prismCard) return;

                        const colorfulPane  = prismCard.querySelector('[data-prism-colorful]');
                        const contrastyPane = prismCard.querySelector('[data-prism-contrasty]');
                        const colorfulVal   = prismCard.querySelector('[data-prism-colorful-value]');
                        const contrastyVal  = prismCard.querySelector('[data-prism-contrasty-value]');
                        if (!colorfulPane || !contrastyPane) return;

                        const w = window;
                        const sessionHue = Number(sessionStorage.getItem('prism-flow-hue'));
                        w.__prismPreviewHue   = Number.isFinite(sessionHue) ? sessionHue : (w.__prismPreviewHue ?? 275);
                        w.__prismPreviewStart = performance.now();

                        const clamp = (v, lo, hi) => Math.min(hi, Math.max(lo, v));

                        // Probe temporal para convertir colores CSS a hex
                        const probe = document.createElement('span');
                        probe.style.display = 'none';
                        document.body.appendChild(probe);
                        const cssToHex = (c) => {
                            probe.style.color = c;
                            const rgb = getComputedStyle(probe).color.match(/\d+/g);
                            if (!rgb || rgb.length < 3) return c;
                            return '#' + rgb.slice(0, 3).map((n) => (+n).toString(16).padStart(2, '0')).join('').toUpperCase();
                        };

                        const paint = (colorful, contrasty) => {
                            colorfulPane.style.backgroundColor = colorful;
                            colorfulPane.style.color           = contrasty;
                            contrastyPane.style.backgroundColor = contrasty;
                            contrastyPane.style.color          = colorful;
                            prismCard.style.borderColor        = colorful;
                            prismCard.style.outline            = `2px solid ${contrasty}`;
                            if (colorfulVal)  colorfulVal.textContent  = cssToHex(colorful);
                            if (contrastyVal) contrastyVal.textContent = cssToHex(contrasty);
                        };

                        const tick = () => {
                            // Si prism-flow está activo, reflejar los colores reales del runtime
                            if (localStorage.getItem('theme-id') === 'prism-flow') {
                                const rs = getComputedStyle(document.documentElement);
                                const cf = rs.getPropertyValue('--theme-colorful').trim();
                                const ct = rs.getPropertyValue('--theme-contrasty').trim();
                                if (cf && ct) { paint(cf, ct); return; }
                            }
                            // Curva animada propia del tema
                            const elapsed = (performance.now() - (w.__prismPreviewStart || 0)) / 1000;
                            const anchors = [196, 228, 272, 318, 18, 52];
                            const cycle   = ((elapsed / 36) % 1 + 1) % 1;
                            const scaled  = cycle * anchors.length;
                            const fi = Math.floor(scaled) % anchors.length;
                            const ti = (fi + 1) % anchors.length;
                            const lt = scaled - Math.floor(scaled);
                            const et = lt * lt * (3 - 2 * lt);
                            const delta = ((anchors[ti] - anchors[fi] + 540) % 360) - 180;
                            const base  = (anchors[fi] + delta * et + 360) % 360;
                            w.__prismPreviewHue = (base + Math.sin(elapsed * 0.19) * 2.6 + Math.sin(elapsed * 0.07 + 1.1) * 1.4 + 360) % 360;
                            const h1 = w.__prismPreviewHue;
                            const h2 = (h1 + 158 + Math.sin(elapsed * 0.11 + 0.6) * 6.5 + 360) % 360;
                            paint(
                                `hsl(${h1.toFixed(1)} ${clamp(66 + Math.sin(elapsed * 0.23) * 7 + Math.sin(elapsed * 0.09 + 1.7) * 4, 56, 78).toFixed(1)}% ${clamp(83 + Math.sin(elapsed * 0.17 + 0.4) * 3.6 + Math.sin(elapsed * 0.05) * 1.8, 76, 88).toFixed(1)}%)`,
                                `hsl(${h2.toFixed(1)} ${clamp(48 + Math.sin(elapsed * 0.21 + 2.2) * 8, 36, 62).toFixed(1)}% ${clamp(20 + Math.sin(elapsed * 0.16 + 0.9) * 3.2, 14, 26).toFixed(1)}%)`
                            );
                        };

                        tick();
                        w.__prismPreviewInterval = window.setInterval(tick, 180);

                        // Limpiar al navegar (View Transitions)
                        window.addEventListener('astro:before-preparation', () => {
                            clearInterval(w.__prismPreviewInterval);
                            w.__prismPreviewInterval = null;
                            probe.remove();
                        }, { once: true });
                    }

                    // ── arranque ─────────────────────────────────────────────────────────

                    applyVisibilityState();
                    updateActiveChecks();
                    startPrismPreview();

                    const onThemeEvent = () => {
                        applyVisibilityState();
                        updateActiveChecks();
                    };

                    window.addEventListener('themes-unlocked',           onThemeEvent);
                    window.addEventListener('themes-locked',             onThemeEvent);
                    window.addEventListener('theme-unlocked',            onThemeEvent);
                    window.addEventListener('theme-changed',             onThemeEvent);
                    window.addEventListener('theme-control-ready',       onThemeEvent);
                    window.addEventListener('company-theme-activated',   onThemeEvent);
                    window.addEventListener('company-theme-deactivated', onThemeEvent);
                    window.addEventListener('storage', (e) => {
                        if (e.key === 'special-themes-visible' || e.key === 'theme-id') onThemeEvent();
                    });
                };

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initDesignSystemThemeCards, { once: true });
                } else {
                    initDesignSystemThemeCards();
                }

                document.addEventListener('astro:page-load', initDesignSystemThemeCards);
            </script>
        </section>


