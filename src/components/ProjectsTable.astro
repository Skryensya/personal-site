---
import type { CollectionEntry } from 'astro:content';
import { getTranslations } from '@/i18n/utils';
import { defaultLang, type Language } from '@/i18n/ui';
import { getLocalizedUrl } from '@/utils/localized-routes';
import { getSlugFromId } from '@/utils/content-utils';
import SevenSegmentDisplay from '@/components/ui/seven-segment/SevenSegmentDisplay.astro';

interface Props {
    projects: CollectionEntry<'projects'>[];
    startIndex?: number;
    lang?: Language;
}

const { projects, startIndex = 0, lang = defaultLang } = Astro.props;
const t = getTranslations(lang);
---

{projects.length > 0 && (
  <div class="w-full">
    <h2 class="h2 mb-8"> 
      {t('home.allProjects')}
    </h2>

    <!-- Header - Desktop only -->
    <div class="hidden md:flex gap-4 border-b border-main/30  py-2 px-6 bg-main items-center selection-opposite">
      <div class="flex-[0_0_30%] flex gap-6 items-center">
        <div class="font-mono text-sm font-bold uppercase tracking-wider text-secondary w-[50px]">#</div>
        <div class="font-mono text-sm font-bold uppercase tracking-wider text-secondary flex-1">{t('projects.table.name')}</div>
      </div>
      <div class="flex-1">
        <div class="font-mono text-sm font-bold uppercase tracking-wider text-secondary">{t('projects.table.description')}</div>
      </div>
      <div class="flex-[0_0_48px]">
        <div class="font-mono text-sm font-bold uppercase tracking-wider text-secondary sr-only">Link</div>
      </div>
    </div>

    <!-- Rows -->
    {projects.map((project: CollectionEntry<'projects'>, index: number) => (
      <a
        href={getLocalizedUrl(lang, 'projects', getSlugFromId(project.id))}
        class="project-row flex flex-col md:flex-row gap-3 md:gap-4 border-b-[1px] border-main/30 border-l-main bg-main/[3%] hover:bg-main/[6%] py-5 md:py-3 px-4 md:px-6 cursor-pointer group font-mono hover:no-underline transition-[background-color,transform,border-color,box-shadow] duration-300 ease-out focus-visible:outline-none focus-visible:bg-main/[8%]"
        style={`--row-index: ${index};`}
      >
        <!-- Mobile: Number above title -->
        <div class="md:hidden">
          <SevenSegmentDisplay
            value={String(startIndex + index + 1).padStart(2, '0')}
            ariaLabel={`${lang === 'es' ? 'Proyecto' : lang === 'no' ? 'Prosjekt' : 'Project'} ${startIndex + index + 1}`}
            inverted={true}
            className="project-number !min-h-[2.05rem] !min-w-[3rem] !px-1 !py-0.5 !gap-[1px] origin-left [transform:scaleX(0.9)_scaleY(1.08)]"
          />
        </div>

        <!-- Number + Name (Desktop) / Just Name (Mobile) -->
        <div class="flex-[0_0_100%] md:flex-[0_0_30%] self-start flex gap-6 items-center">
          <!-- Desktop Number -->
          <div class="hidden md:inline-block w-[50px]">
            <SevenSegmentDisplay
              value={String(startIndex + index + 1).padStart(2, '0')}
              ariaLabel={`${lang === 'es' ? 'Proyecto' : lang === 'no' ? 'Prosjekt' : 'Project'} ${startIndex + index + 1}`}
              inverted={true}
              className="project-number !min-h-[2.05rem] !min-w-[3rem] !px-1 !py-0.5 !gap-[1px] origin-left [transform:scaleX(0.9)_scaleY(1.08)]"
            />
          </div>

          <div class="flex-1">
            <h3 class="h3 !my-0">
              {project.data.name}
            </h3>
          </div>
        </div>

        <!-- Description -->
        <div class="flex-1 self-start">
          <p class="text-body">
            {project.data.hook}
          </p>
        </div>

        <!-- Arrow Icon -->
        <div class="hidden md:flex flex-[0_0_48px] items-center justify-end">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-main/80 project-arrow transition-[transform,opacity,color] duration-300 ease-out group-hover:translate-x-2 group-hover:-translate-y-2">
            <path d="M7 7h10v10"></path>
            <path d="M7 17 17 7"></path>
          </svg>
        </div>
      </a>
    ))}
  </div>
)}

<style>
  .project-row {
    border-left-width: 0;
    border-left-style: solid;
    animation: projectRowIn 520ms cubic-bezier(0.2, 0.75, 0.3, 1) both;
    animation-delay: calc(var(--row-index, 0) * 45ms);
    will-change: transform, opacity;
  }

  .project-row:hover,
  .project-row:focus-visible {
    transform: translateX(6px);
    border-left-width: 3px;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-main) 20%, transparent);
  }

  .project-row:hover .project-number,
  .project-row:focus-visible .project-number {
    transform: translateX(2px);
    color: var(--color-main);
  }

  .project-row:hover .project-arrow,
  .project-row:focus-visible .project-arrow {
    opacity: 1;
    color: var(--color-main);
  }

  @keyframes projectRowIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-row {
      animation: none;
    }

    .project-row,
    .project-row:hover,
    .project-row:focus-visible,
    .project-row:hover .project-number,
    .project-row:focus-visible .project-number,
    .project-row:hover .project-arrow,
    .project-row:focus-visible .project-arrow {
      transform: none;
    }
  }
</style>
