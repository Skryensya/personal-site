---
import ScrollProgress from './ScrollProgress';
import Sidebar from './Sidebar.astro';
import { defaultLang, type Language } from '@/i18n/ui';

interface Props {
    contentId?: string;
    sidebarClassName?: string;
    containerClassName?: string;
    contentClassName?: string;
    lang?: Language;
    useClerkTOC?: boolean;
}

const {
    contentId = 'main-content',
    sidebarClassName = '',
    containerClassName = '',
    contentClassName = '',
    lang = defaultLang,
    useClerkTOC = true,
} = Astro.props as Props;

const resolvedContentId = contentId === 'main-content' ? 'main-content-article' : contentId;
---

<!-- Scroll Progress (global component) -->
<ScrollProgress client:idle />

<!-- Full height layout with content and sidebar -->
<div class={`flex ${containerClassName}`} id={`${resolvedContentId}-container`}>
    <!-- Main content area -->
    <div
        class={`mx-auto min-w-0 w-fit max-w-[850px] ${contentClassName}`}
        id={resolvedContentId}
        data-heading-slug-root
        data-skip-target
    >
        <slot />
    </div>

    <!-- Desktop Sidebar -->
    <Sidebar
        contentId={resolvedContentId}
        className={sidebarClassName}
        lang={lang}
        useClerkTOC={useClerkTOC}
    />
</div>

<script is:inline type="module" define:vars={{ resolvedContentId }}>
    import { initializeHeadingSlugs } from '/src/utils/heading-slugs.ts';

    initializeHeadingSlugs(resolvedContentId);
</script>
