---
import { getTranslationValue, getTranslations } from '@/i18n/utils';
import { defaultLang, type Language } from '@/i18n/ui';
import Button from '../Button.astro';
import CornersWithCrosses from '../CornersWithCrosses.astro';
import FooterNavigationList from '../FooterNavigationList.astro';
import { MapPin, CheckCircle } from 'lucide-react';

interface Props {
  className?: string;
  lang?: Language;
}

const { className = '', lang = defaultLang } = Astro.props;
const t = getTranslations(lang);

const contactLocalPartByLang: Record<Language, string> = {
  es: 'contacto',
  en: 'contact',
  no: 'kontakt',
  ja: 'renraku',
};
const localizedContactEmail = `${contactLocalPartByLang[lang]}@allison.sh`;
const copyEmailLabel = t('about.cta.copy');
const copyEmailSuccess = t('about.cta.copy.success');
const copyEmailError = t('about.cta.copy.error');

const aboutConnectLinks = [
  {
    href: `mailto:${localizedContactEmail}`,
    text: t('social.email'),
    isExternal: true,
  },
  {
    href: 'https://github.com/Skryensya',
    text: t('social.github'),
    isExternal: true,
  },
  {
    href: 'https://linkedin.com/in/skryensya',
    text: t('social.linkedin'),
    isExternal: true,
  },
  {
    href: 'https://lichess.org/@/Skryensya',
    text: t('social.lichess'),
    isExternal: true,
  },
];
---

<section id="about" aria-labelledby="about-heading" class={`relative ${className}`} style="view-transition-name: about-section;">
  <h2 id="about-heading" class="h2">{t('about.title')}</h2>

  <div class="grid items-start gap-4 lg:grid-cols-[1fr_minmax(12rem,16rem)]">
    <!-- Content -->
    <div class=" ">
      <!-- TL;DR Block -->
      <section class="border-2 border-main bg-main p-4 w-full !max-w-[850ch] selection-opposite">
        <h3 class="text-body-mono !my-0 text-secondary">
          {t('about.tldrLabel')}
        </h3>
        <p class="text-2xl leading-[1.25] text-secondary font-semibold text-balance ">
          {t('about.tldr')}
        </p>
      </section>
 

      <!-- Expanded content + Contact CTA -->
      <CornersWithCrosses showLeft={true} showBottom={true} showTopRight={true} showBottomRight={false} class="mt-10 text-main w-full p-5 border-t border-l border-main/20 overflow-visible">
        <div class="about-content space-y-4 max-w-[75ch]">
          {(() => {
            const expandedRaw = getTranslationValue(lang, 'about.expanded');
            const paragraphs: string[] = Array.isArray(expandedRaw)
              ? [...expandedRaw]
              : [String(expandedRaw)];
            return paragraphs.map((paragraph: string) => (
              <p class="text-lg leading-relaxed font-normal" set:html={paragraph} />
            ));
          })()}
        </div>

        <section>
          <div class="leading-relaxed text-main !flex items-center gap-4 w-full">
            <span>{t('about.cta.message')}</span>
            <span>
              <Button variant="outline" elevated href={`mailto:${localizedContactEmail}`} data-haptic="confirm">
                {t('about.cta.button')}
              </Button>
            </span>
          </div>
          <div class="mt-2 flex flex-wrap items-center gap-1 text-sm text-main/70">
            <span>{t('about.cta.or')}</span>
            <button
              type="button"
              class="underline hover:bg-main hover:text-secondary"
              aria-label={`${copyEmailLabel}: ${localizedContactEmail}`}
              data-copy-email-button
              data-copy-email={localizedContactEmail}
              data-copy-success={copyEmailSuccess}
              data-copy-error={copyEmailError}
              data-haptic="confirm"
            >
              {localizedContactEmail}
            </button>
          </div>
        </section>
      </CornersWithCrosses>
    </div>

    <!-- Photo and Contact Info -->
    <div class="space-y-6">
      <figure class="relative aspect-square w-48 lg:w-full overflow-hidden ring-1 ring-main/20 bg-secondary/10 group" style="view-transition-name: photo-block;">
        <picture class="absolute inset-0 size-full transition-opacity duration-300 ease-out group-hover:opacity-0">
          <source srcset="/img/me.webp" type="image/webp" />
          <img
            src="/img/me.png"
            alt={t('cv.photo.alt.pixelated')}
            class="absolute inset-0 size-full object-cover"
            loading="lazy"
            decoding="async"
            fetchpriority="low"
            width="1200"
            height="1600"
          />
        </picture>
        <picture class="absolute inset-0 size-full opacity-0 transition-opacity duration-300 ease-out group-hover:opacity-100">
          <source srcset="/img/true_me.webp" type="image/webp" />
          <img
            src="/img/true_me.png"
            alt={t('cv.photo.alt.original')}
            class="absolute inset-0 size-full object-cover"
            loading="lazy"
            decoding="async"
            fetchpriority="low"
            width="1148"
            height="1425"
          />
        </picture>
        <div
          class="absolute inset-0 pointer-events-none z-10"
          style="background: var(--theme-colorful); mix-blend-mode: color; opacity: 0.28;"
          aria-hidden="true"
        ></div>
      </figure>

      <!-- Contact Info -->
      <div class="space-y-4">
        <!-- Basic Info -->
        <div class="space-y-3">
          <div class="flex items-start gap-3 text-sm">
            <MapPin size={16} className="text-main mt-0.5 flex-shrink-0" />
            <div class="flex-1">
              <div class="font-mono text-xs text-main/70 uppercase tracking-wide">{t('home.stats.location')}</div>
              <div class="font-medium text-main">Santiago, Chile</div>
            </div>
          </div>
          <div class="flex items-start gap-3 text-sm">
            <CheckCircle size={16} className="text-main mt-0.5 flex-shrink-0" />
            <div class="flex-1">
              <div class="font-mono text-xs text-main/70 uppercase tracking-wide">{t('home.stats.status')}</div>
              <div class="font-medium text-main">{t('footer.availableForProjects')}</div>
            </div>
          </div>
        </div>

        <!-- Social Links -->
        <div class="border-t border-main/20 pt-4">
          <div class="font-mono text-sm font-bold text-main uppercase mb-4">{t('footer.connect')}</div>
          <FooterNavigationList links={aboutConnectLinks} inverted />
        </div>
      </div>
    </div>
  </div>

</section>

<script>
  import { showToast } from '@/utils/toast';

  async function copyTextToClipboard(text) {
    if (!text) return false;

    if (navigator.clipboard && window.isSecureContext) {
      await navigator.clipboard.writeText(text);
      return true;
    }

    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.setAttribute('readonly', '');
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    textarea.style.left = '-9999px';
    document.body.appendChild(textarea);
    textarea.focus();
    textarea.select();

    let copied = false;
    try {
      copied = document.execCommand('copy');
    } finally {
      textarea.remove();
    }

    return copied;
  }

  function initCopyEmailButtons() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-copy-email-button]');

    buttons.forEach((button) => {
      const buttonElement = button;
      if (buttonElement.dataset.copyBound === 'true') return;
      buttonElement.dataset.copyBound = 'true';

      buttonElement.addEventListener('click', async () => {
        const email = buttonElement.dataset.copyEmail || '';
        const successMessage = buttonElement.dataset.copySuccess || 'Email copied';
        const errorMessage = buttonElement.dataset.copyError || 'Could not copy email';

        try {
          const copied = await copyTextToClipboard(email);
          if (!copied) throw new Error('copy-failed');

          showToast({
            id: 'copy-email-toast',
            message: successMessage,
            kind: 'success',
            duration: 2200
          });
        } catch {
          showToast({
            id: 'copy-email-toast',
            message: errorMessage,
            kind: 'warning',
            duration: 2800
          });
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCopyEmailButtons, { once: true });
  } else {
    initCopyEmailButtons();
  }

  document.addEventListener('astro:page-load', initCopyEmailButtons);
</script>

<style>
  .about-content :global(a) {
    text-decoration: underline;
    color: var(--color-main);
  }

  .about-content :global(a:hover) {
    background-color: var(--color-main);
    color: var(--color-secondary);
  }
</style>
