---
import { getTranslationValue, getTranslations } from '@/i18n/utils';
import { defaultLang, type Language } from '@/i18n/ui';
import Avatar from '../Avatar.astro';
import AvatarPhraseDisplay from '../AvatarPhraseDisplay.astro';
import Button from '../Button.astro';
import CornersWithCrosses from '../CornersWithCrosses.astro';
import FooterNavigationList from '../FooterNavigationList.astro';

interface Props {
  className?: string;
  lang?: Language;
}

const { className = '', lang = defaultLang } = Astro.props;
const t = getTranslations(lang);

const contactLocalPartByLang: Record<Language, string> = {
  es: 'contacto',
  en: 'contact',
  no: 'kontakt',
  ja: 'renraku',
};
const localizedContactEmail = `${contactLocalPartByLang[lang]}@allison.sh`;
const copyEmailLabel = t('about.cta.copy');
const copyEmailSuccess = t('about.cta.copy.success');
const copyEmailError = t('about.cta.copy.error');

const aboutSayingsRaw = getTranslationValue(lang, 'about.sayings');
const aboutSayings: string[] = Array.isArray(aboutSayingsRaw)
  ? [...aboutSayingsRaw].map((phrase) => String(phrase))
  : [String(aboutSayingsRaw)];

const expandedRaw = getTranslationValue(lang, 'about.expanded');
const aboutParagraphs: string[] = Array.isArray(expandedRaw)
  ? [...expandedRaw].map((paragraph) => String(paragraph))
  : [String(expandedRaw)];

const aboutConnectLinks = [
  {
    href: `mailto:${localizedContactEmail}`,
    text: t('social.email'),
    isExternal: true,
  },
  {
    href: 'https://github.com/Skryensya',
    text: t('social.github'),
    isExternal: true,
  },
  {
    href: 'https://linkedin.com/in/skryensya',
    text: t('social.linkedin'),
    isExternal: true,
  },
  {
    href: 'https://lichess.org/@/Skryensya',
    text: t('social.lichess'),
    isExternal: true,
  },
];
---

<section id="about" aria-labelledby="about-heading" class={`relative ${className}`} style="view-transition-name: about-section;">
  <h2 id="about-heading" class="h2">{t('about.title')}</h2>

  <div class="grid items-start gap-6 lg:grid-cols-[minmax(12rem,16rem)_1fr] lg:gap-8">
    <!-- Avatar and Contact Info -->
    <div class="relative z-[300] space-y-6 overflow-visible lg:-mt-2 lg:sticky lg:top-16">
      <div class="relative z-[310] space-y-2 overflow-visible">
        <figure class="relative aspect-square w-56 overflow-hidden ring-1 ring-main/20 lg:w-full" style="view-transition-name: photo-block;">
          <Avatar id="about-avatar" className="size-full" alt={t('cv.photo.alt.pixelated')} />
        </figure>
        <Button
          size="sm"
          class="w-56 lg:w-full justify-center"
          data-avatar-phrase-next
          data-avatar-target="about-avatar"
          aria-label={t('about.avatarPhrase.next')}
        >
          {t('about.avatarPhrase.next')}
        </Button>
      </div>

      <div class="space-y-4">
        <div class="space-y-3">
          <div class="flex items-start gap-3 text-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-main mt-0.5 flex-shrink-0" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            <div class="flex-1">
              <div class="font-mono text-xs text-main/70 uppercase tracking-wide">{t('home.stats.location')}</div>
              <div class="font-medium text-main">Santiago, Chile</div>
            </div>
          </div>
          <div class="flex items-start gap-3 text-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-main mt-0.5 flex-shrink-0" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>
            <div class="flex-1">
              <div class="font-mono text-xs text-main/70 uppercase tracking-wide">{t('home.stats.status')}</div>
              <div class="font-medium text-main">{t('footer.availableForProjects')}</div>
            </div>
          </div>
        </div>

        <div class="border-t border-main/20 pt-4">
          <div class="font-mono text-sm font-bold text-main uppercase mb-4">{t('footer.connect')}</div>
          <FooterNavigationList links={aboutConnectLinks} inverted />
        </div>
      </div>
    </div>

    <!-- Content -->
    <div>
      <AvatarPhraseDisplay
        avatarId="about-avatar"
        phrases={aboutSayings}
        label={t('about.sayingsLabel')}
        className="mb-6 max-w-[75ch]"
      />
      <CornersWithCrosses showLeft={true} showBottom={true} showTopRight={true} showBottomRight={false} class="text-main w-full p-5 border-t border-l border-main/20 overflow-visible about-copy-selection">
        <div class="about-content space-y-4 max-w-[75ch]">
          {aboutParagraphs.map((paragraph: string) => (
            <p class="text-lg leading-relaxed font-normal" set:html={paragraph} />
          ))}
        </div>

        <section class="mt-8">
          <div class="leading-relaxed text-main !flex items-center gap-4 w-full">
            <span>{t('about.cta.message')}</span>
            <span>
              <Button variant="outline" elevated href={`mailto:${localizedContactEmail}`} data-haptic="confirm">
                {t('about.cta.button')}
              </Button>
            </span>
          </div>
          <div class="mt-2 flex flex-wrap items-center gap-1 text-sm text-main/70">
            <span>{t('about.cta.or')}</span>
            <button
              type="button"
              class="underline hover:bg-main hover:text-secondary"
              aria-label={`${copyEmailLabel}: ${localizedContactEmail}`}
              data-copy-email-button
              data-copy-email={localizedContactEmail}
              data-copy-success={copyEmailSuccess}
              data-copy-error={copyEmailError}
              data-haptic="confirm"
            >
              {localizedContactEmail}
            </button>
          </div>
        </section>
      </CornersWithCrosses>
    </div>
  </div>

</section>

<script>
  import { showToast } from '@/utils/toast';
  import { haptic } from '@/utils/haptics';

  async function copyTextToClipboard(text: string) {
    if (!text) return false;
    if (!navigator.clipboard || !window.isSecureContext) return false;

    await navigator.clipboard.writeText(text);
    return true;
  }

  function initCopyEmailButtons() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-copy-email-button]');

    buttons.forEach((button) => {
      const buttonElement = button;
      if (buttonElement.dataset.copyBound === 'true') return;
      buttonElement.dataset.copyBound = 'true';

      buttonElement.addEventListener('click', async () => {
        const email = buttonElement.dataset.copyEmail || '';
        const successMessage = buttonElement.dataset.copySuccess || 'Email copied';
        const errorMessage = buttonElement.dataset.copyError || 'Could not copy email';

        try {
          const copied = await copyTextToClipboard(email);
          if (!copied) throw new Error('copy-failed');

          showToast({
            id: 'copy-email-toast',
            message: successMessage,
            kind: 'success',
            duration: 2200
          });
          haptic('success');
        } catch {
          showToast({
            id: 'copy-email-toast',
            message: errorMessage,
            kind: 'warning',
            duration: 2800
          });
          haptic('error');
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCopyEmailButtons, { once: true });
  } else {
    initCopyEmailButtons();
  }

  document.addEventListener('astro:page-load', initCopyEmailButtons);
</script>

<style>
  .about-content :global(a) {
    text-decoration: underline;
    color: var(--color-main);
  }

  .about-content :global(a:hover) {
    background-color: var(--color-main);
    color: var(--color-secondary);
  }

  .about-copy-selection ::selection {
    background: var(--color-main);
    color: var(--color-secondary);
    box-shadow: 0 0 0 2px var(--color-main);
  }
</style>
