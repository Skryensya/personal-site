---
// imports normales
import Button from '../Button.astro';

import CornersWithCrosses from '../CornersWithCrosses.astro';
import SimplePixelBlastWithCssVar from '../SimplePixelBlastWithCssVar.tsx';
import HeroCardsAstro from '../HeroCardsAstro.astro';
import { getTranslations } from '@/i18n/utils';
import { defaultLang, type Language } from '@/i18n/ui';
import { getLocalizedUrl } from '@/utils/localized-routes';

interface Props { lang?: Language; }
const { lang = defaultLang } = Astro.props;
const t = getTranslations(lang);
const japaneseName = 'アリソン';
const heroHeading = t('hero.heading');
const heroNameToken = 'Allison';
const heroHeadingParts = lang === 'ja' && heroHeading.includes(heroNameToken)
  ? heroHeading.split(heroNameToken)
  : null;

// Get CV PDF path based on language
const getCVPath = (locale: Language) => {
  // Spanish uses curriculum.pdf
  if (locale === 'es') return '/curriculum.pdf';
  // English and Norwegian use resume.pdf
  return '/resume.pdf';
};
 
---

<section class="hero-section pt-2 mb-10 md:mb-12 relative">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-0">
    <!-- Text Content -->
    <CornersWithCrosses class="flex flex-col justify-center p-4 md:p-8 md:pr-16 min-h-[20rem] md:min-h-[24rem] lg:min-h-[450px] border-t border-l border-main/20">
      <div class="space-y-3 md:space-y-4">
        <h1 class="h1">
          {lang === 'ja' && heroHeadingParts ? (
            <>
              {heroHeadingParts[0]}
              <span class="relative inline-block align-baseline">
                <span class="absolute left-1/2 -translate-x-1/2 -top-[1.1em] font-mono text-[0.30em] tracking-[0.04em] text-main/60 whitespace-nowrap leading-none pointer-events-none select-none">
                  ({japaneseName})
                </span>
                <span class="inline-block ml-[-0.4em] mr-[-0.2em] tracking-[-0.005em]">{heroNameToken}</span>
              </span>
              {heroHeadingParts[1]}
            </>
          ) : (
            heroHeading
          )}
        </h1>
        <p class="mb-4 md:mb-8 md:text-lg text-main/70 max-w-2xl">
          {t('hero.description')}
        </p>
        <div class="flex flex-col sm:flex-row flex-wrap gap-3 md:gap-5">
          <Button href={getLocalizedUrl(lang, 'projects')}  id="projects-button">
            {t('home.heroProjectsButton')}
          </Button>
          <Button href={getCVPath(lang)} filled elevated target="_blank" rel="noopener noreferrer">
            {t('home.cvButton')}
          </Button>
        </div>
      </div>
    </CornersWithCrosses>

    <!-- Cards Section -->
    <CornersWithCrosses class="flex items-center justify-center min-h-[20rem] md:min-h-[24rem] lg:min-h-[450px]" showLeft={false}>
      <div class="overflow-hidden w-full h-full min-h-[20rem] md:min-h-[24rem] lg:min-h-[450px] relative border-b border-r border-main/20">
        <!-- PixelBlast Background -->
        <SimplePixelBlastWithCssVar
          className="absolute inset-0 w-full h-full"
          cssVar="--color-main"
          fallbackColor="#B19EEF"
          pixelSize={8}
          density={0.1}
          speed={0.08}
          decay={0.92}
          maxCells={6000}
          threshold={0.08}
          client:idle
        />

        <!-- Hero Cards on top -->
        <div class="relative z-10 h-full">
          <HeroCardsAstro
            cardDistance={50}
            verticalDistance={50}
            delay={6000}
            pauseOnHover={false}
            width={400}
            height={300}
            frontendTitle={t('hero.cards.frontend.title')}
            frontendDescription={t('hero.cards.frontend.description')}
            backendTitle={t('hero.cards.backend.title')}
            backendDescription={t('hero.cards.backend.description')}
            designTitle={t('hero.cards.design.title')}
            designDescription={t('hero.cards.design.description')}
          />
        </div>
      </div>
    </CornersWithCrosses>
  </div>
  
  <!-- OS Debug Toggle -->
  <!-- <div class="mt-8">
    <SimpleOSDebug client:load />
  </div> -->
</section>
