---
import DropdownButton from './ui/DropdownButton.astro';
import DropdownContent from './ui/DropdownContent.astro';
import { supportedLanguages, languages, type Language } from '@/i18n/ui';
import { getLangFromUrl, getTranslations } from '@/i18n/utils';
import { getEquivalentPage } from '@/utils/localized-routes';

interface Props {
  id?: string;
  placement?: 'bottom-left' | 'bottom-right';
}

const { id = 'language-control', placement = 'bottom-right' } = Astro.props;
const currentLocale = getLangFromUrl(Astro.url);
const pathname = Astro.url.pathname;
const t = getTranslations(currentLocale);
const konamiLockedLanguages: Language[] = ['no', 'ja'];

const translatedNameMap: Record<Language, Record<Language, string>> = {
  es: { es: 'Español', en: 'Inglés', no: 'Noruego', ja: 'Japonés' },
  en: { es: 'Spanish', en: 'English', no: 'Norwegian', ja: 'Japanese' },
  no: { es: 'Spansk', en: 'Engelsk', no: 'Norsk', ja: 'Japansk' },
  ja: { es: 'スペイン語', en: '英語', no: 'ノルウェー語', ja: '日本語' },
};

const languageItems = supportedLanguages.map((lang) => ({
  lang,
  url: getEquivalentPage(pathname, lang),
  nativeName: languages[lang],
  translatedName: translatedNameMap[currentLocale][lang],
  isCurrent: lang === currentLocale,
  isKonamiLocked: konamiLockedLanguages.includes(lang),
}));
---

<div data-component="language-control" data-language-control-id={id} data-current-lang={currentLocale}>
  <DropdownButton
    id={id}
    onMainClick="nextLanguage"
    class="w-7 h-7 lg:w-auto lg:h-8"
    placement={placement}
    ariaLabel={t('nav.menu')}
    lang={currentLocale}
  >
    <div class="flex items-center gap-2">
      <div class="w-3.5 h-3.5 flex-shrink-0 -ml-px translate-y-[0.5px]" aria-hidden="true">
        <svg class="w-3.5 h-3.5 text-main group-hover:text-secondary group-focus-visible:text-secondary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M2 12h20"></path>
          <path d="M12 2a15 15 0 0 1 0 20"></path>
          <path d="M12 2a15 15 0 0 0 0 20"></path>
        </svg>
      </div>
      <span class="font-grotesk text-sm font-semibold text-main group-hover:text-secondary group-focus-visible:text-secondary uppercase" data-language-name-display>
        {languages[currentLocale]}
      </span>
    </div>

    <DropdownContent slot="dropdown-content" class="min-w-[160px]">
      <div data-language-dropdown-content>
        {languageItems.map(({ lang, url, nativeName, translatedName, isCurrent, isKonamiLocked }) => (
          <a
            href={url}
            data-language-link
            data-lang={lang}
            data-url={url}
            data-konami-locked={isKonamiLocked ? 'true' : undefined}
            data-selected={isCurrent ? 'true' : 'false'}
            class:list={[
              'w-full px-1 py-0.5 text-left block cursor-pointer relative focus-visible:z-[9999] no-underline transition-all duration-150',
              isCurrent
                ? 'bg-main text-secondary hover:bg-main hover:text-secondary focus-visible:bg-main focus-visible:text-secondary'
                : 'bg-secondary text-main hover:bg-main hover:text-secondary focus-visible:bg-main focus-visible:text-secondary',
              isKonamiLocked && !isCurrent ? 'hidden' : '',
            ]}
            style="outline-width: 1px; outline-offset: 1px; min-height: 32px;"
            aria-current={isCurrent ? 'true' : undefined}
          >
            <div class="flex items-center gap-0 pointer-events-none">
              <div class="flex-1 px-1 py-1 pointer-events-none select-none">
                <div class="font-grotesk text-sm font-semibold uppercase whitespace-nowrap">
                  {nativeName}
                </div>
                <div class="font-grotesk text-sm opacity-70 mt-0.5 uppercase whitespace-nowrap language-translated-name">
                  {translatedName}
                </div>
              </div>
              <div class="w-4 h-4 flex items-center justify-center pointer-events-none">
                <svg
                  class="w-4 h-4 pointer-events-none language-checkmark"
                  style={`display: ${isCurrent ? 'block' : 'none'};`}
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <polyline points="20,6 9,17 4,12" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </DropdownContent>
  </DropdownButton>
</div>

<script>
  import { supportedLanguages, languages, type Language } from '@/i18n/ui';
  import { getLangFromUrl } from '@/i18n/utils';
  import { getEquivalentPage } from '@/utils/localized-routes';
  import { haptic } from '@/utils/haptics';

  interface HapticOptions {
    triggerHaptic?: boolean;
  }

  const KONAMI_LOCKED_LANGUAGES: Language[] = ['no', 'ja'];

  const translatedNameMap: Record<Language, Record<Language, string>> = {
    es: { es: 'Español', en: 'Inglés', no: 'Noruego', ja: 'Japonés' },
    en: { es: 'Spanish', en: 'English', no: 'Norwegian', ja: 'Japanese' },
    no: { es: 'Spansk', en: 'Engelsk', no: 'Norsk', ja: 'Japansk' },
    ja: { es: 'スペイン語', en: '英語', no: 'ノルウェー語', ja: '日本語' },
  };

  function isKonamiUnlocked() {
    return localStorage.getItem('special-themes-visible') === 'true';
  }

  function getVisibleLanguages(currentLang: Language) {
    return supportedLanguages.filter((lang) => {
      if (!KONAMI_LOCKED_LANGUAGES.includes(lang)) return true;
      return isKonamiUnlocked() || lang === currentLang;
    });
  }

  const languageControl = {
    currentLang: 'es' as Language,

    loadCurrentLanguage() {
      this.currentLang = getLangFromUrl(new URL(window.location.href));
    },

    nextLanguage(options: HapticOptions = {}) {
      const visibleLanguages = getVisibleLanguages(this.currentLang);
      const currentIndex = visibleLanguages.findIndex((lang) => lang === this.currentLang);
      const nextLang = visibleLanguages[(currentIndex + 1) % visibleLanguages.length];
      const nextUrl = getEquivalentPage(window.location.pathname, nextLang);

      localStorage.setItem('langChoice', nextLang);
      if (options.triggerHaptic) haptic('selection');
      window.location.href = nextUrl;
    },

    updateDisplay() {
      const currentLang = this.currentLang;
      const translatedNames = translatedNameMap[currentLang];

      document.querySelectorAll<HTMLElement>('[data-language-name-display]').forEach((el) => {
        el.textContent = languages[currentLang];
      });

      document.querySelectorAll<HTMLElement>('[data-language-link]').forEach((link) => {
        const lang = link.dataset.lang as Language;
        const isSelected = lang === currentLang;
        const isHiddenLocked = KONAMI_LOCKED_LANGUAGES.includes(lang) && !isKonamiUnlocked() && !isSelected;

        link.dataset.selected = isSelected ? 'true' : 'false';
        link.classList.toggle('hidden', isHiddenLocked);
        link.classList.remove('bg-main', 'text-secondary', 'bg-secondary', 'text-main');
        link.classList.add(...(isSelected ? ['bg-main', 'text-secondary'] : ['bg-secondary', 'text-main']));

        const checkmark = link.querySelector<HTMLElement>('.language-checkmark');
        if (checkmark) checkmark.style.display = isSelected ? 'block' : 'none';

        const translatedName = link.querySelector<HTMLElement>('.language-translated-name');
        if (translatedName) translatedName.textContent = translatedNames[lang];
      });
    },

    bindLinks() {
      document.querySelectorAll<HTMLElement>('[data-language-link]').forEach((link) => {
        if (link.dataset.languageBound === 'true') return;
        link.dataset.languageBound = 'true';

        link.addEventListener('click', (event) => {
          const lang = link.dataset.lang as Language;
          const url = link.dataset.url || '/';
          const isPointerClick = event instanceof MouseEvent && event.button === 0 && event.detail > 0;

          localStorage.setItem('langChoice', lang);
          if (!isPointerClick) {
            localStorage.setItem('focusAfterNavigation', 'language-control');
          }
          if (isPointerClick) haptic('selection');

          event.preventDefault();
          window.location.href = url;
        });
      });
    },

    refresh() {
      this.loadCurrentLanguage();
      this.updateDisplay();
      this.bindLinks();
    },

    init() {
      this.refresh();
      window.nextLanguage = (options: HapticOptions = {}) => this.nextLanguage(options);
    }
  };

  declare global {
    interface Window {
      languageControl: typeof languageControl;
      nextLanguage: (options?: HapticOptions) => void;
    }
  }

  window.languageControl = languageControl;

  const initializeLanguageControl = () => {
    window.languageControl.init();

    const sync = () => window.languageControl.refresh();
    window.addEventListener('themes-unlocked', sync);
    window.addEventListener('themes-locked', sync);

    const focusTarget = localStorage.getItem('focusAfterNavigation');
    if (focusTarget === 'language-control') {
      localStorage.removeItem('focusAfterNavigation');
      setTimeout(() => {
        document.querySelector<HTMLElement>('[data-component="language-control"][data-language-control-id="language-control"] [data-main-action="nextLanguage"]')?.focus()
          ?? document.querySelector<HTMLElement>('[data-component="language-control"] [data-main-action="nextLanguage"]')?.focus();
      }, 120);
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeLanguageControl, { once: true });
  } else {
    initializeLanguageControl();
  }

  document.addEventListener('astro:page-load', initializeLanguageControl);
</script>
