---
import ThemeControl from './ThemeControl.astro';
import ModeControl from './ModeControl.astro';
import LanguageControl from './LanguageControl.astro';
import Button from './Button.astro';
import { getLangFromUrl } from '@/i18n/utils';
import { getTranslations } from '@/i18n/utils';
import { themes } from '../data/themes.js';
import { getHomeUrl } from '@/utils/localized-routes';

const currentLocale = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
const t = getTranslations(currentLocale);


// Check if current page is home page
// Spanish default: '/' is home
// Other languages: '/en/' or '/no/' is home
const isHomePage = currentLocale === 'es' 
  ? currentPath === '/' 
  : (currentPath === `/${currentLocale}/` || currentPath === `/${currentLocale}`);

// Prepare localized theme data for client-side JavaScript
const themeNames = themes.reduce((acc, theme) => {
  const key = `theme.${theme.id}`;
  const localized = (t as any)(key);
  acc[theme.id] = (typeof localized === 'string' && localized !== key) ? localized : theme.name;
  return acc;
}, {} as Record<string, string>);

const themeColors = themes.reduce((acc, theme) => {
  acc[theme.id] = {
    colorful: theme.colorful,
    contrasty: theme.contrasty
  };
  return acc;
}, {} as Record<string, { colorful: string; contrasty: string }>);

const projectsAnchor = currentLocale === 'es' ? 'proyectos' : (currentLocale === 'no' ? 'prosjekter' : 'projects');

// Get CV PDF path based on language
const getCVPath = (locale: string) => {
  // Spanish uses curriculum.pdf
  if (locale === 'es') return '/curriculum.pdf';
  // English and Norwegian use resume.pdf
  return '/resume.pdf';
};

const displayName = 'Allison Peña';

const navItems = [
  { label: displayName, href: getHomeUrl(currentLocale) },
  { label: t('nav.projects'), href: `${getHomeUrl(currentLocale)}#${projectsAnchor}` },
  { label: t('nav.cv'), href: getCVPath(currentLocale), isExternal: true, haptic: 'confirm' },
];

