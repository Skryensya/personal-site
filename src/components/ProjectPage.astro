---
import { type CollectionEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ContentPage from './ContentPage.astro';
import { getLocalizedUrl, getHomeUrl } from '@/utils/localized-routes';
import { getSlugFromId } from '@/utils/content-utils';

interface Props {
    projectsByLang: Record<string, CollectionEntry<'projects'>>;
    slug: string;
    currentLocale: "es" | "en" | "no" | "ja";
    navigation: {
        previous: {
            slug: string;
            projectsByLang: Record<string, CollectionEntry<'projects'>>;
        };
        next: {
            slug: string;
            projectsByLang: Record<string, CollectionEntry<'projects'>>;
        };
    };
}

const { projectsByLang, currentLocale, navigation } = Astro.props as Props;

// Get the project for the current language, fallback to Spanish if not available
const project = projectsByLang[currentLocale] || projectsByLang['es'] || Object.values(projectsByLang)[0];

if (!project) {
    return Astro.redirect('/404');
}

const { name, hook, seo, clientLogo } = project.data;
const { Content } = await render(project);

const getProjectForLocale = (entryMap?: Record<string, CollectionEntry<'projects'>>) => {
    if (!entryMap) return undefined;
    return entryMap[currentLocale] || entryMap['es'] || Object.values(entryMap)[0];
};

const previousProjectEntry = getProjectForLocale(navigation?.previous?.projectsByLang);
const nextProjectEntry = getProjectForLocale(navigation?.next?.projectsByLang);

const navigationLabels = {
    es: { previous: 'Anterior', next: 'Siguiente' },
    en: { previous: 'Previous', next: 'Next' },
    no: { previous: 'Forrige', next: 'Neste' },
    ja: { previous: '前へ', next: '次へ' }
} as const;

const navigationSummaryLabel = {
    es: 'Sigue leyendo',
    en: 'Continue reading',
    no: 'Fortsett å lese',
    ja: '続きを読む'
} as const;

const projectPaginationAriaLabel = {
    es: 'Paginación de proyectos',
    en: 'Project pagination',
    no: 'Prosjektpaginering',
    ja: 'プロジェクトページネーション'
} as const;

const navigationItems = [
    {
        entry: previousProjectEntry,
        slug: navigation?.previous?.slug,
        label: navigationLabels[currentLocale].previous,
        variant: 'previous'
    },
    {
        entry: nextProjectEntry,
        slug: navigation?.next?.slug,
        label: navigationLabels[currentLocale].next,
        variant: 'next'
    }
].filter(item => item.entry && item.slug);

const projectSlug = getSlugFromId(project.id);
const projectPath = getLocalizedUrl(currentLocale, 'projects', projectSlug);
const projectCanonicalPath = projectPath.endsWith('/') ? projectPath : `${projectPath}/`;
const projectUrl = new URL(projectCanonicalPath, Astro.site).toString();
const projectImage = seo?.image?.src ? new URL(seo.image.src, Astro.site).toString() : undefined;

const projectJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: seo?.title ?? name,
    description: seo?.description ?? hook ?? '',
    url: projectUrl,
    inLanguage: currentLocale,
    datePublished: project.data.publishDate ? new Date(project.data.publishDate).toISOString() : undefined,
    image: projectImage,
    author: {
        '@type': 'Person',
        name: 'Allison Peña',
        url: 'https://allison.sh/'
    }
};

const projectsLabelByLang = {
    es: 'Proyectos',
    en: 'Projects',
    no: 'Prosjekter',
    ja: 'プロジェクト'
} as const;

const projectsListPath = getLocalizedUrl(currentLocale, 'projects');
const projectsBreadcrumbPath = projectsListPath.includes('#')
    ? getHomeUrl(currentLocale)
    : projectsListPath;

const breadcrumbJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: 'Home',
            item: new URL(getHomeUrl(currentLocale), Astro.site).toString()
        },
        {
            '@type': 'ListItem',
            position: 2,
            name: projectsLabelByLang[currentLocale],
            item: new URL(projectsBreadcrumbPath, Astro.site).toString()
        },
        {
            '@type': 'ListItem',
            position: 3,
            name: name,
            item: projectUrl
        }
    ]
};
---

<Layout title={seo?.title ?? name} description={seo?.description ?? hook} image={seo?.image} pageType="article" showHeader={true} lang={currentLocale} structuredData={[projectJsonLd, breadcrumbJsonLd]}>
    <article class="min-h-screen">
        <ContentPage 
            contentId="project-content"
            sidebarClassName="w-48"
            contentClassName="md:mb-8"
        >
                <!-- Card identical to hero card - this is the transition element -->
                <div class="border border-main bg-secondary flex flex-col overflow-hidden rounded-sm w-[520px] h-[320px]" transition:name={`hero-card-${projectSlug}`} transition:animate="morph">
                    <!-- macOS Window Title Bar - identical to hero card -->
                    <div class="flex items-center gap-2 px-4 py-3 border-b border-main/20 bg-main/5">
                        <div class="flex gap-1.5">
                            <div class="w-2.5 h-2.5 rounded-full bg-main/20"></div>
                            <div class="w-2.5 h-2.5 rounded-full bg-main/20"></div>
                            <div class="w-2.5 h-2.5 rounded-full bg-main/20"></div>
                        </div>
                        <span class="font-mono text-[10px] uppercase tracking-wider text-main/60 truncate flex-1 text-center">
                            {name}
                        </span>
                    </div>
                    <!-- Hook content -->
                    <div class="flex-1 px-5 pt-4 overflow-hidden">
                        <h1 class="text-lg font-bold text-main leading-snug line-clamp-3">
                            {hook}
                        </h1>
                    </div>
                </div>

                    <!-- Article Content -->
                    <div class="prose w-full [&_p]:max-w-[75ch] [&_a]:inline-block [&_a]:whitespace-nowrap [&>p]: [&>p]:lg:text-lg [&>p]:leading-relaxed [&>p]:mb-6 [&>h1]:text-4xl [&>h1]:font-bold [&>h1]:mt-12 [&>h1]:mb-6 [&>h1]:scroll-mt-12 [&>h2]:text-3xl [&>h2]:font-bold [&>h2]:mt-10 [&>h2]:mb-4 [&>h2]:scroll-mt-12 [&>h3]:text-2xl [&>h3]:font-semibold [&>h3]:mt-8 [&>h3]:mb-3 [&>h3]:scroll-mt-12 [&>h4]:text-xl [&>h4]:font-semibold [&>h4]:mt-6 [&>h4]:mb-2 [&>h4]:scroll-mt-12 [&>h5]:scroll-mt-12 [&>h6]:scroll-mt-12" style="max-width: var(--paragraph-max-width)">
                        <Content />
                    </div>

                    {navigationItems.length === 2 && (
                        <section class="w-full mt-14 border-t border-dotted border-main/30 pt-8" style="max-width: var(--paragraph-max-width)" data-toc-ignore>
                            <h2 class="font-grotesk text-base sm:text-lg font-semibold text-main mb-4">
                                {navigationSummaryLabel[currentLocale]}
                            </h2>
                            <nav class="grid grid-cols-1 sm:grid-cols-2 gap-2" aria-label={projectPaginationAriaLabel[currentLocale]}>
                                {navigationItems.map(({ entry, slug, label }) => (
                                    <a
                                        href={getLocalizedUrl(currentLocale, 'projects', slug!)}
                                        class="project-nav-link no-underline"
                                    >
                                        <small class="project-nav-link__meta">
                                            {label}
                                        </small>
                                        <span class="project-nav-link__title">
                                            {entry?.data.name}
                                        </span>
                                    </a>
                                ))}
                            </nav>
                        </section>
                    )}
        </ContentPage>

        <style>
            .project-nav-link {
                display: block;
                min-height: 3.5rem;
                padding: 0.8rem 0.9rem;
                border: 2px double color-mix(in srgb, var(--color-main) 52%, transparent);
                background: color-mix(in srgb, var(--color-main) 4%, var(--color-secondary));
                box-shadow: 2px 2px 0 color-mix(in srgb, var(--color-main) 42%, transparent);
                transition:
                    background-color 170ms ease,
                    border-color 170ms ease,
                    box-shadow 210ms ease,
                    transform 210ms ease;
            }

            .project-nav-link__meta {
                display: block;
                margin-bottom: 0.35rem;
                font-family: var(--font-mono, monospace);
                font-size: 10px;
                text-transform: uppercase;
                letter-spacing: 0.16em;
                color: color-mix(in srgb, var(--color-main) 68%, transparent);
            }

            .project-nav-link__title {
                display: block;
                color: var(--color-main);
                font-size: 0.95rem;
                line-height: 1.3;
                font-weight: 600;
                text-wrap: balance;
            }

            .project-nav-link:hover,
            .project-nav-link:focus-visible {
                transform: translate(-1px, -1px);
                border-color: var(--color-main);
                background: color-mix(in srgb, var(--color-main) 9%, var(--color-secondary));
                box-shadow: 3px 3px 0 color-mix(in srgb, var(--color-main) 60%, transparent);
            }

            .project-nav-link:focus-visible {
                outline: 2px solid var(--color-main);
                outline-offset: 3px;
            }

            @media (min-width: 640px) {
                .project-nav-link__title {
                    font-size: 1rem;
                }
            }

            @media (prefers-reduced-motion: reduce) {
                .project-nav-link {
                    transition: none;
                }

                .project-nav-link:hover,
                .project-nav-link:focus-visible {
                    transform: none;
                    box-shadow: 2px 2px 0 color-mix(in srgb, var(--color-main) 42%, transparent);
                }
            }
        </style>


    </article>

</Layout>

<!-- clientLogo: cargado bajo demanda, no preload para no ocupar ancho de banda crítico -->
{clientLogo && <link rel="prefetch" as="image" href={clientLogo} />}
