---
interface Props {
  class?: string;
  crossSize?: string;
  showLeft?: boolean;
  showRight?: boolean;
  showTop?: boolean;
  showBottom?: boolean;
  showTopLeft?: boolean;
  showTopRight?: boolean;
  showBottomLeft?: boolean;
  showBottomRight?: boolean;
}

const {
  class: className,
  crossSize = "w-3 h-3",
  showLeft = true,
  showRight = true,
  showTop = true,
  showBottom = true,
  showTopLeft,
  showTopRight,
  showBottomLeft,
  showBottomRight
} = Astro.props;

const hasTopLeft = showTopLeft ?? (showTop && showLeft);
const hasTopRight = showTopRight ?? (showTop && showRight);
const hasBottomLeft = showBottomLeft ?? (showBottom && showLeft);
const hasBottomRight = showBottomRight ?? (showBottom && showRight);
---

<div class={`relative ${className || ""}`}>
  <!-- Contenido del slot -->
  <slot />
  
  <!-- Cruz esquina superior izquierda -->
  {hasTopLeft && (
    <div class={`absolute -top-1.5 -left-1.5 ${crossSize} flex items-center justify-center`}>
      <div class="relative w-full h-full">
        <div class="absolute inset-y-0 left-1/2 w-px bg-main transform -translate-x-1/2"></div>
        <div class="absolute inset-x-0 top-1/2 h-px bg-main transform -translate-y-1/2"></div>
      </div>
    </div>
  )}
  
  <!-- Cruz esquina superior derecha -->
  {hasTopRight && (
    <div class={`absolute -top-1.5 -right-1.5 ${crossSize} flex items-center justify-center`}>
      <div class="relative w-full h-full">
        <div class="absolute inset-y-0 left-1/2 w-px bg-main transform -translate-x-1/2"></div>
        <div class="absolute inset-x-0 top-1/2 h-px bg-main transform -translate-y-1/2"></div>
      </div>
    </div>
  )}
  
  <!-- Cruz esquina inferior izquierda -->
  {hasBottomLeft && (
    <div class={`absolute -bottom-1.5 -left-1.5 ${crossSize} flex items-center justify-center`}>
      <div class="relative w-full h-full">
        <div class="absolute inset-y-0 left-1/2 w-px bg-main transform -translate-x-1/2"></div>
        <div class="absolute inset-x-0 top-1/2 h-px bg-main transform -translate-y-1/2"></div>
      </div>
    </div>
  )}
  
  <!-- Cruz esquina inferior derecha -->
  {hasBottomRight && (
    <div class={`absolute -bottom-1.5 -right-1.5 ${crossSize} flex items-center justify-center`}>
      <div class="relative w-full h-full">
        <div class="absolute inset-y-0 left-1/2 w-px bg-main transform -translate-x-1/2"></div>
        <div class="absolute inset-x-0 top-1/2 h-px bg-main transform -translate-y-1/2"></div>
      </div>
    </div>
  )}
</div>