---
import { getTranslations } from '@/i18n/utils';
import { defaultLang, type Language } from '@/i18n/ui';

interface Props {
  contentId?: string;
  className?: string;
  lang?: Language;
  useClerkTOC?: boolean;
}

const {
  contentId = 'main-content',
  className = '',
  lang = defaultLang,
  useClerkTOC = true
} = Astro.props as Props;

const t = getTranslations(lang);
const tocId = `toc-list-${contentId}`;
const homeLabel = t('nav.home');
---

<aside
  class={`sticky top-20 self-start w-[240px] min-w-[240px] flex-shrink-0 hidden md:block py-6 px-4 ${className}`}
  id="content-sidebar"
  data-component="sidebar-toc"
  data-content-id={contentId}
  data-toc-id={tocId}
  data-home-label={homeLabel}
  data-lang={lang}
  data-use-clerk={useClerkTOC}
>
  {useClerkTOC ? (
    <nav aria-label={t('sidebar.toc')}>
      <div class="mb-3 text-xs font-mono font-medium text-main uppercase tracking-wide">{t('sidebar.toc')}</div>
      <ul id={tocId} class="flex flex-col gap-0.5 pe-1"></ul>
    </nav>
  ) : null}
</aside>

<script>
  import { applyHeadingSlugs } from '@/utils/heading-slugs';

  const TOP_OFFSET = 112;
  const SIDEBAR_SELECTOR = '[data-component="sidebar-toc"]';

  const initSidebarToc = () => {
    const sidebar = document.querySelector(SIDEBAR_SELECTOR) as HTMLElement | null;
    if (!sidebar || sidebar.dataset.useClerk !== 'true') return;

    const contentId = sidebar.dataset.contentId || 'main-content';
    const tocId = sidebar.dataset.tocId;
    const homeLabel = sidebar.dataset.homeLabel || 'Home';
    const list = (tocId ? document.getElementById(tocId) : sidebar.querySelector('ul[id]')) as HTMLUListElement | null;
    if (!list) return;

    const getRoot = () => {
      const roots = Array.from(document.querySelectorAll('[data-heading-slug-root]'));
      const exact = roots.find((el) => el.id === contentId);
      return exact || document.getElementById(contentId) || roots[roots.length - 1] || document.querySelector('main');
    };

    const updateActive = (id: string) => {
      const anchors = Array.from(list.querySelectorAll<HTMLAnchorElement>('a[data-toc-id]'));
      anchors.forEach((a) => {
        const active = a.dataset.tocId === id;
        a.classList.toggle('text-main', active);
        a.classList.toggle('font-semibold', active);
        a.classList.toggle('bg-main/10', active);
        a.classList.toggle('border-main', active);
        a.classList.toggle('text-main/70', !active);
        a.classList.toggle('border-transparent', !active);
        if (active) a.setAttribute('aria-current', 'location');
        else a.removeAttribute('aria-current');
      });
    };

    const updateByScroll = () => {
      const sy = window.scrollY || window.pageYOffset;
      if (sy <= 24) {
        updateActive('inicio');
        return;
      }

      const anchors = Array.from(list.querySelectorAll<HTMLAnchorElement>('a[data-toc-id]'));
      const entries = anchors
        .map((a) => a.dataset.tocId)
        .filter((id): id is string => Boolean(id) && id !== 'inicio')
        .map((id) => {
          const el = document.getElementById(id);
          if (!el) return null;
          return { id, top: el.getBoundingClientRect().top + sy };
        })
        .filter((entry): entry is { id: string; top: number } => Boolean(entry));

      if (!entries.length) {
        updateActive('inicio');
        return;
      }

      const reached = entries.filter((e) => e.top <= sy + TOP_OFFSET + 2);
      const current = reached.length ? reached.reduce((a, b) => (a.top > b.top ? a : b)) : entries[0];
      updateActive(current.id);
    };

    const build = () => {
      const root = getRoot();
      if (!root) return;

      const slugResults = applyHeadingSlugs(root, {
        selector: 'h2, h3, h4',
        filter: (heading) => !heading.closest('header') && !heading.closest('[data-toc-ignore]')
      });

      const frag = document.createDocumentFragment();
      const ids = new Set<string>();

      const pushItem = (id: string, title: string, depth: number) => {
        if (!id || ids.has(id)) return;
        ids.add(id);

        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = title;
        a.dataset.tocId = id;
        a.className = [
          'block py-1.5 pe-2 text-sm leading-snug border-l-2 transition-colors max-w-full truncate',
          depth <= 2 ? 'ms-0 ps-2' : depth === 3 ? 'ms-3 ps-2' : 'ms-6 ps-2',
          'text-main/70 hover:text-main border-transparent hover:border-main/30'
        ].join(' ');

        a.addEventListener('click', (e) => {
          if (id === 'inicio') {
            e.preventDefault();
            window.history.pushState(null, '', '#inicio');
            window.scrollTo({ top: 0, behavior: 'smooth' });
            updateActive('inicio');
            return;
          }

          const target = document.getElementById(id);
          if (!target) return;
          e.preventDefault();
          const top = target.getBoundingClientRect().top + window.scrollY - TOP_OFFSET;
          window.history.pushState(null, '', `#${id}`);
          window.scrollTo({ top, behavior: 'smooth' });
          updateActive(id);
        });

        li.appendChild(a);
        frag.appendChild(li);
      };

      pushItem('inicio', homeLabel, 1);
      slugResults.forEach(({ id, text, level }) => pushItem(id, text, level));

      list.innerHTML = '';
      list.appendChild(frag);
      updateByScroll();
    };

    build();

    let raf = 0;
    const schedule = () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        raf = 0;
        updateByScroll();
      });
    };

    const onResize = () => build();
    window.addEventListener('scroll', schedule, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });
    window.addEventListener('hashchange', schedule);

    const win = window as Window & { __sidebarTocCleanup?: Array<() => void> };
    if (!win.__sidebarTocCleanup) win.__sidebarTocCleanup = [];
    win.__sidebarTocCleanup.push(() => {
      window.removeEventListener('scroll', schedule);
      window.removeEventListener('resize', onResize);
      window.removeEventListener('hashchange', schedule);
    });
  };

  const cleanupSidebarToc = () => {
    const win = window as Window & { __sidebarTocCleanup?: Array<() => void> };
    (win.__sidebarTocCleanup || []).forEach((fn) => {
      try { fn(); } catch {}
    });
    win.__sidebarTocCleanup = [];
  };

  cleanupSidebarToc();

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebarToc, { once: true });
  } else {
    initSidebarToc();
  }

  document.addEventListener('astro:page-load', () => {
    cleanupSidebarToc();
    initSidebarToc();
  });
</script>
