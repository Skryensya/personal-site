---
import Layout from '@/layouts/Layout.astro';
import SitemapTree from '@/components/SitemapTree.astro';
import Sidebar from '@/components/Sidebar.astro';
import { defaultLang } from '@/i18n/ui';
import { getSitemapForLanguage, sitemapData, type SitemapNode } from '@/data/sitemap-data';

const lang = defaultLang;
const tree = getSitemapForLanguage(lang);

const countNodes = (nodes: SitemapNode[]): number =>
  nodes.reduce((total, node) => total + 1 + countNodes(node.children || []), 0);

const getMaxDepth = (nodes: SitemapNode[], depth = 1): number => {
  if (!nodes.length) return depth;
  return Math.max(
    ...nodes.map((node) =>
      node.children?.length ? getMaxDepth(node.children, depth + 1) : depth,
    ),
  );
};

const mainSections = tree.length;
const totalNodes = countNodes(tree);
const projectsCount = tree.find((n) => n.url.includes('/proyectos/'))?.children?.length || 0;
const supportedLanguages = Object.keys(sitemapData).length;
const maxDepth = getMaxDepth(tree);
---

<Layout
  title="Árbol de contenido - Allison Peña"
  description="Estructura completa del sitio web de Allison Peña, desarrollador full-stack"
  lang={lang}
>
  <div class="flex gap-4">
    <section id="content-tree-main" class="flex-1 mx-auto max-w-[850px] py-8" data-heading-slug-root>
      <div class="mb-8">
        <h1 id="contenido" class="text-3xl text-mono font-bold text-main border-b-2 border-main pb-4 mb-4">
          Árbol de contenido
        </h1>
        <p class="text-main text-mono">
          Explora la estructura completa del sitio web para navegar fácilmente por todo el contenido.
        </p>
      </div>

      <div id="estructura" class="mb-8">
        <h2 class="text-xl text-mono font-bold text-main border-b border-main pb-2 mb-4">Estructura del sitio</h2>
        <SitemapTree lang={lang} showHeader={false} />
      </div>

      <div class="mt-12 space-y-8">
        <div class="space-y-6">
          <h2 id="info-adicional" class="text-xl text-mono font-bold text-main border-b border-main pb-2">Información adicional</h2>

          <h3 id="metricas-del-sitio" class="text-lg text-mono font-bold text-main">Métricas del sitio</h3>
          <div id="stats" class="grid gap-3 md:grid-cols-2 text-mono text-sm text-main">
            <div class="border border-main p-3 bg-secondary text-main">
              <p class="text-xs opacity-75">Secciones principales</p>
              <p class="text-lg font-bold">{mainSections}</p>
            </div>
            <div class="border border-main p-3">
              <p class="text-xs opacity-75">Páginas/rutas en el árbol</p>
              <p class="text-lg font-bold">{totalNodes}</p>
            </div>
            <div class="border border-main p-3">
              <p class="text-xs opacity-75">Proyectos publicados</p>
              <p class="text-lg font-bold">{projectsCount}</p>
            </div>
            <div class="border border-main p-3">
              <p class="text-xs opacity-75">Profundidad máxima</p>
              <p class="text-lg font-bold">Nivel {maxDepth}</p>
            </div>
            <div class="border border-main p-3 md:col-span-2">
              <p class="text-xs opacity-75">Idiomas soportados</p>
              <p class="text-lg font-bold">{supportedLanguages} (Español, Inglés, Noruego)</p>
            </div>
          </div>

          <div class="border border-main p-3 text-sm text-mono text-main space-y-2">
            <h3 id="recursos-utiles" class="text-base font-bold">Recursos útiles</h3>
            <ul class="list-disc pl-5 space-y-1">
              <li>
                Sitemap XML:
                <a href="/sitemap.xml" class="underline hover:no-underline">/sitemap.xml</a>
              </li>
              <li>Última actualización: {new Date().toLocaleDateString('es-ES')}</li>
              <li>
                Inicio:
                <a href="/" class="underline hover:no-underline">/</a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <Sidebar contentId="content-tree-main" />
  </div>
</Layout>
