                if(k===sig)return;sig=k;
                var url=URL.createObjectURL(new Blob([P+sec+M+main+S],{type:'image/svg+xml'})),
                    el=document.getElementById('favicon');
                if(!el){el=document.createElement('link');el.id='favicon';el.rel='icon';el.type='image/svg+xml';document.head.appendChild(el)}
                el.href=url;if(blob)URL.revokeObjectURL(blob);blob=url;
            }
            w.__SYNC_FAVICON__=sync;
            sync();
            ['theme-changed','mode-changed','company-theme-activated','company-theme-deactivated'].forEach(function(e){w.addEventListener(e,sync)});
            document.addEventListener('astro:page-load',sync);
            document.addEventListener('astro:before-preparation',sync);
            if(w.matchMedia){var mq=w.matchMedia('(prefers-color-scheme: dark)');if(mq.addEventListener)mq.addEventListener('change',sync)}
            new MutationObserver(function(ms){ms.some(function(m){return m.attributeName==='data-theme'||m.attributeName==='class'})&&sync()}).observe(document.documentElement,{attributes:true,attributeFilter:['data-theme','class']});
        })();</script>

        <!-- Selection color animator - defer to reduce blocking -->
        <script>
            import { startGlobalSelectionAnimation } from '@/utils/globalSelectionAnimator';
            import { debugLogger } from '@/utils/debug-lite';

            // Use idle callback for non-critical animation
            function initSelectionAnimation() {
                try {
                    startGlobalSelectionAnimation();
                } catch (err) {
                    debugLogger.warn('Selection animator failed to load:', err);
                }
            }

            if ('requestIdleCallback' in window) {
                requestIdleCallback(initSelectionAnimation, { timeout: 2000 });
            } else {
                setTimeout(initSelectionAnimation, 100);
            }
        </script>
        
        <!-- Additional theme persistence for View Transitions -->
        <script is:inline>
            // Ensure theme persists during View Transitions
            document.addEventListener('astro:before-preparation', function() {
                // Apply theme immediately when preparing for transition
                if (window.__APPLY_THEME_INSTANTLY__) {
                    window.__APPLY_THEME_INSTANTLY__();
                }
            });

            document.addEventListener('astro:after-preparation', function() {
                // Apply theme immediately after transition preparation
                if (window.__APPLY_THEME_INSTANTLY__) {
                    window.__APPLY_THEME_INSTANTLY__();
                }
            });
        </script>


        <!-- Konami Code Integration - defer to reduce blocking -->
        <script is:inline define:vars={{ themeMessages }}>
            // Store theme messages for use in module script
            window.__THEME_MESSAGES__ = themeMessages;
        </script>

        <!-- Footer translations - expose to client scripts -->
        <script is:inline define:vars={{ lang }}>
            // Store all translations for the current language for use in footer scripts
            window.__ASTRO_I18N__ = window.__ASTRO_I18N__ || {};

            // Import translation function on the client
            const translations = {
                'es': {
                    'footer.motion.activated': 'Activado',
                    'footer.motion.deactivated': 'Desactivado'
                },
                'en': {
                    'footer.motion.activated': 'Activated',
                    'footer.motion.deactivated': 'Deactivated'
                },
                'no': {
                    'footer.motion.activated': 'Aktivert',
                    'footer.motion.deactivated': 'Deaktivert'
                },
                'ja': {
                    'footer.motion.activated': '有効',
                    'footer.motion.deactivated': '無効'
                }
            };

            window.__ASTRO_I18N__[lang] = translations[lang];
        </script>

        <script>
            import { initKonami, resetKonami } from '@/utils/konami-init';

            // Konami es un Easter egg de teclado: diferir hasta idle para no bloquear
            function scheduleKonami() {
                if ('requestIdleCallback' in window) {
                    requestIdleCallback(() => initKonami(), { timeout: 4000 });
                } else {
                    setTimeout(initKonami, 1500);
                }
            }

            scheduleKonami();

            // Re-inicializar tras navegación por View Transitions
            document.addEventListener('astro:page-load', () => {
                resetKonami();
                scheduleKonami();
            });
        </script>

        <!-- Company Theme Query Param Detection - only run if params exist -->
        <script>
            import { checkCompanyQueryParams } from '@/utils/company-theme-init';

            // Quick check if any params exist before loading heavy modules
            const hasQueryParams = window.location.search.length > 0;
            if (hasQueryParams) {
                // Check on page load
                checkCompanyQueryParams();
            }

            // Also check on navigation (for SPAs)
            document.addEventListener('astro:page-load', () => {
                if (window.location.search.length > 0) {
                    checkCompanyQueryParams();
                }
            });
        </script>

        <script>
            import { bindHapticActions } from '@/utils/haptics';

            // Haptics son mejora progresiva: diferir hasta idle para no bloquear
            function scheduleHaptics() {
                if ('requestIdleCallback' in window) {
                    requestIdleCallback(() => bindHapticActions(), { timeout: 3000 });
                } else {
                    setTimeout(bindHapticActions, 800);
                }
            }

            scheduleHaptics();
            document.addEventListener('astro:page-load', scheduleHaptics);
        </script>

        <!-- PostHog Analytics -->
        <PostHogAnalytics />

        <script is:inline>
            (() => {
                const nav = navigator;
                const connection = nav.connection;
                const saveData = !!(connection && connection.saveData);
                const verySlowNetwork = /(^|\b)(slow-2g|2g)(\b|$)/i.test((connection && connection.effectiveType) || '');
                const lowCpu = typeof nav.hardwareConcurrency === 'number' && nav.hardwareConcurrency <= 4;
                const lowMemory = typeof nav.deviceMemory === 'number' && nav.deviceMemory <= 4;

                const shouldReduceTransitions = saveData || verySlowNetwork || (lowCpu && lowMemory);
                if (shouldReduceTransitions) {
                    document.documentElement.style.setProperty('--vt-multiplier', '0.01');
                }
            })();
        </script>

        <style is:inline>
            /* Cross-document View Transitions */
            @view-transition {
                navigation: auto;
            }

            @keyframes vt-fade-out {
                from { opacity: 1; transform: translateY(0); }
                to { opacity: 0; transform: translateY(4px); }
            }

            @keyframes vt-fade-in {
                from { opacity: 0; transform: translateY(6px); }
                to { opacity: 1; transform: translateY(0); }
            }

            :root {
                view-transition-name: root;
                --vt-multiplier: 1;
            }

            ::view-transition-old(root) {
                animation: vt-fade-out calc(140ms * var(--vt-multiplier)) cubic-bezier(0.22, 1, 0.36, 1) both;
            }

            ::view-transition-new(root) {
                animation: vt-fade-in calc(180ms * var(--vt-multiplier)) cubic-bezier(0.22, 1, 0.36, 1) both;
            }

            /* Keep navbar stable during transitions */
            ::view-transition-group(navbar),
            ::view-transition-old(navbar),
            ::view-transition-new(navbar) {
                animation: none !important;
            }

            @keyframes click-ray-burst {
                0% {
                    transform: translate(-50%, -50%) rotate(var(--ray-rot, 0deg)) scale(0.56);
                    opacity: 0;
                }
                22% {
                    opacity: 1;
                }
                68% {
                    transform: translate(-50%, -50%) rotate(calc(var(--ray-rot, 0deg) + 2deg)) scale(1.02);
                    opacity: 0.9;
                }
                100% {
                    transform: translate(-50%, -50%) rotate(calc(var(--ray-rot, 0deg) + 3deg)) scale(1.05);
                    opacity: 0;
                }
            }

            .click-ray-burst {
                position: fixed;
                left: 0;
                top: 0;
                width: var(--ray-size, 20px);
                height: var(--ray-size, 20px);
                border-radius: 999px;
                pointer-events: none;
                z-index: 9999;
                animation: click-ray-burst 170ms cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
                will-change: transform, opacity;
            }

            .click-ray-burst::before {
                content: '';
                position: absolute;
                inset: 0;
                border-radius: inherit;
                background: repeating-conic-gradient(
                    from var(--ray-rot, 0deg),
                    var(--color-main) 0deg 9deg,
                    var(--color-secondary) 9deg 18deg,
                    transparent 18deg 52deg
                );
                -webkit-mask: radial-gradient(circle, transparent 0 18%, rgba(0,0,0,0.92) 34%, rgba(0,0,0,0.92) 66%, transparent 84%);
                mask: radial-gradient(circle, transparent 0 18%, rgba(0,0,0,0.92) 34%, rgba(0,0,0,0.92) 66%, transparent 84%);
            }

            .click-ray-burst::after {
                content: '';
                position: absolute;
                left: 50%;
                top: 50%;
                width: 2px;
                height: 2px;
                transform: translate(-50%, -50%);
                border-radius: 999px;
                background: linear-gradient(90deg, var(--color-main), var(--color-secondary));
            }

        </style>
    </head>
    <body class="relative bg-main" id="app-body">
        <ScrollProgress />
        <div class="text-main bg-secondary">

      
        <div class="bg-main w-full h-2"></div> 
        <div class="h-8 !z-100"> 
            <WaveDivider />
        </div>
        <Navbar />
        <NorwegianDisclaimer lang={lang} />
        <div class="pt-24 mt-8 mx-auto max-w-[var(--max-w-size)] "> 
            <main class="text-left px-4" id="main-content" data-skip-target>
                <slot />
            </main>
        </div> 
        <Footer lang={lang} />
         
           </div>


 
        <!-- Lazy loading script to change body background from secondary to main after everything loads -->
        <script>
            // @ts-nocheck
            // Function to bind body background to the live theme variable
            function applyBodyMainBackground() {
                const body = document.body;
                const html = document.documentElement;

                // Wait a bit more to ensure theme variables are fully loaded
                setTimeout(() => {
                    const computedStyle = getComputedStyle(html);
                    const mainColor = computedStyle.getPropertyValue('--color-main').trim();

                    if (mainColor && body) {
                        // Keep a live CSS variable reference so dynamic themes like Prisma
                        // continue updating without needing to rewrite inline colors every frame.
                        body.style.setProperty('background-color', 'var(--color-main)', 'important');
                        if (window.debugLogger) {
                            window.debugLogger.log('🎨 Body background bound to --color-main:', mainColor);
                        }
                    } else {
                        if (window.debugLogger) {
                            window.debugLogger.warn('⚠️ Could not get main color or body element');
                        }
                    }
                }, 100);
            }

            // Tiny subtle click rays on background interactions
            function initClickRayBurst() {
                if (window.__clickRayBurstBound) return;
                window.__clickRayBurstBound = true;

                const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
                if (prefersReducedMotion) return;

                const EXCLUDED_SELECTOR = [
                    'a',
                    'button',
                    'input',
                    'textarea',
                    'select',
                    'summary',
                    'label',
                    '[role="button"]',
                    '[contenteditable="true"]',
                    '[data-no-click-burst]',
                    // text/content elements
                    'p,h1,h2,h3,h4,h5,h6,li,blockquote,code,pre,kbd,span,strong,em,small'
                ].join(',');

                const THROTTLE_MS = 140;
                const MAX_ACTIVE_BURSTS = 2;
                let lastAt = 0;

                const shouldShowForTarget = (target) => {
                    if (!(target instanceof Element)) return true;
                    if (target.closest(EXCLUDED_SELECTOR)) return false;
                    return true;
                };

                const spawn = (x, y) => {
                    const ray = document.createElement('span');
                    ray.className = 'click-ray-burst';
                    ray.style.left = `${x}px`;
                    ray.style.top = `${y}px`;
                    ray.style.setProperty('--ray-rot', `${Math.floor(Math.random() * 360)}deg`);
                    ray.style.setProperty('--ray-size', `${17 + Math.floor(Math.random() * 5)}px`);
                    document.body.appendChild(ray);
                    ray.addEventListener('animationend', () => ray.remove(), { once: true });
                };

                document.addEventListener('pointerdown', (e) => {
                    if (!e.isPrimary) return;
                    if (typeof e.button === 'number' && e.button !== 0) return;
                    if (!shouldShowForTarget(e.target)) return;

                    const now = performance.now();
                    if (now - lastAt < THROTTLE_MS) return;

                    const activeBursts = document.querySelectorAll('.click-ray-burst').length;
                    if (activeBursts >= MAX_ACTIVE_BURSTS) return;

                    lastAt = now;
                    spawn(e.clientX, e.clientY);
                }, { passive: true });
            }

            // Multiple strategies for lazy loading
            function initLazyBodyMainBackground() {
                // Strategy 1: Use requestIdleCallback for true lazy loading
                if ('requestIdleCallback' in window) {
                    requestIdleCallback(() => {
                        if (window.debugLogger) {
                            window.debugLogger.log('🚀 requestIdleCallback triggered');
                        }
                        applyBodyMainBackground();
                    }, { timeout: 3000 });
                } else {
                    // Strategy 2: Fallback to setTimeout
                    if (window.debugLogger) {
                        window.debugLogger.log('🕒 Using setTimeout fallback');
                    }
                    setTimeout(applyBodyMainBackground, 500);
                }
            }

            // Strategy 3: Multiple event listeners to ensure it runs
            function setupLazyBackground() {
                if (window.__lazyBackgroundBound) return;
                window.__lazyBackgroundBound = true;

                if (window.debugLogger) {
                    window.debugLogger.log('🔧 Setting up lazy background, readyState:', document.readyState);
                }

                if (document.readyState === 'complete') {
                    if (window.debugLogger) {
                        window.debugLogger.log('✅ Page already complete, initializing immediately');
                    }
                    setTimeout(initLazyBodyMainBackground, 0);
                } else {
                    window.addEventListener('load', () => {
                        if (window.debugLogger) {
                            window.debugLogger.log('📄 Window load event fired');
                        }
                        initLazyBodyMainBackground();
                    }, { once: true });

                    document.addEventListener('DOMContentLoaded', () => {
                        if (window.debugLogger) {
                            window.debugLogger.log('🏗️ DOMContentLoaded fired');
                        }
                        setTimeout(initLazyBodyMainBackground, 200);
                    }, { once: true });
                }
            }

            // Keep body background in sync with --color-main after theme changes
            function setupThemeBackgroundSync() {
                if (window.__themeBackgroundSyncBound) return;
                window.__themeBackgroundSyncBound = true;

                let syncTimer;
                const sync = () => {
                    clearTimeout(syncTimer);
                    syncTimer = setTimeout(() => applyBodyMainBackground(), 0);
                };

                window.addEventListener('theme-changed', sync);
                window.addEventListener('company-theme-activated', sync);
                window.addEventListener('company-theme-deactivated', sync);

                const rootObserver = new MutationObserver((mutations) => {
                    const changedThemeProps = mutations.some((m) =>
                        m.type === 'attributes' && ['data-theme', 'class'].includes(m.attributeName)
                    );
                    if (changedThemeProps) sync();
                });

                rootObserver.observe(document.documentElement, {
                    attributes: true,
                    attributeFilter: ['data-theme', 'class']
                });
            }

            function initDeferredEffects() {
                setupLazyBackground();
                setupThemeBackgroundSync();
                initClickRayBurst();
            }

            function scheduleDeferredEffects() {
                if ('requestIdleCallback' in window) {
                    requestIdleCallback(initDeferredEffects, { timeout: 2500 });
                } else {
                    setTimeout(initDeferredEffects, 700);
                }
            }

            // Initialize deferred visual effects lazily
            scheduleDeferredEffects();

            // Re-apply after page transitions
            document.addEventListener('astro:page-load', () => {
                if (window.debugLogger) {
                    window.debugLogger.log('🔄 Astro page transition detected');
                }
                setTimeout(() => {
                    scheduleDeferredEffects();
                }, 100);
            });
        </script>
    </body>
</html>
