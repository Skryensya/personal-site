{
    "name": "allison.sh",
    "type": "module",
    "version": "1.0.0",
    "scripts": {
        "predev": "node scripts/avatar/generate-sprite-sheet.mjs",
        "dev": "astro dev",
        "prestart": "node scripts/avatar/generate-sprite-sheet.mjs",
        "start": "astro dev",
        "prebuild": "node scripts/avatar/generate-sprite-sheet.mjs",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "unlighthouse": "npx unlighthouse --site http://localhost:4321",
        "avatar:mouths": "python3 scripts/generate-avatar-mouth-tiles.py",
        "avatar:sprite": "node scripts/avatar/generate-sprite-sheet.mjs",
        "test": "playwright test",
        "test:ui": "playwright test --ui",
        "test:debug": "playwright test --debug",
        "test:headed": "playwright test --headed",
        "test:cross-browser": "playwright test --config=playwright.cross-browser.config.ts",
        "test:cross-browser:ui": "playwright test --config=playwright.cross-browser.config.ts --ui",
        "test:a11y": "playwright test tests/accessibility-smoke.spec.ts",
        "test:a11y:deep": "playwright test tests/accessibility-deep.spec.ts",
        "test:navbar": "playwright test tests/navbar-focus.spec.ts",
        "test:navbar:advanced": "playwright test tests/navbar-keyboard-advanced.spec.ts",
        "test:nav:a11y": "playwright test tests/navbar-focus.spec.ts tests/navbar-keyboard-advanced.spec.ts"
    },
    "dependencies": {
        "@astrojs/mdx": "^5.0.1",
        "@astrojs/react": "^5.0.0",
        "@astrojs/rss": "^4.0.17",
        "@astrojs/sitemap": "^3.7.1",
        "@tailwindcss/vite": "^4.2.1",
        "@tanstack/react-table": "^8.21.3",
        "astro": "^6.0.5",
        "astro-font": "^1.1.0",
        "clsx": "^2.1.1",
        "embla-carousel": "^8.6.0",
        "embla-carousel-autoplay": "^8.6.0",
        "embla-carousel-react": "^8.6.0",
        "gsap": "^3.14.2",
        "lucide-react": "^0.577.0",
        "posthog-js": "^1.360.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-rnd": "^10.5.3",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "web-haptics": "^0.0.6"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.8",
        "@axe-core/playwright": "^4.11.1",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/typography": "^0.5.19",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "install": "^0.13.0",
        "npm": "^11.11.1",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript": "^5.9.3"
    }
}
